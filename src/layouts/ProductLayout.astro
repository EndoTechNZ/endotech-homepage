---
import Layout from './Layout.astro';
import logo from '../assets/logo-wordmark.png';

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: Record<string, unknown>;
  accent?: 'teal' | 'violet' | 'slate';
}

const { title, description, image, schema, accent = 'teal' } = Astro.props;
const base = import.meta.env.BASE_URL;
const accentClass = {
  teal: 'text-teal-700',
  violet: 'text-violet-700',
  slate: 'text-slate-700',
}[accent];
---

<Layout title={title} description={description} image={image}>
  {schema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/92 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href={base} class="flex items-center gap-3">
        <img src={logo.src} alt="EndoTech Singapore" class="h-10 w-auto" />
      </a>
      <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-600 lg:flex">
        <a href={base} class="hover:text-slate-900">Home</a>
        <a href={`${base}products/bcs/`} class={`hover:text-slate-900 ${accentClass}`}>Products</a>
        <a href={`${base}technique/workflow/`} class="hover:text-slate-900">Clinical Workflow</a>
        <a href={`${base}technology/transform-technology/`} class="hover:text-slate-900">Technology</a>
        <a href={`${base}resources/clinical-tips/`} class="hover:text-slate-900">Education</a>
        <a href={`${base}products/bcs/evidence/`} class="hover:text-slate-900">Evidence & Downloads</a>
        <a href={`${base}about/company/`} class="hover:text-slate-900">About</a>
        <a href={`${base}about/contact/`} class="rounded-full bg-slate-900 px-5 py-2.5 text-white hover:bg-slate-800">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-7xl px-6 py-10">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-lg font-bold text-slate-900">EndoTech Singapore</p>
          <p class="mt-2 max-w-xl text-sm leading-7 text-slate-600">
            Clinical endodontic systems and bioceramic materials presented with a workflow-first, evidence-aware approach.
          </p>
        </div>
        <div class="flex flex-wrap gap-4 text-sm font-semibold text-slate-600">
          <a href={`${base}products/bcs/`} class="hover:text-slate-900">BCS Family</a>
          <a href={`${base}products/bcs-bioceramic-sealer/`} class="hover:text-slate-900">BCS BioCeramic Sealer</a>
          <a href={`${base}products/bcs-bioceramic-putty/`} class="hover:text-slate-900">BCS BioCeramic Putty</a>
          <a href={`${base}products/bcs/evidence/`} class="hover:text-slate-900">Downloads</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
