---
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import FeatureGrid from '../../components/product/FeatureGrid.astro';
import ApplicationsGrid from '../../components/product/ApplicationsGrid.astro';
import PackagingPanel from '../../components/product/PackagingPanel.astro';
import DownloadsList from '../../components/product/DownloadsList.astro';
import DistributorCTA from '../../components/product/DistributorCTA.astro';
import { bcsSealer, getProductDownloads } from '../../data/bcs';
import { getBcsDownloads } from '../../utils/downloads';
import { withBasePath } from '../../utils/paths';

const siteUrl = Astro.site?.toString() ?? 'https://endotechnz.github.io';
const clinicalBenefitCards = bcsSealer.clinicalBenefits.map((benefit) => ({
  title: benefit,
  description: 'Stated in practical clinical language rather than broad promotional language.',
  icon: 'workflow' as const,
}));

const downloads = getProductDownloads(getBcsDownloads());
const sealerImage = withBasePath('/downloads/metallic-packshots/BCS-Sealer-metallic-silver.png');
const sealerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'BCS BioCeramic Sealer',
  description: bcsSealer.shortDescription,
  brand: {
    '@type': 'Brand',
    name: 'EndoTech Singapore',
  },
  category: 'Bioceramic root canal sealer',
  image: [new URL(sealerImage, siteUrl).toString()],
  url: new URL('/products/bcs-bioceramic-sealer/', siteUrl).toString(),
  additionalProperty: bcsSealer.featureBullets.map((feature) => ({
    '@type': 'PropertyValue',
    name: feature.title,
    value: feature.description,
  })),
};
---

<ProductLayout
  title="BCS BioCeramic Sealer | Bioceramic Root Canal Sealer"
  description={bcsSealer.shortDescription}
  image={sealerImage}
  schema={sealerSchema}
  accent="teal"
>
  <ProductHero
    eyebrow="BCS BioCeramic Sealer"
    title={bcsSealer.name}
    subtitle={bcsSealer.headline}
    description={bcsSealer.subheadline}
    ctas={bcsSealer.ctas}
    accent="teal"
    imageSrc={sealerImage}
    imageAlt="BCS BioCeramic Sealer premixed root canal sealer syringe"
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto grid max-w-7xl gap-4 px-6 py-14 sm:gap-6 sm:py-16 lg:grid-cols-2 lg:py-20">
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-50/70 p-5 sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Problem</p>
        <p class="mt-4 text-base leading-7 text-slate-600 sm:mt-5 sm:leading-8">{bcsSealer.clinicalProblem}</p>
      </article>
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-950 p-5 text-white sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">TransformX Solution</p>
        <p class="mt-4 text-base leading-7 text-slate-300 sm:mt-5 sm:leading-8">{bcsSealer.transformxSolution}</p>
      </article>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">What Makes It Different</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A simpler sealer story</h2>
      <p class="mt-4 max-w-4xl text-base leading-7 text-slate-600 sm:mt-6 sm:text-lg sm:leading-8">{bcsSealer.whatMakesItDifferent}</p>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Key Features</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The core product attributes</h2>
      <ul class="mt-8 grid gap-3 sm:mt-10 sm:gap-4 md:grid-cols-2">
        {bcsSealer.featureBullets.map((feature) => (
          <li class="rounded-[1.2rem] border border-slate-200 bg-slate-50/70 px-4 py-3.5 text-sm font-semibold text-slate-900 sm:rounded-[1.5rem] sm:px-5 sm:py-4 sm:text-base">
            {feature.title}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Proof</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Why clinicians move to bioceramic sealers</h2>
      <div class="mt-8 grid gap-4 sm:mt-10 sm:gap-5 md:grid-cols-2">
        {bcsSealer.proofBlocks.map((block) => (
          <article class="rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:rounded-[1.75rem] sm:p-7">
            <h3 class="text-xl font-bold tracking-tight text-slate-900 sm:text-2xl">{block.title}</h3>
            <p class="mt-3 text-base leading-7 text-slate-600 sm:mt-4 sm:leading-8">{block.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ApplicationsGrid
    eyebrow="Indications"
    title="Where BCS BioCeramic Sealer fits"
    items={['Root canal sealing', 'Hydraulic single-cone obturation']}
    accent="teal"
  />

  <FeatureGrid
    eyebrow="Clinical Benefits"
    title="Clinical benefits"
    items={clinicalBenefitCards}
    accent="teal"
  />

  <PackagingPanel items={bcsSealer.packaging} />
  <DownloadsList
    title="Downloads"
    intro="Brochure, IFU, SDS, and supporting technical files are available from the BCS evidence section."
    items={downloads}
  />
  <DistributorCTA
    title="Use BCS BioCeramic Sealer - next generation of biocompatibility"
    body={bcsSealer.regulatoryNote}
    secondaryLabel="View evidence"
    secondaryHref="/products/bcs/evidence/"
  />
</ProductLayout>
