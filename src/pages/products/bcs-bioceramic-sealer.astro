---
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import FeatureGrid from '../../components/product/FeatureGrid.astro';
import ApplicationsGrid from '../../components/product/ApplicationsGrid.astro';
import PackagingPanel from '../../components/product/PackagingPanel.astro';
import DownloadsList from '../../components/product/DownloadsList.astro';
import DistributorCTA from '../../components/product/DistributorCTA.astro';
import { bcsSealer, getProductDownloads } from '../../data/bcs';
import { getBcsDownloads } from '../../utils/downloads';
import { withBasePath } from '../../utils/paths';

const clinicalBenefitCards = bcsSealer.clinicalBenefits.map((benefit) => ({
  title: benefit,
  description: 'Stated in practical clinical language rather than broad promotional language.',
  icon: 'workflow' as const,
}));

const downloads = getProductDownloads(getBcsDownloads());
const sealerImage = withBasePath('/downloads/metallic-packshots/BCS-Sealer-metallic-silver.png');
---

<ProductLayout
  title="BCS BioCeramic Sealer | EndoTech Singapore"
  description={bcsSealer.shortDescription}
  accent="teal"
>
  <ProductHero
    eyebrow="BCS BioCeramic Sealer"
    title={bcsSealer.name}
    subtitle={bcsSealer.headline}
    description={bcsSealer.subheadline}
    ctas={bcsSealer.ctas}
    accent="teal"
    imageSrc={sealerImage}
    imageAlt="BCS BioCeramic Sealer"
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto grid max-w-7xl gap-6 px-6 py-20 lg:grid-cols-2">
      <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50/70 p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Problem</p>
        <p class="mt-5 text-base leading-8 text-slate-600">{bcsSealer.clinicalProblem}</p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-7 text-white">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">TransformX Solution</p>
        <p class="mt-5 text-base leading-8 text-slate-300">{bcsSealer.transformxSolution}</p>
      </article>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">What Makes It Different</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">A simpler sealer story</h2>
      <p class="mt-6 max-w-4xl text-lg leading-8 text-slate-600">{bcsSealer.whatMakesItDifferent}</p>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Key Features</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">The core product attributes</h2>
      <ul class="mt-10 grid gap-4 md:grid-cols-2">
        {bcsSealer.featureBullets.map((feature) => (
          <li class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 px-5 py-4 text-base font-semibold text-slate-900">
            {feature.title}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Proof</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Why clinicians move to bioceramic sealers</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {bcsSealer.proofBlocks.map((block) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7">
            <h3 class="text-2xl font-bold tracking-tight text-slate-900">{block.title}</h3>
            <p class="mt-4 text-base leading-8 text-slate-600">{block.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ApplicationsGrid
    eyebrow="Indications"
    title="Where BCS BioCeramic Sealer fits"
    intro="Keep indications concise and immediately relevant to the sealer itself."
    items={['Root canal sealing', 'Hydraulic single-cone obturation']}
    accent="teal"
  />

  <FeatureGrid
    eyebrow="Clinical Benefits"
    title="Clinical benefits"
    items={clinicalBenefitCards}
    accent="teal"
  />

  <PackagingPanel items={bcsSealer.packaging} />
  <DownloadsList
    title="Downloads"
    intro="Brochure, IFU, SDS, and supporting technical files are available from the BCS evidence section."
    items={downloads}
  />
  <DistributorCTA
    title="Use BCS BioCeramic Sealer where the message should be immediate and product-led"
    body={bcsSealer.regulatoryNote}
    secondaryLabel="View evidence"
    secondaryHref="/products/bcs/evidence/"
  />
</ProductLayout>
