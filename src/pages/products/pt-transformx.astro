---
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import FeatureGrid from '../../components/product/FeatureGrid.astro';
import ProductOrderSelector from '../../components/product/ProductOrderSelector.astro';
import ptProduct from '../../assets/transformx-rotary-file-system.png';
import { withBasePath } from '../../utils/paths';
import { siteConfig } from '../../config/site';
import { getShopifyStoreDomain } from '../../utils/shopify';
import { buildOrderSelectorItems, getOrderCoverageLabel } from '../../utils/productOrdering';

const siteUrl = Astro.site?.toString() ?? 'https://endotechnz.github.io';
const workflowPdfSrc = withBasePath('/downloads/PT-Technique-Work-Flow.pdf');
const partNumbersPdfSrc = withBasePath('/downloads/PT-Part-Numbers.pdf');
const shopifyStoreDomain = getShopifyStoreDomain();

const ptOrderEntries = [
  { size: 'SX', length: '19 mm', sku: 'TXPT-SX-19', handle: null },
  { size: 'S1', length: '21 mm', sku: 'TXPT-S1-21', handle: null },
  { size: 'S2', length: '21 mm', sku: 'TXPT-S2-21', handle: null },
  { size: 'F1', length: '21 mm', sku: 'TXPT-F1-21', handle: null },
  { size: 'F2', length: '21 mm', sku: 'TXPT-F2-21', handle: null },
  { size: 'F3', length: '21 mm', sku: 'TXPT-F3-21', handle: null },
  { size: 'S1', length: '25 mm', sku: 'TXPT-S1-25', handle: null },
  { size: 'S2', length: '25 mm', sku: 'TXPT-S2-25', handle: null },
  { size: 'F1', length: '25 mm', sku: 'TXPT-F1-25', handle: null },
  { size: 'F2', length: '25 mm', sku: 'TXPT-F2-25', handle: null },
  { size: 'F3', length: '25 mm', sku: 'TXPT-F3-25', handle: null },
  { size: 'F4', length: '25 mm', sku: 'TXPT-F4-25', handle: null },
  { size: 'F5', length: '25 mm', sku: 'TXPT-F5-25', handle: null },
  { size: 'S1', length: '31 mm', sku: 'TXPT-S1-31', handle: null },
  { size: 'S2', length: '31 mm', sku: 'TXPT-S2-31', handle: null },
  { size: 'F1', length: '31 mm', sku: 'TXPT-F1-31', handle: null },
  { size: 'F2', length: '31 mm', sku: 'TXPT-F2-31', handle: null },
  { size: 'F3', length: '31 mm', sku: 'TXPT-F3-31', handle: null },
];

const ptOrderItems = await buildOrderSelectorItems(ptOrderEntries, shopifyStoreDomain);
const orderPanelDescription = `To order
- Choose file Size (Step 1)
- Choose file length (Step 2)
- Click 'Add to order'`;
const ptSelectionNote =
  'SX is supplied in 19 mm. Shaping and finishing files run across 21 mm, 25 mm, and 31 mm lengths in the current PT TransformX part-number sheet.';

const keyFeatureItems = [
  {
    title: 'Progressive PT sequence architecture',
    description:
      'Built for clinicians already shaping with ProTaper-style coronal, shaping, and finishing logic, so the sequence remains clinically familiar from SX through to the finishing files.',
    icon: 'workflow' as const,
  },
  {
    title: 'Avatar Tip for centred progression',
    description:
      'The apical design supports more controlled advancement through curvature, helping the file follow canal anatomy with less tendency to drift away from the original path.',
    icon: 'handling' as const,
  },
  {
    title: 'Transform Technology through the working length',
    description:
      'Variable metallurgy is used to balance flexibility, torsional control, and cutting response along the file, especially where the shaping sequence becomes more demanding.',
    icon: 'stability' as const,
  },
];

const clinicalBenefitItems = [
  {
    title: 'Keep a familiar PT workflow',
    description:
      'Supports clinicians who want the feel of a ProTaper-style sequence without rebuilding their preparation logic from the start.',
    icon: 'workflow' as const,
  },
  {
    title: 'Improve control through coronal to apical shaping',
    description:
      'Links the file design directly to the clinical challenge of maintaining centred preparation as taper and canal demand increase.',
    icon: 'handling' as const,
  },
  {
    title: 'Match file choice to apical anatomy',
    description:
      'The familiar finishing sequence keeps clinical decision-making readable when selecting F1, F2, F3, and larger finishing files according to canal size.',
    icon: 'stability' as const,
  },
];

const ptSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'PT TransformX Files',
  description:
    'PT TransformX rotary shaping files for clinicians using a ProTaper-style workflow, combining progressive sequence logic with Avatar Tip and Transform Technology.',
  brand: {
    '@type': 'Brand',
    name: siteConfig.name,
  },
  category: 'Endodontic rotary files',
  image: [new URL(ptProduct.src, siteUrl).toString()],
  url: new URL('/products/pt-transformx/', siteUrl).toString(),
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Workflow compatibility', value: 'ProTaper Gold and ProTaper-style shaping' },
    { '@type': 'PropertyValue', name: 'Tip design', value: 'Avatar Tip' },
    { '@type': 'PropertyValue', name: 'Metallurgy', value: 'Transform Technology' },
  ],
};

const ctas = [
  { label: 'Open PT workflow PDF', href: '/downloads/PT-Technique-Work-Flow.pdf', variant: 'primary' as const },
  { label: 'Contact EndoTech', href: '/about/contact/', variant: 'secondary' as const },
];
---

<ProductLayout
  title="PT TransformX Files | Rotary Endodontic Files for ProTaper-Style Workflows"
  description="PT TransformX rotary shaping files preserve a familiar ProTaper-style sequence while improving canal-centred control with Avatar Tip and Transform Technology."
  image={ptProduct.src}
  schema={ptSchema}
  accent="teal"
>
  <ProductHero
    eyebrow="PT TransformX"
    title="PT TransformX Files"
    subtitle="Keep the familiar PT shaping philosophy."
    description="PT TransformX is designed for clinicians already using ProTaper-style coronal, shaping, and finishing sequences, preserving familiar progression while improving control through Avatar Tip and Transform Technology."
    ctas={ctas}
    accent="teal"
    imageSrc={ptProduct.src}
    imageAlt="PT TransformX rotary file system for ProTaper-style shaping workflows"
    visualLabel="PT TransformX"
  />

  <ProductOrderSelector
    title="Order the PT sequence online"
    description={orderPanelDescription}
    coverageLabel={getOrderCoverageLabel(ptOrderItems)}
    packFormat="6 files per pack"
    items={ptOrderItems}
    shopifyStoreDomain={shopifyStoreDomain}
    selectionNote={ptSelectionNote}
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto grid max-w-7xl gap-4 px-6 py-14 sm:gap-6 sm:py-16 lg:grid-cols-2 lg:py-20">
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-50/70 p-5 sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Problem</p>
        <p class="mt-4 text-base leading-7 text-slate-600 sm:mt-5 sm:leading-8">
          Moving to a different progressive shaping system can disrupt familiar coronal-to-apical sequence logic, making it harder to keep the same level of confidence through increasingly demanding canal anatomy.
        </p>
      </article>
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-950 p-5 text-white sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">TransformX Solution</p>
        <p class="mt-4 text-base leading-7 text-slate-300 sm:mt-5 sm:leading-8">
          PT TransformX preserves a familiar progressive shaping workflow while introducing Avatar Tip guidance and Transform Technology to improve control, safety, and adaptability across the full sequence.
        </p>
      </article>
    </div>
  </section>

  <FeatureGrid
    eyebrow="Key Features"
    title="Built around the PT shaping sequence"
    intro="PT TransformX keeps the workflow clinically legible from coronal shaping through to apical finishing, while linking file design back to the anatomy challenges that matter most."
    items={keyFeatureItems}
    accent="teal"
  />

  <FeatureGrid
    eyebrow="Clinical Benefits"
    title="Why the PT workflow translates cleanly"
    intro="Each feature is tied to a practical clinical advantage: maintain sequence familiarity, improve canal-centred behaviour, and preserve clear apical decision-making."
    items={clinicalBenefitItems}
    accent="teal"
  />

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Sequence Overview</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">PT sequence logic and file coverage</h2>
      <div class="mt-8 grid gap-4 sm:mt-10 sm:gap-5 lg:grid-cols-3">
        <article class="rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:rounded-[1.75rem] sm:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Step 1</p>
          <h3 class="mt-3 text-2xl font-bold tracking-tight text-slate-900">SX</h3>
          <p class="mt-4 text-base leading-7 text-slate-600 sm:leading-8">
            Coronal shaping at 19 mm to establish straight-line access and reduce coronal resistance before the shaping files progress deeper.
          </p>
        </article>
        <article class="rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:rounded-[1.75rem] sm:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Step 2</p>
          <h3 class="mt-3 text-2xl font-bold tracking-tight text-slate-900">S1 and S2</h3>
          <p class="mt-4 text-base leading-7 text-slate-600 sm:leading-8">
            Middle-third shaping in 21 mm, 25 mm, and 31 mm lengths for clinicians who want the familiar PT progression to working length.
          </p>
        </article>
        <article class="rounded-[1.35rem] border border-slate-200 bg-slate-950 p-5 text-white sm:rounded-[1.75rem] sm:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Step 3</p>
          <h3 class="mt-3 text-2xl font-bold tracking-tight text-white">F1 to F5</h3>
          <p class="mt-4 text-base leading-7 text-slate-300 sm:leading-8">
            Apical finishing files allow the preparation to stay matched to canal anatomy, with F4 and F5 extending the 25 mm range for larger finishing requirements.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="downloads" class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Downloads</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Open the technical files next</h2>
      <div class="mt-8 grid gap-4 sm:mt-10">
        <article class="flex flex-col gap-4 rounded-[1.35rem] border border-slate-200 bg-slate-50/60 p-4 sm:rounded-[1.5rem] sm:p-5 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Technique Guide</p>
            <h3 class="mt-2 text-base font-bold text-slate-900 sm:text-lg">PT Technique Workflow</h3>
          </div>
          <a href={workflowPdfSrc} class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800 sm:w-auto">
            Open PDF
          </a>
        </article>
        <article class="flex flex-col gap-4 rounded-[1.35rem] border border-slate-200 bg-slate-50/60 p-4 sm:rounded-[1.5rem] sm:p-5 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Product File</p>
            <h3 class="mt-2 text-base font-bold text-slate-900 sm:text-lg">PT Part Numbers</h3>
          </div>
          <a href={partNumbersPdfSrc} class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800 sm:w-auto">
            Open PDF
          </a>
        </article>
      </div>
    </div>
  </section>
</ProductLayout>
