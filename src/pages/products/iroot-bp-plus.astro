---
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import FeatureGrid from '../../components/product/FeatureGrid.astro';
import ApplicationsGrid from '../../components/product/ApplicationsGrid.astro';
import ComparisonTable from '../../components/product/ComparisonTable.astro';
import PackagingPanel from '../../components/product/PackagingPanel.astro';
import FAQAccordion from '../../components/product/FAQAccordion.astro';
import DistributorCTA from '../../components/product/DistributorCTA.astro';
import { irootBPPlus } from '../../data/iroot';

const clinicalBenefitCards = irootBPPlus.clinicalBenefits.map((benefit) => ({
  title: benefit,
  description: 'Expressed as workflow and handling value rather than unsupported comparative marketing.',
  icon: 'repair' as const,
}));
---

<ProductLayout
  title="iRoot BP Plus | EndoTech Singapore"
  description={irootBPPlus.shortDescription}
  accent="violet"
>
  <ProductHero
    eyebrow="iRoot BP Plus"
    title={irootBPPlus.name}
    subtitle={irootBPPlus.headline}
    description={irootBPPlus.subheadline}
    ctas={irootBPPlus.ctas}
    accent="violet"
    visualLabel={irootBPPlus.visualLabel}
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto grid max-w-7xl gap-6 px-6 py-20 lg:grid-cols-2">
      <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50/70 p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Problem</p>
        <p class="mt-5 text-base leading-8 text-slate-600">{irootBPPlus.clinicalProblem}</p>
      </article>
      <article class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-7 text-white">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">TransformX Solution</p>
        <p class="mt-5 text-base leading-8 text-slate-300">{irootBPPlus.transformxSolution}</p>
      </article>
    </div>
  </section>

  <FeatureGrid
    eyebrow="Key Features"
    title="Repair-oriented bioceramic handling without chairside mixing"
    items={irootBPPlus.featureBullets}
    accent="violet"
  />

  <ApplicationsGrid
    eyebrow="Main Applications"
    title="Designed for repair and vital pulp procedures"
    items={irootBPPlus.applications}
    accent="violet"
  />

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Why Clinicians Choose iRoot BP Plus</p>
          <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Handling and workflow are part of the clinical value</h2>
          <ul class="mt-8 grid gap-4">
            {irootBPPlus.clinicianReasons.map((reason) => (
              <li class="rounded-[1.25rem] border border-slate-200 bg-white px-5 py-4 text-base font-semibold text-slate-900">{reason}</li>
            ))}
          </ul>
        </div>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Product Story</p>
          <p class="mt-5 text-base leading-8 text-slate-600">{irootBPPlus.story}</p>
        </article>
      </div>
    </div>
  </section>

  <ComparisonTable
    title="Why move beyond conventional mixed repair materials?"
    intro="The focus here is handling logic, washout positioning, and workflow efficiency, not aggressive superiority claims."
    rows={irootBPPlus.comparisonRows}
    irootLabel="iRoot BP Plus"
    conventionalLabel="Conventional mixed repair material"
  />

  <FeatureGrid
    eyebrow="Clinical Benefits"
    title="Repair benefits translated into procedure-level language"
    items={clinicalBenefitCards}
    accent="violet"
  />

  <PackagingPanel items={irootBPPlus.packaging} />
  <FAQAccordion title="iRoot BP Plus FAQs" items={irootBPPlus.faq} />
  <DistributorCTA
    title="Use iRoot BP Plus where repair procedures need controlled handling"
    body={irootBPPlus.regulatoryNote}
    secondaryLabel="View applications"
    secondaryHref="/products/iroot/clinical-applications/"
  />
</ProductLayout>
