---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductHero from '../../../components/product/ProductHero.astro';
import FeatureGrid from '../../../components/product/FeatureGrid.astro';
import EvidenceCards from '../../../components/product/EvidenceCards.astro';
import DownloadsList from '../../../components/product/DownloadsList.astro';
import DistributorCTA from '../../../components/product/DistributorCTA.astro';
import { evidenceCards, evidenceThemes, getProductDownloads, literatureReferences } from '../../../data/iroot';
import { getIrootDownloads } from '../../../utils/downloads';

const downloads = getProductDownloads(getIrootDownloads());
---

<ProductLayout
  title="iRoot Evidence & Downloads | EndoTech Singapore"
  description="Clinical references and downloadable materials for the iRoot bioceramic family."
  accent="slate"
>
  <ProductHero
    eyebrow="Evidence & Downloads"
    title="Clinical references and technical files for the iRoot family"
    subtitle="Access product literature, supporting evidence themes, and technical documents in one place."
    description="Use this page to review brochures, IFUs, SDS files, and selected evidence areas relevant to the iRoot bioceramic family."
    accent="slate"
    ctas={[
      { label: 'Open iRoot family page', href: '/products/iroot/' },
      { label: 'Review applications', href: '/products/iroot/clinical-applications/', variant: 'secondary' },
    ]}
    visualLabel="Technical Reference Hub"
  />

  <DownloadsList
    title="Downloads"
    intro="Access brochures, IFUs, SDS files, evidence summaries, and supporting product resources for the iRoot bioceramic family."
    items={downloads}
  />

  <FeatureGrid
    eyebrow="Key Evidence Themes"
    title="Key evidence areas"
    intro="These evidence areas support the material characteristics and clinical uses associated with the iRoot bioceramic family."
    items={evidenceThemes}
    accent="slate"
  />

  <EvidenceCards
    title="Evidence summaries"
    intro="These summaries highlight the main evidence areas associated with bioceramic sealer and repair materials."
    items={evidenceCards}
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Literature List</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Selected references</h2>
      <div class="mt-10 grid gap-4">
        {literatureReferences.map((reference) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-6">
            <p class="text-base leading-8 text-slate-900">{reference.citation}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">{reference.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <DistributorCTA
    title="Review the evidence alongside the product information"
    body="Use this page to access technical documents and supporting literature relevant to material chemistry, handling, dimensional stability, and clinical use."
    secondaryLabel="View iRoot SP"
    secondaryHref="/products/iroot-sp/"
  />
</ProductLayout>
