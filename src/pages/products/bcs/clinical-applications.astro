---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductHero from '../../../components/product/ProductHero.astro';
import ApplicationsGrid from '../../../components/product/ApplicationsGrid.astro';
import ClinicalWorkflowStrip from '../../../components/product/ClinicalWorkflowStrip.astro';
import DistributorCTA from '../../../components/product/DistributorCTA.astro';
import { workflowSteps } from '../../../data/bcs';

const applications = [
  {
    title: 'Root canal sealing',
    body: 'Use BCS BioCeramic Sealer where the final objective is a stable, moisture-assisted canal seal within a controlled obturation workflow.',
  },
  {
    title: 'Perforation repair',
    body: 'Use BCS BioCeramic Putty when the procedure requires a premixed repair material with practical placement control.',
  },
  {
    title: 'Retrograde filling',
    body: 'Present BCS BioCeramic Putty as a repair-oriented bioceramic option for root-end procedures where handling and dimensional stability matter.',
  },
  {
    title: 'Apexification',
    body: 'Position BCS BioCeramic Putty within biologically aligned apexification cases that benefit from a premixed calcium silicate material.',
  },
  {
    title: 'Pulp capping',
    body: 'Use BCS BioCeramic Putty when vital pulp procedures call for a bioceramic material positioned around biocompatibility and workflow consistency.',
  },
  {
    title: 'Resorption repair',
    body: 'Frame BCS BioCeramic Putty as part of a repair protocol where access, cleaning, and controlled placement all contribute to the final outcome.',
  },
];
---

<ProductLayout
  title="BCS Clinical Applications | EndoTech Singapore"
  description="Clinical use-cases for BCS BioCeramic Sealer and BCS BioCeramic Putty across obturation and root repair workflows."
  accent="slate"
>
  <ProductHero
    eyebrow="Clinical Applications"
    title="Use-case guidance across obturation and root repair"
    subtitle="The BCS family is strongest when each material is matched to the correct clinical task and integrated into a clean, controlled workflow."
    description="These application notes are written to support clinical understanding, not to replace the IFU. Final material selection should always follow the intended use, case requirements, and manufacturer instructions."
    accent="slate"
    ctas={[
      { label: 'View BCS BioCeramic Sealer', href: '/products/bcs-bioceramic-sealer/' },
      { label: 'View BCS BioCeramic Putty', href: '/products/bcs-bioceramic-putty/', variant: 'secondary' },
      { label: 'Open downloads', href: '/products/bcs/evidence/', variant: 'ghost' },
    ]}
    visualLabel="Procedure Map"
  />

  <ApplicationsGrid
    eyebrow="Applications"
    title="Core procedural use-cases"
    intro="The two-product family is deliberately compact: one material for canal sealing and one for repair-oriented procedures."
    items={applications.map((item) => item.title)}
    accent="slate"
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid gap-5 lg:grid-cols-2">
        {applications.map((item) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50/70 p-7">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">{item.title}</h2>
            <p class="mt-4 text-base leading-8 text-slate-600">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ClinicalWorkflowStrip
    title="Keep applications inside the full clinical sequence"
    intro="Material performance is connected to earlier steps. Assessment, access, glidepath creation, shaping, and three-dimensional cleaning all influence whether the final sealing or repair step is clinically controlled."
    steps={workflowSteps}
  />

  <DistributorCTA
    title="Use the applications page as a routing layer, not a claim dump"
    body="This page works best when it helps clinicians self-select the right product, then move to the relevant product page, evidence file, or IFU for deeper detail."
    secondaryLabel="View evidence"
    secondaryHref="/products/bcs/evidence/"
  />
</ProductLayout>
