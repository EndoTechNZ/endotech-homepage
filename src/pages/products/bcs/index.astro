---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import PremiumProductNarrative from '../../../components/product/PremiumProductNarrative.astro';
import { bcsFamilyPage, familyCards, getProductDownloads } from '../../../data/bcs';
import { getBcsDownloads } from '../../../utils/downloads';
import { withBasePath } from '../../../utils/paths';

const downloads = getProductDownloads(getBcsDownloads());
const familyImages = [
  {
    src: withBasePath('/downloads/metallic-packshots/BCS-Sealer-metallic-silver.png'),
    alt: 'BCS BioCeramic Sealer',
    href: '/products/bcs-bioceramic-sealer/',
    tone: 'teal' as const,
  },
  {
    src: withBasePath('/downloads/metallic-packshots/BCS-Putty-metallic-gold.png'),
    alt: 'BCS BioCeramic Putty',
    href: '/products/bcs-bioceramic-putty/',
    tone: 'violet' as const,
  },
];

const sequenceItems = [
  {
    step: 'Seal',
    role: 'BCS BioCeramic Sealer',
    detail:
      'Supports canal sealing after shaping and irrigation with a premixed bioceramic format.',
  },
  {
    step: 'Repair',
    role: 'BCS BioCeramic Putty',
    detail:
      'Extends the same material platform into repair procedures where handling and placement control matter.',
  },
  {
    step: 'Restore',
    role: 'Workflow completion',
    detail:
      'Keeps the final material decision connected to the system-first EndoTech treatment sequence.',
  },
];

const benefitItems = familyCards.map((card) => ({
  title: card.name,
  description: card.summary,
}));

const downloadItems = downloads.slice(0, 4).map((download) => ({
  label: download.type,
  title: download.label,
  href: withBasePath(download.href),
}));
---

<ProductLayout
  title="BCS BioCeramic Materials | Endodontic Bioceramic Sealer and Putty"
  description="BCS BioCeramic Materials brings together a premixed endodontic bioceramic sealer and bioceramic putty for canal sealing, root repair, and simplified clinical workflows."
  accent="teal"
>
  <PremiumProductNarrative
    eyebrow="BCS BioCeramic Materials"
    title="Bioceramic sealing and repair within one clinical platform."
    lede="Two products. One clear material logic. Choose BCS BioCeramic Sealer for canal sealing or BCS BioCeramic Putty for repair procedures."
    imageSrc={familyImages[0].src}
    imageAlt={familyImages[0].alt}
    visualTitle="BCS material platform"
    visualText="Premixed bioceramic materials positioned at the seal and repair stage of the EndoTech workflow."
    primaryCta={{ label: 'View sealer', href: withBasePath('/products/bcs-bioceramic-sealer/') }}
    secondaryCta={{ label: 'View putty', href: withBasePath('/products/bcs-bioceramic-putty/') }}
    clinicalProblem="Final sealing and repair decisions are often treated as separate material choices, even though they sit at the point where shaping, cleaning, biological response, and restorative planning converge."
    solution={bcsFamilyPage.positioning}
    engineeringTitle="The BCS platform is defined by premixed handling, moisture-compatible setting, and workflow fit."
    features={bcsFamilyPage.whyBcs.slice(0, 3)}
    sequenceTitle="Choose the material by indication, then move into product-specific detail."
    sequenceItems={sequenceItems}
    benefitsTitle="The family page keeps the clinical decision simple: sealing or repair."
    benefits={benefitItems}
    downloads={downloadItems}
    downloadsTitle="BCS brochures, IFUs, SDS files, and supporting resources."
    workflowActiveStep="seal"
  />
</ProductLayout>
