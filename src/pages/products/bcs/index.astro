---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductHero from '../../../components/product/ProductHero.astro';
import FeatureGrid from '../../../components/product/FeatureGrid.astro';
import DownloadsList from '../../../components/product/DownloadsList.astro';
import DistributorCTA from '../../../components/product/DistributorCTA.astro';
import { bcsFamilyPage, familyCards, getProductDownloads } from '../../../data/bcs';
import { getBcsDownloads } from '../../../utils/downloads';
import { withBasePath } from '../../../utils/paths';

const downloads = getProductDownloads(getBcsDownloads());
const familyImages = [
  {
    src: withBasePath('/downloads/metallic-packshots/BCS-Sealer-metallic-silver.png'),
    alt: 'BCS BioCeramic Sealer',
    href: '/products/bcs-bioceramic-sealer/',
    tone: 'teal' as const,
  },
  {
    src: withBasePath('/downloads/metallic-packshots/BCS-Putty-metallic-gold.png'),
    alt: 'BCS BioCeramic Putty',
    href: '/products/bcs-bioceramic-putty/',
    tone: 'violet' as const,
  },
];
---

<ProductLayout
  title="BCS BioCeramic Materials | EndoTech Singapore"
  description="Premixed bioceramic materials for sealing, repair, and simplified endodontic workflows."
  accent="teal"
>
  <ProductHero
    eyebrow="BCS BioCeramic Materials"
    title="Bioceramic sealing and repair"
    subtitle="Premixed bioceramic materials for modern endodontics."
    description="Two products. One clear platform. Choose BCS BioCeramic Sealer for canal sealing or BCS BioCeramic Putty for root repair."
    accent="teal"
    ctas={bcsFamilyPage.ctas}
    imageStack={familyImages}
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Products</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Choose the material by indication</h2>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
        Keep the first decision simple: sealing or repair. Each page then focuses on one product and one message.
      </p>
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {familyCards.map((card) => (
          <a href={withBasePath(card.slug)} class="rounded-[1.75rem] border border-slate-200 bg-slate-50/70 p-7 transition-all hover:-translate-y-0.5 hover:border-slate-300 hover:bg-white">
            <p class={`text-xs font-semibold uppercase tracking-[0.22em] ${card.accent === 'violet' ? 'text-violet-700' : 'text-teal-700'}`}>
              {card.accent === 'violet' ? 'Root Repair' : 'Canal Sealing'}
            </p>
            <h3 class="mt-4 text-2xl font-bold text-slate-900">{card.name}</h3>
            <p class="mt-4 text-base leading-8 text-slate-600">{card.summary}</p>
            <span class="mt-6 inline-flex text-sm font-semibold text-slate-900">Open page</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FeatureGrid
    eyebrow="Core Material Logic"
    title="What defines the BCS platform"
    intro="These are the material characteristics that run across the family and explain why the range feels clinically consistent."
    items={bcsFamilyPage.whyBcs}
    accent="teal"
  />

  <DownloadsList
    title="Downloads"
    intro="Access brochures, IFUs, SDS files, and supporting product resources for the BCS bioceramic family."
    items={downloads}
  />

  <DistributorCTA
    title="Start with the indication"
    body="Select the material by clinical use, then access the product page, evidence, and instructions for use as needed."
  />
</ProductLayout>
