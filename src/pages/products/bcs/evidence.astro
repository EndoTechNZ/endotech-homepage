---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductHero from '../../../components/product/ProductHero.astro';
import FeatureGrid from '../../../components/product/FeatureGrid.astro';
import EvidenceCards from '../../../components/product/EvidenceCards.astro';
import DownloadsList from '../../../components/product/DownloadsList.astro';
import DistributorCTA from '../../../components/product/DistributorCTA.astro';
import { evidenceCards, evidenceThemes, getProductDownloads, literatureReferences } from '../../../data/bcs';
import { getBcsDownloads } from '../../../utils/downloads';
import { withBasePath } from '../../../utils/paths';

const downloads = getProductDownloads(getBcsDownloads());
---

<ProductLayout
  title="BCS Evidence & Downloads | EndoTech Singapore"
  description="Clinical references and downloadable materials for the BCS bioceramic family."
  accent="slate"
>
  <ProductHero
    eyebrow="Evidence & Downloads"
    title="Clinical references and technical files for the BCS family"
    subtitle="Access product literature, supporting evidence themes, and technical documents in one place."
    description="Use this page to review brochures, IFUs, SDS files, and selected evidence areas relevant to the BCS bioceramic family."
    accent="slate"
    ctas={[
      { label: 'Open BCS family page', href: '/products/bcs/' },
      { label: 'Review applications', href: '/products/bcs/clinical-applications/', variant: 'secondary' },
    ]}
    visualLabel="Technical Reference Hub"
  />

  <DownloadsList
    title="Downloads"
    intro="Access brochures, IFUs, SDS files, evidence summaries, and supporting product resources for the BCS bioceramic family."
    items={downloads}
  />

  <section class="border-b border-slate-200/80 bg-slate-50/70">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Material Consistency</p>
        <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Evaluate sealer consistency before clinical use</h2>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          Handling consistency matters at the point of obturation. This video is presented as an example of visible separation observed in a competitor bioceramic sealer sample before use.
        </p>
      </div>

      <div class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(360px,1fr)] lg:items-start">
        <div class="space-y-4">
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.12)]">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">What To Look For</p>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-slate-900">Material consistency should be evaluated before obturation begins</h3>
            <p class="mt-5 text-base leading-8 text-slate-600">
              The purpose of the video is not to overload the page with media. It is there to support one clear clinical point: material condition should be assessed before delivery into the canal.
            </p>
            <ul class="mt-6 space-y-3 text-sm leading-7 text-slate-600">
              <li>Visible separation can affect confidence in syringe delivery and placement control.</li>
              <li>Uniform handling matters when a sealer is expected to perform as a premixed material.</li>
              <li>A simple on-demand video review keeps the page clean while still supporting professional evaluation.</li>
            </ul>
          </article>

          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.12)]">
            <div class="overflow-hidden rounded-[1.5rem] bg-black">
              <div class="aspect-[9/16] bg-black">
                <video
                  class="h-full w-full object-contain bg-black"
                  controls
                  preload="metadata"
                  playsinline
                >
                  <source src={withBasePath('/videos/bcs/material-consistency-inline.mp4')} type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
              </div>
            </div>
            <p class="mt-4 text-sm leading-7 text-slate-500">
              Additional on-page example showing visible separation in a competitor bioceramic sealer sample before use.
            </p>
          </article>

          <article class="flex min-h-[18rem] w-full flex-col justify-between rounded-[1.5rem] border border-slate-200 bg-slate-950 p-8 text-white shadow-[0_24px_60px_-42px_rgba(15,23,42,0.45)]">
            <p class="text-sm leading-7 text-slate-300">
              Video shown for professional evaluation purposes. Clinicians should assess material condition, handling, and manufacturer instructions before use.
            </p>
            <p class="mt-5 text-center text-sm font-semibold tracking-[0.04em] text-cyan-200">
              Click for video training below
            </p>
            <button
              type="button"
              class="material-video-trigger mt-5 inline-flex items-center justify-center rounded-full border border-white/12 bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition-all duration-200 hover:-translate-y-0.5 hover:bg-cyan-200 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-cyan-200/70"
              data-video-modal-open
            >
              Why Material Consistency is fundamental
            </button>
          </article>
        </div>

        <div class="space-y-4">
          <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6">
            <h3 class="text-xl font-bold text-slate-900">Why this matters clinically</h3>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
              <li>Delivery consistency affects placement control.</li>
              <li>Material uniformity matters before obturation begins.</li>
              <li>Handling variability can complicate a simplified workflow.</li>
            </ul>
          </article>

          <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6">
            <h3 class="text-xl font-bold text-slate-900">How BCS BioCeramic Sealer is presented</h3>
            <ol class="mt-4 space-y-3 pl-5 text-sm leading-7 text-slate-600 list-decimal">
              <li>Premixed syringe delivery</li>
              <li>No chairside mixing</li>
              <li>Designed for predictable handling and moisture-assisted setting</li>
              <li>WITHOUT IN-TUBE SPLITING into solid and liquid forms (see video)</li>
            </ol>
          </article>

        </div>
      </div>
    </div>
  </section>

  <dialog class="material-video-modal" data-video-modal>
    <div class="material-video-panel">
      <button
        type="button"
        class="material-video-close"
        aria-label="Close video"
        data-video-modal-close
      >
        Close
      </button>
      <div class="overflow-hidden rounded-[1.5rem] bg-black">
        <div class="aspect-video max-h-[78vh] bg-black">
          <video
            class="h-full w-full object-contain bg-black"
            controls
            preload="metadata"
            playsinline
            data-material-video
          >
            <source src={withBasePath('/videos/bcs/material-consistency-fundamental.mp4')} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>
    </div>
  </dialog>

  <FeatureGrid
    eyebrow="Key Evidence Themes"
    title="Key evidence areas"
    intro="These evidence areas support the material characteristics and clinical uses associated with the BCS bioceramic family."
    items={evidenceThemes}
    accent="slate"
  />

  <EvidenceCards
    title="Evidence summaries"
    intro="These summaries highlight the main evidence areas associated with bioceramic sealer and repair materials."
    items={evidenceCards}
  />

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Literature List</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">Selected references</h2>
      <div class="mt-10 grid gap-4">
        {literatureReferences.map((reference) => (
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-6">
            <p class="text-base leading-8 text-slate-900">{reference.citation}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">{reference.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <DistributorCTA
    title="Review the evidence alongside the product information"
    body="Use this page to access technical documents and supporting literature relevant to material chemistry, handling, dimensional stability, and clinical use."
    secondaryLabel="View BCS BioCeramic Sealer"
    secondaryHref="/products/bcs-bioceramic-sealer/"
  />
</ProductLayout>

<style>
  .material-video-modal {
    width: min(64rem, calc(100vw - 2rem));
    max-width: 64rem;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .material-video-modal::backdrop {
    background: rgba(2, 6, 23, 0.72);
    backdrop-filter: blur(8px);
  }

  .material-video-panel {
    position: relative;
    border-radius: 1.75rem;
    border: 1px solid rgba(226, 232, 240, 0.7);
    background: rgba(255, 255, 255, 0.96);
    padding: 1rem;
    box-shadow: 0 28px 80px -32px rgba(15, 23, 42, 0.5);
  }

  .material-video-close {
    margin: 0 0 0.75rem auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: white;
    padding: 0.55rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(15 23 42);
    transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease;
  }

  .material-video-close:hover {
    transform: translateY(-1px);
    background: rgb(248 250 252);
    border-color: rgba(148, 163, 184, 0.55);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.querySelector<HTMLDialogElement>('[data-video-modal]');
    const openButton = document.querySelector<HTMLButtonElement>('[data-video-modal-open]');
    const closeButton = document.querySelector<HTMLButtonElement>('[data-video-modal-close]');
    const video = document.querySelector<HTMLVideoElement>('[data-material-video]');
    let lastTrigger: HTMLElement | null = null;

    if (!modal || !openButton || !closeButton || !video) return;

    const closeModal = () => {
      video.pause();
      video.currentTime = 0;
      if (modal.open) {
        modal.close();
      }
      lastTrigger?.focus();
    };

    openButton.addEventListener('click', () => {
      lastTrigger = openButton;
      modal.showModal();
      video.currentTime = 0;
      void video.play().catch(() => {
        // Playback may require an additional user action on some browsers.
      });
    });

    closeButton.addEventListener('click', closeModal);

    modal.addEventListener('click', (event) => {
      const bounds = modal.getBoundingClientRect();
      const clickedOutside =
        event.clientX < bounds.left ||
        event.clientX > bounds.right ||
        event.clientY < bounds.top ||
        event.clientY > bounds.bottom;

      if (clickedOutside) {
        closeModal();
      }
    });

    video.addEventListener('ended', closeModal);

    modal.addEventListener('close', () => {
      video.pause();
      video.currentTime = 0;
    });
  });
</script>
