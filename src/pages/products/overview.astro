---
import ProductLayout from '../../layouts/ProductLayout.astro';
import WorkflowStrip from '../../components/navigation/WorkflowStrip.astro';
import etProduct from '../../assets/et-transformx.png';
import ptProduct from '../../assets/pt-transformx.png';

const base = import.meta.env.BASE_URL;

const shapingSystems = [
  {
    eyebrow: 'ET TransformX',
    title: 'ET-style shaping for familiar .04/.06 sequence logic.',
    body:
      'Designed for clinicians who want to preserve established ET-style preparation behaviour while improving apical control through Avatar Tip and Transform Technology.',
    href: `${base}products/et-transformx/`,
    image: etProduct.src,
    alt: 'ET TransformX rotary files',
  },
  {
    eyebrow: 'PT TransformX',
    title: 'PT-style shaping for progressive crown-down preparation.',
    body:
      'Built for clinicians using ProTaper-style sequence architecture who want a more controlled shaping response through demanding anatomy.',
    href: `${base}products/pt-transformx/`,
    image: ptProduct.src,
    alt: 'PT TransformX rotary file system',
  },
];

const compareColumns = [
  {
    label: 'ET TransformX',
    rows: [
      'ET, EdgeX7, or .04/.06 style sequences.',
      'ET-style logic and familiar .04/.06 thinking.',
      'Maintain centring while advancing efficiently toward working length.',
      'ET workflow PDF',
    ],
    links: {
      primary: `${base}products/et-transformx/`,
      next: `${base}downloads/ET-Technique-Work-Flow.pdf`,
    },
  },
  {
    label: 'PT TransformX',
    rows: [
      'ProTaper-style shaping with minimal workflow disruption.',
      'PT-style sequence rhythm with a lower switching curve.',
      'Preserve a PT-style treatment rhythm while improving control.',
      'PT workflow PDF',
    ],
    links: {
      primary: `${base}products/pt-transformx/`,
      next: `${base}downloads/PT-Technique-Work-Flow.pdf`,
    },
  },
  {
    label: 'BCS BioCeramics',
    rows: [
      'Practices wanting one bioceramic family for final sealing and repair.',
      'Fits directly into the final sealing phase after shaping.',
      'Deliver premixed materials for predictable sealing without mixing variability.',
      'Family details',
    ],
    links: {
      primary: `${base}products/bcs/`,
      next: `${base}products/bcs/`,
    },
  },
];

const compareRows = ['Best fit', 'Feels familiar', 'Primary promise', 'Open next'];

const compareNotes = [
  {
    title: 'For the specialist',
    text: 'Move straight to workflow and apical-control rationale.',
  },
  {
    title: 'For the GP',
    text: 'Match the system to the sequence logic you already run.',
  },
  {
    title: 'For the buyer or distributor',
    text: 'Open the PDFs first, then move into pricing and availability.',
  },
];
---

<ProductLayout
  title="Shape Overview | EndoTech NZ"
  description="Compare EndoTech shaping systems and move into the ET TransformX or PT TransformX pathway that best matches your established clinical sequence."
  image={ptProduct.src}
  accent="teal"
>
  <main class="shape-overview-page">
    <section class="shape-overview-hero" aria-labelledby="shape-overview-title">
      <div>
        <p class="shape-overview-eyebrow">Shape</p>
        <h1 id="shape-overview-title">Choose the shaping path that fits the sequence you already trust.</h1>
        <p class="shape-overview-lede">
          EndoTech presents shaping as a controlled stage inside the wider clinical workflow. Select the file system that matches your established preparation logic, then move into the relevant clinical detail.
        </p>
        <div class="shape-overview-actions">
          <a href={`${base}products/et-transformx/`}>View ET TransformX</a>
          <a href={`${base}products/pt-transformx/`}>View PT TransformX</a>
        </div>
      </div>
    </section>

    <WorkflowStrip activeStep="shape" />

    <section class="shape-overview-grid" aria-label="Shaping system options">
      {shapingSystems.map((system) => (
        <article>
          <div class="shape-overview-copy">
            <p>{system.eyebrow}</p>
            <h2>{system.title}</h2>
            <span>{system.body}</span>
            <a href={system.href}>Open shaping page</a>
          </div>
          <figure>
            <img src={system.image} alt={system.alt} />
          </figure>
        </article>
      ))}
    </section>

    <section class="compare-section" aria-labelledby="compare-title">
      <div class="compare-heading">
        <div>
          <p class="shape-overview-eyebrow">Compare Systems</p>
          <h2 id="compare-title">Answer the first questions quickly.</h2>
          <p class="compare-lede">
            A concise clinical screen for sequence fit, core promise, and the next document to open.
          </p>
        </div>
        <a class="compare-cta" href={`${base}products/overview/`}>Full product overview</a>
      </div>

      <div class="compare-table-shell">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Question</th>
              {compareColumns.map((column) => (
                <th>{column.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {compareRows.map((rowLabel, rowIndex) => (
              <tr>
                <th>{rowLabel}</th>
                {compareColumns.map((column) => (
                  <td>
                    {rowIndex === compareRows.length - 1 ? (
                      <a href={column.links.next}>{column.rows[rowIndex]}</a>
                    ) : rowIndex === 0 ? (
                      <a class="compare-inline-link" href={column.links.primary}>{column.rows[rowIndex]}</a>
                    ) : (
                      column.rows[rowIndex]
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="compare-notes">
        {compareNotes.map((note) => (
          <article>
            <h3>{note.title}</h3>
            <p>{note.text}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</ProductLayout>

<style>
  .shape-overview-page {
    background: #f7f9fb;
    color: #0b1424;
  }

  .shape-overview-hero,
  .shape-overview-grid,
  .compare-section {
    padding-left: 56px;
    padding-right: 56px;
  }

  .shape-overview-hero {
    max-width: 1260px;
    margin: 0 auto;
    padding-top: 72px;
    padding-bottom: 34px;
  }

  .shape-overview-eyebrow,
  .shape-overview-copy p {
    margin: 0 0 18px;
    color: #876a2b;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .shape-overview-hero h1,
  .shape-overview-copy h2 {
    margin: 0;
    color: #0b1424;
    letter-spacing: 0;
  }

  .shape-overview-hero h1 {
    max-width: 980px;
    font-size: 4.2rem;
    font-weight: 700;
    line-height: 0.98;
  }

  .shape-overview-lede,
  .shape-overview-copy span {
    display: block;
    max-width: 820px;
    color: #4b5c70;
    font-size: 1.08rem;
    line-height: 1.74;
  }

  .shape-overview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .shape-overview-actions a,
  .shape-overview-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border: 1px solid #c8d2dc;
    border-radius: 4px;
    padding: 0 18px;
    color: #0b1424;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
  }

  .shape-overview-grid {
    display: grid;
    gap: 22px;
    max-width: 1260px;
    margin: 0 auto;
    padding-top: 98px;
    padding-bottom: 112px;
  }

  .shape-overview-grid article {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
    gap: 36px;
    align-items: center;
    border: 1px solid #dbe3ea;
    background: #ffffff;
    padding: 34px;
  }

  .shape-overview-copy h2 {
    max-width: 16ch;
    font-size: 2.45rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .shape-overview-copy span {
    margin-top: 18px;
    max-width: 62ch;
    font-size: 1rem;
    line-height: 1.72;
  }

  .shape-overview-copy a {
    margin-top: 24px;
    width: fit-content;
  }

  .shape-overview-grid figure {
    margin: 0;
    border-top: 1px solid #dbe3ea;
    border-bottom: 1px solid #dbe3ea;
    padding: 24px 0;
  }

  .shape-overview-grid img {
    width: 100%;
    max-height: 260px;
    object-fit: contain;
  }

  .compare-section {
    max-width: 1260px;
    margin: 0 auto;
    padding-top: 0;
    padding-bottom: 112px;
  }

  .compare-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    padding-top: 8px;
  }

  .compare-heading h2,
  .compare-notes h3 {
    margin: 0;
    color: #0b1424;
    letter-spacing: 0;
  }

  .compare-heading h2 {
    max-width: 11ch;
    font-size: 3.1rem;
    font-weight: 700;
    line-height: 1.02;
  }

  .compare-lede,
  .compare-notes p,
  .compare-table td {
    color: #4b5c70;
    font-size: 1rem;
    line-height: 1.72;
  }

  .compare-lede {
    max-width: 54ch;
    margin: 20px 0 0;
  }

  .compare-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border: 1px solid #0b1424;
    border-radius: 999px;
    padding: 0 24px;
    background: #0b1424;
    color: #ffffff;
    font-size: 0.94rem;
    font-weight: 800;
    text-decoration: none;
  }

  .compare-table-shell {
    margin-top: 34px;
    overflow: hidden;
    border: 1px solid #dbe3ea;
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 24px 65px -52px rgba(15, 23, 42, 0.28);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
  }

  .compare-table th,
  .compare-table td {
    padding: 22px 26px;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid #e7edf2;
  }

  .compare-table thead th {
    background: #f8fafc;
    color: #0b1424;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .compare-table tbody th {
    width: 15%;
    color: #0b1424;
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.45;
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .compare-table a {
    color: #2d6f92;
    font-weight: 800;
    text-decoration: none;
    transition: color 190ms ease, background-position 240ms ease;
  }

  .compare-table a:hover,
  .compare-table a:focus-visible {
    color: transparent;
    background-image: linear-gradient(90deg, #19b7c5 0%, #57d7d2 48%, #1ca8da 100%);
    background-size: 200% 100%;
    background-position: 100% 50%;
    -webkit-background-clip: text;
    background-clip: text;
  }

  .compare-inline-link {
    color: #4b5c70;
    font-weight: 700;
  }

  .compare-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-top: 24px;
  }

  .compare-notes article {
    border: 1px solid #dbe3ea;
    border-radius: 20px;
    background: #ffffff;
    padding: 22px 24px;
  }

  .compare-notes h3 {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .compare-notes p {
    margin: 14px 0 0;
  }

  @media (max-width: 1120px) {
    .shape-overview-hero,
    .shape-overview-grid,
    .compare-section {
      padding-left: 30px;
      padding-right: 30px;
    }

    .shape-overview-hero h1 {
      font-size: 3.45rem;
    }

    .shape-overview-grid article {
      grid-template-columns: 1fr;
    }

    .compare-heading,
    .compare-notes {
      grid-template-columns: 1fr;
    }

    .compare-table-shell {
      overflow-x: auto;
      border-radius: 16px;
    }

    .compare-table {
      min-width: 860px;
    }
  }

  @media (max-width: 720px) {
    .shape-overview-hero,
    .shape-overview-grid,
    .compare-section {
      padding-left: 18px;
      padding-right: 18px;
    }

    .shape-overview-hero {
      padding-top: 44px;
      padding-bottom: 16px;
    }

    .shape-overview-hero h1 {
      font-size: 2.7rem;
      line-height: 1;
    }

    .shape-overview-grid {
      padding-top: 72px;
      padding-bottom: 84px;
    }

    .shape-overview-grid article {
      gap: 24px;
      padding: 24px 18px;
    }

    .shape-overview-copy h2 {
      font-size: 2rem;
    }

    .compare-section {
      padding-bottom: 84px;
    }

    .compare-heading h2 {
      font-size: 2.28rem;
    }

    .compare-table th,
    .compare-table td {
      padding: 16px 18px;
    }

    .compare-notes article {
      border-radius: 16px;
      padding: 18px;
    }
  }
</style>
