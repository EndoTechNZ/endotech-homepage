---
import ProductLayout from '../../layouts/ProductLayout.astro';
import PremiumProductNarrative from '../../components/product/PremiumProductNarrative.astro';
import acrobatFiles from '../../assets/acrobat-glide-path-files.png';
import { withBasePath } from '../../utils/paths';
import { siteConfig } from '../../config/site';

const siteUrl = Astro.site?.toString() ?? 'https://endotechnz.github.io';
const base = import.meta.env.BASE_URL;
const keyFeatureItems = [
  {
    title: 'Rotary glide path preparation',
    description:
      'Built specifically for rotary glide path progression before shaping, keeping the negotiation stage clinically separate from the main shaping sequence.',
    icon: 'workflow' as const,
  },
  {
    title: 'Transform Metal Technology',
    description:
      'Applies Transform Metal Technology to the glide path stage, supporting a more flexible file response where canal anatomy becomes less forgiving.',
    icon: 'handling' as const,
  },
  {
    title: '.03 progression across 13, 15, and 17',
    description:
      'A clear size sequence gives clinicians a simple rotary glide path progression from initial negotiation through to a more established path.',
    icon: 'stability' as const,
  },
  {
    title: 'Length options for routine and longer canals',
    description:
      'Available in 21 mm, 25 mm, and 29 mm formats so the glide path stage can stay consistent across different case lengths.',
    icon: 'workflow' as const,
  },
  {
    title: 'Dedicated MB2 option',
    description:
      'A 15/.05 file in 17 mm extends the system for MB2 access and other cases where reduced headroom favours a shorter rotary instrument.',
    icon: 'repair' as const,
  },
  {
    title: 'Designed to lead into shaping',
    description:
      'Positions the clinician for a smoother transition into the shaping sequence once reproducible working-length access has been established.',
    icon: 'handling' as const,
  },
];

const clinicalBenefitItems = [
  {
    title: 'Create a reproducible path before shaping',
    description:
      'Addresses the clinical problem of entering the shaping stage too early by establishing a more controlled glide path to working length first.',
    icon: 'workflow' as const,
  },
  {
    title: 'Improve control in narrow and curved anatomy',
    description:
      'Links file flexibility directly to the clinical need to progress safely where canal curvature and reduced diameter increase procedural risk.',
    icon: 'handling' as const,
  },
  {
    title: 'Preserve anatomy through the negotiation stage',
    description:
      'Supports a more anatomy-respecting preparation pathway before larger shaping files are introduced into the canal.',
    icon: 'stability' as const,
  },
  {
    title: 'Keep the workflow clinically readable',
    description:
      'Presents glide path creation as a deliberate, structured stage rather than an improvised step between access and shaping.',
    icon: 'workflow' as const,
  },
  {
    title: 'Improve access in restricted MB2 cases',
    description:
      'The shorter 17 mm MB2 option helps when coronal access and visibility make a conventional file length less practical.',
    icon: 'repair' as const,
  },
  {
    title: 'Transition more cleanly into ET technique',
    description:
      'The existing ET workflow already starts with Acrobat 13/.03 at 300 RPM and 2.0-2.5 Ncm, so the page can connect directly to the documented sequence.',
    icon: 'stability' as const,
  },
];

const acrobatClinicalBlueprintSrc = withBasePath('/downloads/Acrobat_Clinical_Blueprint.pdf');
const acrobatOrderHref = `${base}order/#acrobat-order`;

const standardRange = [
  {
    size: '13/.03',
    items: [
      { length: '21 mm', sku: 'ACGP-130321RF', handle: 'acrobat-glide-path-files-13-03-21mm-6-pack' },
      { length: '25 mm', sku: 'ACGP-130325RF', handle: 'acrobat-glide-path-files-13-03-25mm-6-pack' },
      { length: '29 mm', sku: 'ACGP-130329RF', handle: 'acrobat-glide-path-files-13-03-29mm-6-pack' },
    ],
  },
  {
    size: '15/.03',
    items: [
      { length: '21 mm', sku: 'ACGP-150321RF', handle: 'acrobat-glide-path-files-15-03-21mm-6-pack' },
      { length: '25 mm', sku: 'ACGP-150325RF', handle: 'acrobat-glide-path-files-15-03-25mm-6-pack' },
      { length: '29 mm', sku: 'ACGP-150329RF', handle: 'acrobat-glide-path-files-15-03-29mm-6-pack' },
    ],
  },
  {
    size: '17/.03',
    items: [
      { length: '21 mm', sku: 'ACGP-170321RF', handle: 'acrobat-glide-path-files-17-03-21mm-6-pack' },
      { length: '25 mm', sku: 'ACGP-170325RF', handle: 'acrobat-glide-path-files-17-03-25mm-6-pack' },
      { length: '29 mm', sku: 'ACGP-170329RF', handle: 'acrobat-glide-path-files-17-03-29mm-6-pack' },
    ],
  },
];

const acrobatSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Acrobat Glide Path Files',
  description:
    'Rotary glide path files using Transform Metal Technology to create a controlled path to working length before shaping, with 13/.03, 15/.03, and 17/.03 sizes plus an MB2 option.',
  brand: {
    '@type': 'Brand',
    name: siteConfig.name,
  },
  category: 'Endodontic glide path files',
  image: [new URL(acrobatFiles.src, siteUrl).toString()],
  url: new URL('/products/acrobat-glide-path/', siteUrl).toString(),
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'System type', value: 'Rotary glide path files' },
    { '@type': 'PropertyValue', name: 'Technology', value: 'Transform Metal Technology' },
    { '@type': 'PropertyValue', name: 'Standard sizes', value: '13/.03, 15/.03, 17/.03' },
    { '@type': 'PropertyValue', name: 'Lengths', value: '21 mm, 25 mm, 29 mm' },
    { '@type': 'PropertyValue', name: 'MB2 option', value: '15/.05 17 mm' },
  ],
};

const sequenceItems = [
  {
    step: '13/.03',
    role: 'Initial rotary glide path',
    detail:
      'Begins rotary progression after canal negotiation and helps establish a controlled route toward working length.',
  },
  {
    step: '15/.03',
    role: 'Progressive enlargement',
    detail:
      'Extends the pathway before shaping files are introduced, keeping the glide stage clinically separate.',
  },
  {
    step: '17/.03',
    role: 'Shaping handoff',
    detail:
      'Creates a more reproducible transition into TransformX shaping, with length options across routine and longer canals.',
  },
];

const downloads = [
  { label: 'Clinical Presentation', title: 'Acrobat Clinical Blueprint', href: acrobatClinicalBlueprintSrc },
];
---

<ProductLayout
  title="Acrobat Glide Path Files | Rotary Glide Path Files for Endodontics"
  description="Acrobat Glide Path Files are rotary glide path files for endodontics, using Transform Metal Technology to support controlled progression to working length before shaping."
  image={acrobatFiles.src}
  schema={acrobatSchema}
  accent="teal"
>
  <PremiumProductNarrative
    eyebrow="Acrobat Glide Path"
    title="Controlled rotary access before shaping begins."
    lede="Acrobat Glide Path Files support controlled progression to working length before the shaping sequence, with a simple 13/.03, 15/.03, and 17/.03 range plus a dedicated MB2 option."
    imageSrc={acrobatFiles.src}
    imageAlt="Acrobat Glide Path Files in sizes 13/.03, 15/.03, and 17/.03"
    visualTitle="Acrobat Glide Path"
    visualText="A dedicated glide stage positioned before TransformX shaping."
    primaryCta={{ label: 'Order Acrobat Glide Path', href: acrobatOrderHref }}
    secondaryCta={{ label: 'Motor settings', href: '/technique/motor-settings/' }}
    clinicalProblem="The glide path stage is where clinicians often lose control early. Narrow canals, apical curvature, and restricted access can make it difficult to reach working length reproducibly before shaping begins."
    solution="Acrobat Glide Path Files apply rotary progression and Transform Metal Technology to the negotiation stage, helping clinicians establish a controlled path to working length before introducing their shaping system."
    engineeringTitle="The glide path range is deliberately simple, staged, and clinically readable."
    features={keyFeatureItems.slice(0, 3)}
    sequenceTitle="Acrobat creates the controlled access pathway that shaping depends on."
    sequenceItems={sequenceItems}
    benefitsTitle="The clinical value is control before larger shaping files enter the canal."
    benefits={clinicalBenefitItems.slice(0, 3)}
    downloads={downloads}
    workflowActiveStep="glide"
  >
    <section slot="detail" class="acrobat-range-section" aria-labelledby="acrobat-range-title">
      <div>
        <p class="acrobat-eyebrow">Product Range</p>
        <h2 id="acrobat-range-title">Sizes, lengths, and part numbers.</h2>
        <p>
          The core Acrobat range is built around 13/.03, 15/.03, and 17/.03 rotary glide path files in 21 mm, 25 mm, and 29 mm lengths, with an additional 15/.05 17 mm MB2 file.
        </p>
      </div>

      <div class="acrobat-table-shell">
        <div class="overflow-x-auto">
          <table class="min-w-full border-collapse text-left">
            <thead class="bg-slate-900 text-white">
              <tr>
                <th class="px-5 py-4 text-sm font-semibold uppercase tracking-[0.18em]">File</th>
                <th class="px-5 py-4 text-sm font-semibold uppercase tracking-[0.18em]">21 mm</th>
                <th class="px-5 py-4 text-sm font-semibold uppercase tracking-[0.18em]">25 mm</th>
                <th class="px-5 py-4 text-sm font-semibold uppercase tracking-[0.18em]">29 mm</th>
              </tr>
            </thead>
            <tbody>
              {standardRange.map((row, index) => (
                <tr class={index % 2 === 0 ? 'bg-white' : 'bg-slate-50/80'}>
                  <td class="px-5 py-4 text-base font-semibold text-slate-900">{row.size}</td>
                  <td class="px-5 py-4 text-sm text-slate-600">{row.items[0].sku}</td>
                  <td class="px-5 py-4 text-sm text-slate-600">{row.items[1].sku}</td>
                  <td class="px-5 py-4 text-sm text-slate-600">{row.items[2].sku}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="acrobat-mb2">
        <p class="acrobat-eyebrow">MB2 Option</p>
        <div>
          <h3>15/.05 17 mm</h3>
          <div>
            <p>SKU: ACGP-150517RF</p>
            <p>Shorter file format positioned for MB2 access and other cases where reduced coronal headroom changes the feel of a standard-length glide path instrument.</p>
          </div>
        </div>
      </div>
    </section>

    <section slot="order" class="product-order-cta" aria-labelledby="acrobat-order-cta-title">
      <div>
        <p class="acrobat-eyebrow">Ordering</p>
        <h2 id="acrobat-order-cta-title">Select Acrobat Glide Path files in the central ordering section.</h2>
        <p>
          Configure 13/.03, 15/.03, 17/.03, and MB2 options on the dedicated ordering page, where glide path and shaping files can be combined in one order.
        </p>
      </div>
      <a href={acrobatOrderHref}>Order Acrobat Glide Path</a>
    </section>
  </PremiumProductNarrative>
</ProductLayout>

<style>
  .acrobat-range-section {
    display: grid;
    gap: 34px;
    border-top: 1px solid #dbe3ea;
    background: #ffffff;
    padding: 104px 56px 112px;
  }

  .acrobat-eyebrow {
    margin: 0 0 18px;
    color: #876a2b;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .acrobat-range-section h2 {
    max-width: 1040px;
    margin: 0;
    color: #0b1424;
    font-size: 3.35rem;
    font-weight: 700;
    line-height: 1.08;
  }

  .acrobat-range-section > div > p:not(.acrobat-eyebrow),
  .acrobat-mb2 p {
    max-width: 900px;
    color: #536478;
    line-height: 1.68;
  }

  .acrobat-table-shell {
    overflow: hidden;
    border: 1px solid #c8d2dc;
    background: #ffffff;
  }

  .acrobat-mb2 {
    border-top: 1px solid #c8d2dc;
    border-bottom: 1px solid #c8d2dc;
    padding: 28px 0;
  }

  .acrobat-mb2 > div {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 48px;
  }

  .acrobat-mb2 h3 {
    margin: 0;
    color: #0b1424;
    font-size: 1.4rem;
  }

  .product-order-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 36px;
    align-items: end;
    border-top: 1px solid #dbe3ea;
    background: #f7f9fb;
    padding: 72px 56px;
  }

  .product-order-cta h2 {
    max-width: 920px;
    margin: 0;
    color: #0b1424;
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .product-order-cta p:not(.acrobat-eyebrow) {
    max-width: 760px;
    margin: 18px 0 0;
    color: #536478;
    line-height: 1.68;
  }

  .product-order-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border-radius: 4px;
    background: #0b1424;
    padding: 0 24px;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  @media (max-width: 1120px) {
    .acrobat-range-section {
      padding-left: 30px;
      padding-right: 30px;
    }

    .product-order-cta {
      grid-template-columns: 1fr;
      padding-left: 30px;
      padding-right: 30px;
    }
  }

  @media (max-width: 720px) {
    .acrobat-range-section {
      padding-left: 18px;
      padding-right: 18px;
    }

    .acrobat-range-section h2 {
      font-size: 2.25rem;
    }

    .acrobat-mb2 > div {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .product-order-cta {
      padding: 56px 18px;
    }

    .product-order-cta h2 {
      font-size: 2rem;
    }

    .product-order-cta a {
      width: 100%;
    }
  }
</style>
