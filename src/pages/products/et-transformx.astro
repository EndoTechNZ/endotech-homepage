---
import ProductLayout from '../../layouts/ProductLayout.astro';
import PremiumProductNarrative from '../../components/product/PremiumProductNarrative.astro';
import etProduct from '../../assets/et-transformx.png';
import { withBasePath } from '../../utils/paths';
import { siteConfig } from '../../config/site';

const siteUrl = Astro.site?.toString() ?? 'https://endotechnz.github.io';
const base = import.meta.env.BASE_URL;
const etVideoSrc = withBasePath('/videos/et-transformx-promo_1.mp4');
const workflowPdfSrc = withBasePath('/downloads/ET-Technique-Work-Flow.pdf');
const partNumbersPdfSrc = withBasePath('/downloads/ET-Part-Numbers.pdf');
const etOrderHref = `${base}order/#et-order`;
const etSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'ET TransformX Files',
  description:
    'Rotary shaping files for clinicians who want to preserve established .04/.06-style sequence logic while improving apical control with Avatar Tip and Transform Technology.',
  brand: {
    '@type': 'Brand',
    name: siteConfig.name,
  },
  category: 'Endodontic rotary files',
  image: [new URL(etProduct.src, siteUrl).toString()],
  url: new URL('/products/et-transformx/', siteUrl).toString(),
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Technique change', value: 'No technique change' },
    { '@type': 'PropertyValue', name: 'Tip design', value: 'Avatar Tip' },
    { '@type': 'PropertyValue', name: 'Metallurgy', value: 'Transform Technology' },
  ],
};

const keyFeatureItems = [
  {
    title: 'No technique change',
    description:
      'Built for clinicians already shaping with ET, EdgeX7, Race Evo, and other .04/.06-style sequences, so the transition stays clinically familiar.',
    icon: 'workflow' as const,
  },
  {
    title: 'Avatar Tip follows challenging anatomy',
    description:
      'The apical geometry is designed to support more controlled progression where canal curvature and unpredictability increase procedural risk.',
    icon: 'handling' as const,
  },
  {
    title: 'Transform Technology varies the metallurgy along the file',
    description:
      'Different behaviour along the working length supports flexibility at the tip while preserving cutting efficiency through the mid-root and coronal canal.',
    icon: 'stability' as const,
  },
];

const clinicalBenefitItems = [
  {
    title: 'Maintain established sequence logic',
    description:
      'Reduces the learning burden for clinicians who want a different file system without rebuilding motor habits or file-order thinking.',
    icon: 'workflow' as const,
  },
  {
    title: 'Improve apical control in difficult canals',
    description:
      'Links the file design directly to the clinical challenge of staying centred and progressing with fewer procedural surprises.',
    icon: 'handling' as const,
  },
  {
    title: 'Balance flexibility and cutting behaviour',
    description:
      'Supports canal shaping efficiency without making the apical end feel over-aggressive in more demanding anatomy.',
    icon: 'stability' as const,
  },
];

const sequenceItems = [
  {
    step: '.04',
    role: 'Conservative shaping',
    detail:
      'Maintains familiar ET-style sequence logic while supporting controlled shaping in narrower or more conservative preparations.',
  },
  {
    step: '.06',
    role: 'Standard shaping',
    detail:
      'Supports clinicians who want a familiar taper strategy with improved file behaviour where canal demand increases.',
  },
  {
    step: '21-29',
    role: 'Length selection',
    detail:
      'The current NZ range keeps the ET workflow available across routine and longer canal lengths.',
  },
];

const downloads = [
  { label: 'Technique Guide', title: 'ET Technique Workflow', href: workflowPdfSrc },
  { label: 'Product File', title: 'ET Part Numbers', href: partNumbersPdfSrc },
];
---

<ProductLayout
  title="ET TransformX Files | Rotary Endodontic Files for ET-Style Technique"
  description="ET TransformX rotary endodontic files preserve established .04/.06-style shaping technique while improving apical control with Avatar Tip and Transform Technology."
  image={etProduct.src}
  schema={etSchema}
  accent="teal"
>
  <PremiumProductNarrative
    eyebrow="ET TransformX"
    title="Established technique, engineered for greater control."
    lede="ET TransformX is designed for clinicians already using ET, EdgeX7, Race Evo, and other .04/.06-style systems, preserving familiar sequence architecture while advancing apical control."
    imageSrc={etProduct.src}
    imageAlt="ET TransformX rotary files for established ET-style shaping sequences"
    visualTitle="ET TransformX system"
    visualText="Familiar .04/.06-style shaping logic positioned inside the EndoTech clinical workflow."
    primaryCta={{ label: 'Order ET TransformX', href: etOrderHref }}
    secondaryCta={{ label: 'Technical files', href: '#downloads' }}
    clinicalProblem="Changing to a new rotary system often means relearning sequence logic, accepting less familiar apical behaviour, or sacrificing confidence in challenging anatomy."
    solution="ET TransformX keeps the established ET-style technique intact while combining Avatar Tip guidance and variable metallurgy to improve control where anatomy is least forgiving."
    engineeringTitle="The file behaviour is engineered around familiar technique rather than technique disruption."
    features={keyFeatureItems}
    sequenceTitle="The ET workflow remains readable across taper and length selection."
    sequenceItems={sequenceItems}
    benefitsTitle="Designed to improve apical control without rebuilding clinician habits."
    benefits={clinicalBenefitItems}
    downloads={downloads}
    workflowActiveStep="shape"
  >
    <section slot="detail" class="et-media-section" aria-labelledby="et-media-title">
      <div>
        <p class="et-eyebrow">Technology Overview</p>
        <h2 id="et-media-title">Avatar Tip rationale and Transform Technology in motion.</h2>
      </div>
      <div class="et-video-shell">
        <video
          controls
          playsinline
          preload="metadata"
          class="block aspect-video w-full bg-slate-950"
        >
          <source src={etVideoSrc} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </section>

    <section slot="order" class="product-order-cta" aria-labelledby="et-order-cta-title">
      <div>
        <p class="et-eyebrow">Ordering</p>
        <h2 id="et-order-cta-title">Select ET TransformX sizes in the central ordering section.</h2>
        <p>
          Configure .04 and .06 sequences by size and length on the dedicated ordering page, where ET can be combined with Acrobat and PT in one order.
        </p>
      </div>
      <a href={etOrderHref}>Order ET TransformX</a>
    </section>
  </PremiumProductNarrative>

</ProductLayout>

<style>
  .et-media-section {
    display: grid;
    gap: 44px;
    border-top: 1px solid #dbe3ea;
    background: #ffffff;
    padding: 104px 56px 112px;
  }

  .et-eyebrow {
    margin: 0 0 18px;
    color: #876a2b;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .et-media-section h2 {
    max-width: 1040px;
    margin: 0;
    color: #0b1424;
    font-size: 3.35rem;
    font-weight: 700;
    line-height: 1.08;
  }

  .et-video-shell {
    border-top: 1px solid #c8d2dc;
    border-bottom: 1px solid #c8d2dc;
    padding: 28px 0;
  }

  .et-video-shell video {
    display: block;
    width: 100%;
    max-height: 640px;
    background: #0b1424;
  }

  .product-order-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 36px;
    align-items: end;
    border-top: 1px solid #dbe3ea;
    background: #f7f9fb;
    padding: 72px 56px;
  }

  .product-order-cta h2 {
    max-width: 920px;
    margin: 0;
    color: #0b1424;
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .product-order-cta p:not(.et-eyebrow) {
    max-width: 760px;
    margin: 18px 0 0;
    color: #536478;
    line-height: 1.68;
  }

  .product-order-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border-radius: 4px;
    background: #0b1424;
    padding: 0 24px;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  @media (max-width: 1120px) {
    .et-media-section {
      padding-left: 30px;
      padding-right: 30px;
    }

    .product-order-cta {
      grid-template-columns: 1fr;
      padding-left: 30px;
      padding-right: 30px;
    }
  }

  @media (max-width: 720px) {
    .et-media-section {
      padding-left: 18px;
      padding-right: 18px;
    }

    .et-media-section h2 {
      font-size: 2.25rem;
    }

    .product-order-cta {
      padding: 56px 18px;
    }

    .product-order-cta h2 {
      font-size: 2rem;
    }

    .product-order-cta a {
      width: 100%;
    }
  }
</style>
