---
import { existsSync } from 'node:fs';
import path from 'node:path';
import ProductLayout from '../../layouts/ProductLayout.astro';
import FeatureGrid from '../../components/product/FeatureGrid.astro';
import EvidenceCards from '../../components/product/EvidenceCards.astro';
import ClinicalWorkflowStrip from '../../components/product/ClinicalWorkflowStrip.astro';
import DownloadsList from '../../components/product/DownloadsList.astro';
import FAQAccordion from '../../components/product/FAQAccordion.astro';
import DistributorCTA from '../../components/product/DistributorCTA.astro';
import vortiflowTechnicalRender from '../../assets/vortiflow/vortiflow-technical-cad-render.png';
import vortiflowComparisonChart from '../../assets/vortiflow/vortiflow-irrigation-modality-comparison.png';
import vortiflowVortexFlow from '../../assets/vortiflow/vortiflow-vortex-flow-dynamics.png';
import vortiflowWaterFlowMarketingImage from '../../assets/vortiflow/vortiflow-water-flow-marketing-image.png';
import vortiflowHelicalFigure from '../../assets/vortiflow/vortiflow-helical-channel-figure.png';
import vortiflowVortexFigure from '../../assets/vortiflow/vortiflow-vortex-concept-figure.png';
import vortiflowCadTip1 from '../../assets/vortiflow/vortiflow-cad-tip-render-1.jpg';
import vortiflowCadTip2 from '../../assets/vortiflow/vortiflow-cad-tip-render-2.jpg';
import { siteConfig } from '../../config/site';
import { withBasePath } from '../../utils/paths';

const siteUrl = Astro.site?.toString() ?? 'https://endotechnz.github.io';
const pageTitle = `VortiFlow Irrigation Needle for Controlled Endodontic Irrigation | ${siteConfig.name}`;
const pageDescription =
  'VortiFlow is an irrigation needle concept designed for controlled lateral irrigant flow, fluid exchange, and debris transport after canal shaping.';
const heroHeading = 'VortiFlow Irrigation Needle for Controlled Lateral Flow';
const heroLead = 'Controlled lateral irrigant flow after shaping, built around a helical channel needle concept.';
const evidencePdfHref = '/downloads/VortiFlow-Evidence-Overview.pdf';
const hasEvidencePdf = existsSync(path.join(process.cwd(), 'public', 'downloads', 'VortiFlow-Evidence-Overview.pdf'));

const evidenceDownloads = hasEvidencePdf
  ? [
      {
        label: 'Engineered Endodontic Irrigation Facts Sheet',
        href: evidencePdfHref,
        type: 'Facts Sheet' as const,
        fileName: 'VortiFlow-Evidence-Overview.pdf',
      },
    ]
  : [];

const vortiflowSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'VortiFlow Irrigation Needle',
  description: pageDescription,
  brand: {
    '@type': 'Brand',
    name: siteConfig.name,
  },
  category: 'Endodontic irrigation needle',
  image: [new URL(vortiflowVortexFlow.src, siteUrl).toString()],
  url: new URL('/products/vortiflow-irrigation-needle/', siteUrl).toString(),
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Flow concept', value: 'Helical channel lateral flow' },
    { '@type': 'PropertyValue', name: 'Tip concept', value: 'Closed-end style lateral outlet' },
    { '@type': 'PropertyValue', name: 'Workflow position', value: 'After shaping and before obturation' },
  ],
};

const featureItems = [
  {
    title: 'Helical channel geometry',
    description:
      'The concept is built around helical channels on the needle wall so irrigant delivery is directed laterally rather than relying on a direct apical outlet.',
    icon: 'workflow' as const,
  },
  {
    title: 'Closed-end style tip concept',
    description:
      'The smooth distal form and lateral outlet geometry are intended to support controlled delivery while reducing emphasis on direct apical jetting.',
    icon: 'handling' as const,
  },
  {
    title: 'System placement after shaping',
    description:
      'VortiFlow is positioned as the cleaning step after TransformX shaping, helping the overall EndoTech workflow read as one connected treatment sequence.',
    icon: 'stability' as const,
  },
];

const clinicalBenefitItems = [
  {
    title: 'Support fluid exchange',
    description:
      'The VortiFlow concept is presented to support more controlled irrigant movement within the prepared canal rather than treating the needle as a commodity accessory.',
    icon: 'workflow' as const,
  },
  {
    title: 'Support debris transport',
    description:
      'The lateral-flow concept is intended to help with irrigant replacement and debris transport in shaped canals, especially where geometry influences flow behaviour.',
    icon: 'handling' as const,
  },
  {
    title: 'Keep cleaning inside the workflow story',
    description:
      'It gives the EndoTech system a more explicit shaping-to-cleaning transition before sealing, linking instrumentation and irrigation more clearly.',
    icon: 'stability' as const,
  },
];

const evidenceItems = [
  {
    title: 'Needle design influences irrigation behavior',
    description:
      'Published CFD and experimental work suggests that outlet geometry, venting pattern, and working depth can materially affect irrigant flow behaviour, wall shear, and safety considerations.',
  },
  {
    title: 'Design matters more in constrained canal shapes',
    description:
      'Curved and minimally invasive canal preparations make irrigation more sensitive to anatomy, insertion depth, and directed flow behaviour.',
  },
  {
    title: 'Evidence-led, clinically grounded',
    description:
      'VortiFlow is positioned as an engineered irrigation delivery concept within the EndoTech workflow, not as a substitute for every activation method.',
  },
  {
    title: 'From shaping to cleaning',
    description:
      'The role of VortiFlow in the EndoTech system is to strengthen the transition from canal shaping into active irrigation before obturation.',
  },
];

const faqItems = [
  {
    question: 'Is VortiFlow a replacement for activated irrigation?',
    answer:
      'No. VortiFlow is not presented here as a replacement for every activation method. It is positioned as an engineered needle-based irrigation delivery concept within a broader endodontic cleaning protocol.',
  },
  {
    question: 'How does this differ from a standard side-vented needle?',
    answer:
      'The VortiFlow concept is differentiated by the helical channel and lateral-flow design approach shown in the supplied engineering material, rather than by a conventional straight side-vent alone.',
  },
  {
    question: 'Where does VortiFlow sit in the EndoTech workflow?',
    answer:
      'VortiFlow is intended to sit after shaping and before obturation, linking the prepared canal form created by Acrobat and TransformX to the cleaning phase before BCS or iRoot sealing.',
  },
  {
    question: 'Is VortiFlow intended for minimally invasive shaping approaches?',
    answer:
      'The page positions VortiFlow as relevant to modern shaping approaches where canal anatomy, working depth, and flow behaviour all matter. It does not make a superiority claim for any specific preparation philosophy.',
  },
];

const ctas = [
  { label: 'Contact EndoTech', href: '/about/contact/' },
  { label: 'Review evidence', href: '#evidence', variant: 'secondary' as const },
];

const heroVisualEmailSubject = 'VortiFlow further details';
const heroVisualEmailBody = `Hello ${siteConfig.shortName},

I would like further details about the VortiFlow irrigation concept shown on the product page.

Please send more information about:
- clinical rationale
- product availability
- next steps for enquiry

Thank you.`;
const heroVisualMailtoHref = `mailto:${siteConfig.email}?subject=${encodeURIComponent(heroVisualEmailSubject)}&body=${encodeURIComponent(heroVisualEmailBody)}`;
const factsSheetModalId = 'vortiflow-facts-sheet-modal';
const factsSheetViewerHref = `${withBasePath(evidencePdfHref)}#toolbar=0&navpanes=0&scrollbar=1&view=Fit&zoom=page-fit`;
---

<ProductLayout
  title={pageTitle}
  description={pageDescription}
  image={vortiflowVortexFlow.src}
  schema={vortiflowSchema}
  accent="teal"
>
  <section class="relative overflow-hidden border-b border-slate-200/80 bg-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(191,219,254,0.42),transparent_34%),radial-gradient(circle_at_bottom_center,rgba(219,234,254,0.55),transparent_38%)]"></div>
    <div class="relative mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-24">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,0.86fr)_minmax(0,1.14fr)] lg:items-center lg:gap-8">
        <div class="min-w-0">
          <div class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
            EndoTech Irrigation Concept
          </div>
          <h1 class="mt-6 max-w-4xl text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">{heroHeading}</h1>
          <p class="mt-6 max-w-3xl text-lg font-semibold leading-tight text-slate-800 sm:text-2xl">
            {heroLead}
          </p>
          <p class="mt-6 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
            VortiFlow is positioned as an EndoTech irrigation concept that supports controlled irrigant exchange, debris transport, and a clearer transition from shaping to cleaning.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-6 sm:gap-y-4">
            {ctas.map((cta) => (
              <a
                href={withBasePath(cta.href)}
                class:list={[
                  'inline-flex w-full items-center justify-center rounded-full px-6 py-3.5 text-sm font-semibold transition-all duration-250 ease-out hover:-translate-y-0.5 sm:w-auto',
                  cta.variant === 'secondary'
                    ? 'border border-slate-200 bg-white/85 text-slate-600 hover:border-slate-300 hover:bg-white hover:text-slate-900'
                    : 'bg-slate-900 text-white hover:bg-slate-800',
                ]}
              >
                {cta.label}
              </a>
            ))}
          </div>
        </div>
        <a
          href={heroVisualMailtoHref}
          class="group relative block rounded-[1.9rem] focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-900/20 focus-visible:ring-offset-4 focus-visible:ring-offset-white"
          aria-label="Email EndoTech for further details about VortiFlow"
          data-vortiflow-visual-link
        >
          <div class="pointer-events-none absolute inset-y-[6%] left-[5%] right-[4%] rounded-[2.5rem] bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.88),transparent_28%),radial-gradient(circle_at_bottom_center,rgba(191,219,254,0.32),transparent_38%)] blur-2xl"></div>
          <div class="relative z-10 overflow-hidden rounded-[1.9rem] border border-slate-200/80 bg-white/88 p-3 shadow-[0_34px_90px_-52px_rgba(15,23,42,0.28)] backdrop-blur-sm sm:p-4">
            <div class="pointer-events-none absolute right-5 top-5 z-20 inline-flex translate-y-1 items-center rounded-full border border-slate-200/80 bg-white/92 px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-slate-600 opacity-0 shadow-[0_12px_28px_-18px_rgba(15,23,42,0.35)] transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 group-active:translate-y-0 group-active:opacity-100">
              Click for further details
            </div>
            <div class="grid gap-3 sm:gap-4">
              <div class="overflow-hidden rounded-[1.45rem] border border-slate-200/80 bg-slate-50 px-4 py-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.75)] sm:px-5 sm:py-6">
                <img
                  src={vortiflowTechnicalRender.src}
                  alt="Technical CAD render of the VortiFlow irrigation needle"
                  class="block w-full h-auto"
                />
              </div>
              <div class="overflow-hidden rounded-[1.45rem] border border-slate-200/80 bg-[linear-gradient(180deg,#eef8ff_0%,#dff3fb_100%)] px-4 py-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.75)] sm:px-5 sm:py-6">
                <img
                  src={vortiflowWaterFlowMarketingImage.src}
                  alt="VortiFlow water-flow marketing image showing the irrigation concept with fluid movement"
                  class="block w-full h-auto"
                />
              </div>
            </div>
          </div>
          <div
            class="pointer-events-none absolute bottom-5 left-5 z-20 max-w-[16rem] rounded-[1rem] border border-slate-200/80 bg-white/95 px-3 py-2 text-xs font-medium leading-5 text-slate-600 opacity-0 shadow-[0_16px_32px_-22px_rgba(15,23,42,0.32)] transition-all duration-200"
            data-vortiflow-visual-feedback
            aria-live="polite"
          ></div>
        </a>
      </div>
    </div>
  </section>

  <script define:vars={{ heroVisualMailtoHref, heroVisualEmailBody }}>
    document.querySelectorAll('[data-vortiflow-visual-link]').forEach((link) => {
      const feedback = link.querySelector('[data-vortiflow-visual-feedback]');
      let feedbackTimer;

      const showFeedback = (message) => {
        if (!feedback) return;
        feedback.textContent = message;
        feedback.style.opacity = '1';
        clearTimeout(feedbackTimer);
        feedbackTimer = window.setTimeout(() => {
          feedback.style.opacity = '0';
        }, 2600);
      };

      link.addEventListener('click', async (event) => {
        event.preventDefault();

        let copied = false;

        if (navigator.clipboard?.writeText) {
          try {
            await navigator.clipboard.writeText(heroVisualEmailBody);
            copied = true;
          } catch {
            copied = false;
          }
        }

        showFeedback(
          copied
            ? 'Details copied. Your email editor should open now.'
            : 'Opening your email editor for further details.',
        );

        window.setTimeout(() => {
          window.location.href = heroVisualMailtoHref;
        }, 80);
      });
    });
  </script>

  {hasEvidencePdf && (
    <>
      <section class="border-b border-slate-200/80 bg-white">
        <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10 lg:py-12">
          <div class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-[radial-gradient(circle_at_top_left,rgba(239,246,255,0.92),rgba(255,255,255,0.96)_44%,rgba(248,250,252,0.98)_100%)] shadow-[0_30px_90px_-48px_rgba(15,23,42,0.18)]">
            <div class="flex flex-col gap-6 px-6 py-7 sm:px-8 sm:py-9 lg:flex-row lg:items-center lg:justify-between lg:gap-10">
              <div class="max-w-3xl">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Facts Sheet</p>
                <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Review the VortiFlow facts sheet in-page</h2>
                <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
                  Open the full Engineered Endodontic Irrigation facts sheet in a scrollable viewer without leaving the product page.
                </p>
              </div>
              <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
                <button
                  type="button"
                  class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800 sm:w-auto"
                  data-facts-sheet-open
                  aria-haspopup="dialog"
                  aria-controls={factsSheetModalId}
                >
                  Review Facts Sheet
                </button>
                <a
                  href={withBasePath(evidencePdfHref)}
                  class="inline-flex w-full items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950 sm:w-auto"
                  target="_blank"
                  rel="noreferrer"
                >
                  Open download
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div
        id={factsSheetModalId}
        class="fixed inset-0 z-50 hidden"
        data-facts-sheet-modal
        role="dialog"
        aria-modal="true"
        aria-labelledby={`${factsSheetModalId}-title`}
      >
        <div class="absolute inset-0 bg-slate-950/55 backdrop-blur-[2px]" data-facts-sheet-close></div>
        <div class="absolute inset-x-0 bottom-0 top-auto flex max-h-[99vh] min-h-[92vh] flex-col overflow-hidden rounded-t-[1.75rem] border border-slate-200 bg-white shadow-[0_40px_120px_-40px_rgba(15,23,42,0.45)] sm:inset-y-72 sm:inset-x-6 sm:max-h-none sm:min-h-0 sm:rounded-[1.75rem] lg:left-1/2 lg:right-auto lg:w-[min(81vw,67rem)] lg:-translate-x-1/2">
          <div class="flex items-center justify-between gap-4 border-b border-slate-200/80 px-5 py-3 sm:px-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Facts Sheet Viewer</p>
              <h3 id={`${factsSheetModalId}-title`} class="mt-2 text-lg font-bold tracking-tight text-slate-900 sm:text-xl">Engineered Endodontic Irrigation Facts Sheet</h3>
            </div>
            <button
              type="button"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition hover:border-slate-300 hover:text-slate-900"
              data-facts-sheet-close
              aria-label="Close facts sheet viewer"
            >
              ×
            </button>
          </div>
          <div class="flex items-center justify-between gap-3 border-b border-slate-200/80 bg-slate-50/70 px-5 py-2.5 text-sm sm:px-6">
            <p class="text-slate-600">If the inline viewer does not load, use the fallback link.</p>
            <a
              href={withBasePath(evidencePdfHref)}
              class="inline-flex shrink-0 items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950"
              target="_blank"
              rel="noreferrer"
            >
              Open / Download PDF
            </a>
          </div>
          <div class="min-h-0 flex-1 overflow-y-auto bg-slate-100 p-2 sm:p-3">
            <div class="mx-auto flex h-full min-h-full flex-col rounded-[1.25rem] border border-slate-200 bg-white shadow-[0_24px_60px_-40px_rgba(15,23,42,0.25)]">
              <iframe
                src={factsSheetViewerHref}
                title="VortiFlow facts sheet PDF viewer"
                class="h-[78vh] w-full rounded-[1.25rem] sm:h-full sm:min-h-0"
              ></iframe>
            </div>
          </div>
        </div>
      </div>

      <script define:vars={{ factsSheetModalId }}>
        const factsSheetModal = document.getElementById(factsSheetModalId);
        const factsSheetOpenButtons = document.querySelectorAll('[data-facts-sheet-open]');
        const factsSheetCloseButtons = factsSheetModal?.querySelectorAll('[data-facts-sheet-close]') ?? [];
        let factsSheetLastTrigger = null;

        const setFactsSheetOpen = (isOpen) => {
          if (!factsSheetModal) return;

          factsSheetModal.classList.toggle('hidden', !isOpen);
          document.body.classList.toggle('overflow-hidden', isOpen);

          if (isOpen) {
            const closeButton = factsSheetModal.querySelector('[aria-label="Close facts sheet viewer"]');
            closeButton?.focus();
          } else {
            factsSheetLastTrigger?.focus();
          }
        };

        factsSheetOpenButtons.forEach((button) => {
          button.addEventListener('click', () => {
            factsSheetLastTrigger = button;
            setFactsSheetOpen(true);
          });
        });

        factsSheetCloseButtons.forEach((button) => {
          button.addEventListener('click', () => setFactsSheetOpen(false));
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && factsSheetModal && !factsSheetModal.classList.contains('hidden')) {
            setFactsSheetOpen(false);
          }
        });
      </script>
    </>
  )}

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10 lg:py-12">
      <div class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-slate-950 shadow-[0_30px_90px_-48px_rgba(15,23,42,0.45)]">
        <img
          src={vortiflowComparisonChart.src}
          alt="Irrigation modality comparison chart showing conventional open-ended stainless steel, conventional side-vented stainless steel, and VortiFlow polymer"
          class="w-full object-contain"
        />
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto grid max-w-7xl gap-4 px-6 py-14 sm:gap-6 sm:py-16 lg:grid-cols-2 lg:py-20">
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-50/70 p-5 sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Clinical Problem</p>
        <p class="mt-4 text-base leading-7 text-slate-600 sm:mt-5 sm:leading-8">
          Irrigation performance depends not only on solution choice, but also on delivery geometry, insertion depth, canal shape, and the way fluid is directed inside constrained anatomy.
        </p>
      </article>
      <article class="rounded-[1.35rem] border border-slate-200 bg-slate-950 p-5 text-white sm:rounded-[1.75rem] sm:p-7">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">TransformX Solution</p>
        <p class="mt-4 text-base leading-7 text-slate-300 sm:mt-5 sm:leading-8">
          After TransformX shaping has created the intended canal form, VortiFlow extends the EndoTech control story into irrigation through a helical-channel, lateral-flow delivery concept positioned between shaping and sealing.
        </p>
      </article>
    </div>
  </section>

  <section class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">How It Works</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Helical channel flow design</h2>
        <p class="mt-4 text-base leading-7 text-slate-600 sm:mt-5 sm:text-lg sm:leading-8">
          VortiFlow is built around a lateral-flow concept in which irrigant exits through helical channels rather than being directed straight through an open apical outlet. The design is intended to create controlled flow movement within the canal space while reducing dependence on a direct apical jet.
        </p>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start">
        <div class="grid gap-5">
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-5">
            <img src={vortiflowHelicalFigure.src} alt="Diagram showing helical channel geometry for VortiFlow irrigation concept" class="mx-auto w-full max-w-[18rem] object-contain" />
            <h3 class="mt-5 text-xl font-bold text-slate-900">Spiral channel geometry</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              The helical figure illustrates the wall-channel concept that underpins the lateral delivery story.
            </p>
          </article>
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-5">
            <img src={vortiflowVortexFigure.src} alt="Engineering illustration of vortex-style flow path within an irrigation needle concept" class="mx-auto w-full max-w-[20rem] object-contain" />
            <h3 class="mt-5 text-xl font-bold text-slate-900">Intended vortex-style movement</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              The engineering concept emphasises lateral movement and fluid exchange within the prepared canal space rather than a simple direct apical stream.
            </p>
          </article>
        </div>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.14)] sm:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-teal-700">Mechanism Summary</p>
          <h3 class="mt-4 text-2xl font-bold tracking-tight text-slate-900">Why irrigation delivery design matters</h3>
          <div class="mt-6 space-y-4 text-base leading-8 text-slate-600">
            <p>
              Published CFD and experimental studies indicate that irrigation behaviour changes with canal anatomy, working depth, vent geometry, and outlet design.
            </p>
            <p>
              VortiFlow is positioned around the idea that a needle can be engineered to influence fluid movement more deliberately, with controlled lateral exit and less emphasis on direct apical jetting.
            </p>
            <p>
              The concept should be understood as evidence-led engineering rationale within the irrigation step, not as a blanket claim of superiority over every activation method.
            </p>
          </div>
          <ul class="mt-6 space-y-3 text-sm leading-7 text-slate-600">
            <li>Helical channels on the needle wall support the lateral-flow concept.</li>
            <li>Closed-end style geometry reduces reliance on a tip-open outlet.</li>
            <li>The workflow intent is cleaner transition from shaping into active irrigation.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <FeatureGrid
