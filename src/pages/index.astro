---
import Layout from '../layouts/Layout.astro';
import logo from '../assets/logo-wordmark.png';
import logoDark from '../assets/logo-wordmark-dark.png';
import heroProduct from '../assets/TransformX_All_In_Single_Image.png';
import etProduct from '../assets/et-transformx.png';
import irootProduct from '../assets/iroot-sealer.png';

// Base URL for all internal links
const base = import.meta.env.BASE_URL;
---

<Layout title="EndoTech Singapore | TransformX™ Rotary Endodontic Files">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-100 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href={base} class="flex items-center gap-3">
        <img src={logo.src} alt="EndoTech Singapore" class="h-10 w-auto dark:hidden" />
        <img src={logoDark.src} alt="EndoTech Singapore" class="h-10 w-auto hidden dark:block" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#products" class="text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-colors">Products</a>
        <a href="#workflow" class="text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-colors">Workflow</a>
        <a href={`${base}products/overview/`} class="text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-colors">Clinical Docs</a>
        <a href="#contact" class="inline-flex items-center gap-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-slate-800 dark:hover:bg-slate-100 transition-all hover:shadow-lg hover:shadow-slate-900/20">
          Make an Appointment
        </a>
      </div>
      <button class="md:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-cyan-50/30 dark:from-slate-900 dark:via-slate-900 dark:to-cyan-950/30"></div>
    <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23fff&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Decorative elements -->
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-gradient-to-br from-cyan-400/10 to-blue-500/10 dark:from-cyan-400/20 dark:to-blue-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-80 h-80 bg-gradient-to-tr from-slate-200/50 to-transparent dark:from-slate-700/30 rounded-full blur-3xl"></div>

    <!-- Fine precision lines -->
    <div class="absolute top-32 left-20 w-px h-32 bg-gradient-to-b from-transparent via-cyan-500/20 to-transparent hidden lg:block"></div>
    <div class="absolute top-48 left-32 w-16 h-px bg-gradient-to-r from-cyan-500/20 to-transparent hidden lg:block"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-20 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-50 dark:bg-cyan-950/50 border border-cyan-100 dark:border-cyan-800 rounded-full">
            <span class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></span>
            <span class="text-cyan-700 dark:text-cyan-300 text-sm font-medium">Now available in Singapore & APAC</span>
          </div>

          <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold text-slate-900 dark:text-white leading-[1.1] tracking-tight">
            Reduce the
            <span class="block text-cyan-600 dark:text-cyan-400">UNEXPECTED</span>
            <span class="block text-slate-600 dark:text-slate-400 font-medium text-3xl lg:text-4xl xl:text-5xl mt-3">in Endodontics</span>
          </h1>

          <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
            Get to length <span class="text-slate-900 dark:text-white font-semibold">predictably</span> and <span class="text-slate-900 dark:text-white font-semibold">safely</span>. TransformX™ with Avatar™ Tip — engineered for clinicians who demand precision.
          </p>

          <div class="flex flex-wrap gap-4 pt-4">
            <a href="#products" class="group inline-flex items-center gap-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-8 py-4 rounded-full font-semibold hover:bg-slate-800 dark:hover:bg-slate-100 transition-all hover:shadow-xl hover:shadow-slate-900/20 hover:-translate-y-0.5">
              View Products
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a href="#contact" class="inline-flex items-center gap-2 bg-white dark:bg-slate-800 text-slate-900 dark:text-white px-8 py-4 rounded-full font-semibold border-2 border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
              Make an Appointment
            </a>
          </div>

          <div class="flex items-center gap-8 pt-8 border-t border-slate-100 dark:border-slate-800">
            <div>
              <div class="text-2xl font-bold text-slate-900 dark:text-white">500+</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">Dentists Trust Us</div>
            </div>
            <div class="w-px h-10 bg-slate-200 dark:bg-slate-700"></div>
            <div>
              <div class="text-2xl font-bold text-slate-900 dark:text-white">10k+</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">Cases Completed</div>
            </div>
            <div class="w-px h-10 bg-slate-200 dark:bg-slate-700"></div>
            <div>
              <div class="text-2xl font-bold text-slate-900 dark:text-white">APAC</div>
              <div class="text-sm text-slate-500 dark:text-slate-400">Distribution</div>
            </div>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="aspect-square relative">
            <!-- Product image -->
            <div class="absolute inset-0 bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-900 rounded-3xl border border-slate-200/50 dark:border-slate-700/50 shadow-2xl shadow-slate-200/50 dark:shadow-black/30 overflow-hidden">
              <img src={heroProduct.src} alt="TransformX Rotary Files" class="w-full h-full object-contain p-8" />
              <!-- Corner accent -->
              <div class="absolute top-6 right-6 flex items-center gap-2 bg-white/80 dark:bg-slate-800/80 backdrop-blur px-3 py-1.5 rounded-full border border-slate-200/50 dark:border-slate-700/50">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                <span class="text-xs font-medium text-slate-600 dark:text-slate-300">In Stock</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-400">
      <span class="text-xs font-medium tracking-wider uppercase">Scroll Down For More</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-300 dark:from-slate-600 to-transparent animate-bounce"></div>
    </div>
  </section>

  <!-- Trusted By Section -->
  <section class="py-12 bg-slate-50 dark:bg-slate-800/50 border-y border-slate-100 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-center text-sm text-slate-500 dark:text-slate-400 mb-8">Trusted by leading dental practices across the Asia-Pacific region</p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 dark:opacity-40">
        <!-- Placeholder logos - replace with actual clinic/partner logos -->
        <div class="text-slate-400 dark:text-slate-500 font-semibold text-lg">Dental Clinic A</div>
        <div class="text-slate-400 dark:text-slate-500 font-semibold text-lg">Practice Group B</div>
        <div class="text-slate-400 dark:text-slate-500 font-semibold text-lg">Endo Specialists C</div>
        <div class="text-slate-400 dark:text-slate-500 font-semibold text-lg">Dental Centre D</div>
      </div>
    </div>
  </section>

  <!-- Explainer Video Section -->
  <section class="py-16 lg:py-24 bg-white dark:bg-slate-900">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-sm font-semibold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider mb-4">Watch</h2>
        <p class="text-3xl lg:text-4xl font-bold text-slate-900 dark:text-white">What is TransformX?</p>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-slate-200/50 dark:shadow-black/30 border border-slate-200 dark:border-slate-700">
        <video
          controls
          preload="metadata"
          poster=""
          class="w-full aspect-video bg-slate-900"
        >
          <source src={`${base}videos/explainer.mp4`} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>

      <p class="text-center text-slate-500 dark:text-slate-400 text-sm mt-6">37 seconds • Learn about TransformX technology and products</p>
    </div>
  </section>

  <!-- Why TransformX Section -->
  <section class="py-24 lg:py-32 bg-white dark:bg-slate-900 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-sm font-semibold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider mb-4">Why TransformX</h2>
        <p class="text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white leading-snug">Designed Around What<br class="hidden sm:inline" /> Actually Determines Success</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-cyan-200 dark:hover:border-cyan-700 hover:shadow-xl hover:shadow-cyan-500/5 dark:hover:shadow-cyan-500/10 transition-all duration-300">
          <div class="w-12 h-12 bg-cyan-500/10 dark:bg-cyan-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyan-500/20 dark:group-hover:bg-cyan-500/30 transition-colors">
            <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">Transform Technology</h3>
          <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed">Variable-phase design adapts as it advances—controlled coronal shaping where stability matters, increased flexibility at the apex where risk is highest.</p>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-cyan-200 dark:hover:border-cyan-700 hover:shadow-xl hover:shadow-cyan-500/5 dark:hover:shadow-cyan-500/10 transition-all duration-300">
          <div class="w-12 h-12 bg-cyan-500/10 dark:bg-cyan-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyan-500/20 dark:group-hover:bg-cyan-500/30 transition-colors">
            <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">Avatar™ Tip</h3>
          <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed">Precision-engineered apical geometry for control in the most critical millimeters. Minimises ledging, transportation, and perforation risk.</p>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-cyan-200 dark:hover:border-cyan-700 hover:shadow-xl hover:shadow-cyan-500/5 dark:hover:shadow-cyan-500/10 transition-all duration-300">
          <div class="w-12 h-12 bg-cyan-500/10 dark:bg-cyan-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyan-500/20 dark:group-hover:bg-cyan-500/30 transition-colors">
            <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">Work Smarter, Not Different</h3>
          <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed">TransformX doesn't ask you to work differently—it helps the file work smarter. Same technique, same motor settings, better outcomes.</p>
        </div>

        <!-- Card 4 -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-cyan-200 dark:hover:border-cyan-700 hover:shadow-xl hover:shadow-cyan-500/5 dark:hover:shadow-cyan-500/10 transition-all duration-300">
          <div class="w-12 h-12 bg-cyan-500/10 dark:bg-cyan-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyan-500/20 dark:group-hover:bg-cyan-500/30 transition-colors">
            <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">Shape Defines Seal</h3>
          <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed">Controlled taper development and predictable canal centring create reproducible conditions for optimal obturation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="py-24 lg:py-32 bg-slate-50 dark:bg-slate-800 relative overflow-hidden">
    <div class="absolute inset-0 opacity-50 dark:opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225 / 0.4) 1px, transparent 0); background-size: 32px 32px;"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-sm font-semibold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider mb-4">Products</h2>
        <p class="text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white">Choose Your System</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- ET TransformX -->
        <a href={`${base}products/et-transformx/`} class="group block bg-white dark:bg-slate-900 rounded-3xl p-8 shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 dark:hover:shadow-black/30 transition-all duration-500 border border-slate-100 dark:border-slate-700 hover:border-cyan-100 dark:hover:border-cyan-800 hover:-translate-y-1 cursor-pointer">
          <div class="aspect-[4/3] bg-gradient-to-br from-cyan-50 to-slate-50 dark:from-cyan-950 dark:to-slate-800 rounded-2xl mb-6 flex items-center justify-center overflow-hidden">
            <img src={etProduct.src} alt="ET TransformX Files" class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="space-y-4">
            <div class="flex items-start justify-between">
              <h3 class="text-xl font-bold text-slate-900 dark:text-white">ET TransformX Files</h3>
              <span class="text-lg font-bold text-cyan-600 dark:text-cyan-400">$110</span>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">For clinicians familiar with EdgeTaper, EdgeX7, Race Evo, and other .04/.06 taper systems.</p>
            <div class="flex flex-wrap gap-2 pt-2">
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">EdgeTaper</span>
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">EdgeX7</span>
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">.04/.06</span>
            </div>
            <span class="inline-flex items-center gap-2 text-cyan-600 dark:text-cyan-400 font-semibold text-sm pt-4 group-hover:gap-3 transition-all">
              View details
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>

        <!-- PT TransformX -->
        <a href={`${base}products/pt-transformx/`} class="group block bg-white dark:bg-slate-900 rounded-3xl p-8 shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 dark:hover:shadow-black/30 transition-all duration-500 border border-slate-100 dark:border-slate-700 hover:border-cyan-100 dark:hover:border-cyan-800 hover:-translate-y-1 cursor-pointer">
          <div class="aspect-[4/3] bg-gradient-to-br from-cyan-50 to-slate-50 dark:from-cyan-950 dark:to-slate-800 rounded-2xl mb-6 flex items-center justify-center overflow-hidden">
            <img src={heroProduct.src} alt="PT TransformX Files" class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="space-y-4">
            <div class="flex items-start justify-between">
              <h3 class="text-xl font-bold text-slate-900 dark:text-white">PT TransformX Files</h3>
              <span class="text-lg font-bold text-cyan-600 dark:text-cyan-400">$130</span>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">For clinicians experienced with ProTaper Gold or ProTaper Next systems.</p>
            <div class="flex flex-wrap gap-2 pt-2">
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">ProTaper Gold</span>
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">ProTaper Next</span>
            </div>
            <span class="inline-flex items-center gap-2 text-cyan-600 dark:text-cyan-400 font-semibold text-sm pt-4 group-hover:gap-3 transition-all">
              View details
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>

        <!-- iRoot Sealer -->
        <a href={`${base}products/iroot-sealer/`} class="group block bg-white dark:bg-slate-900 rounded-3xl p-8 shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 dark:hover:shadow-black/30 transition-all duration-500 border border-slate-100 dark:border-slate-700 hover:border-cyan-100 dark:hover:border-cyan-800 hover:-translate-y-1 cursor-pointer">
          <div class="aspect-[4/3] bg-gradient-to-br from-amber-50 to-slate-50 dark:from-amber-950 dark:to-slate-800 rounded-2xl mb-6 flex items-center justify-center overflow-hidden">
            <img src={irootProduct.src} alt="iRoot Sealer" class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="space-y-4">
            <div class="flex items-start justify-between">
              <h3 class="text-xl font-bold text-slate-900 dark:text-white">iRoot Sealer</h3>
              <span class="text-lg font-bold text-cyan-600 dark:text-cyan-400">$170</span>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Premixed, injectable bioceramic root canal sealer — the gold standard for obturation.</p>
            <div class="flex flex-wrap gap-2 pt-2">
              <span class="px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-xs font-medium rounded-full">Gold Standard</span>
              <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs font-medium rounded-full">Bioceramic</span>
            </div>
            <span class="inline-flex items-center gap-2 text-cyan-600 dark:text-cyan-400 font-semibold text-sm pt-4 group-hover:gap-3 transition-all">
              View details
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>
