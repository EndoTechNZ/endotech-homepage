      <div class="border-t border-slate-200 dark:border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-500 text-sm">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>

        <div class="flex items-center gap-4">
          <p class="text-slate-500 text-sm">{siteConfig.email}</p>

          <!-- Theme Picker -->
          <div class="flex items-center gap-1 bg-slate-200 dark:bg-slate-800 rounded-full p-1">
            <button id="theme-light" aria-label="Light theme" class="theme-btn p-2 rounded-full text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-300 dark:hover:bg-slate-700 transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
            </button>
            <button id="theme-system" aria-label="System theme" class="theme-btn p-2 rounded-full text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-300 dark:hover:bg-slate-700 transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </button>
            <button id="theme-dark" aria-label="Dark theme" class="theme-btn p-2 rounded-full text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-300 dark:hover:bg-slate-700 transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  .theme-btn.active {
    background-color: rgb(51 65 85); /* slate-700 */
    color: white;
  }

  #site-nav.scrolled {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 45px -28px rgba(15, 23, 42, 0.35);
    backdrop-filter: blur(18px);
  }

  .dark #site-nav.scrolled {
    background: rgba(15, 23, 42, 0.92);
    box-shadow: 0 18px 45px -28px rgba(0, 0, 0, 0.5);
  }

  .nav-link.active {
    color: rgb(8 145 178);
  }

  .proof-card,
  .action-card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    --dot-x: 50%;
    --dot-y: 50%;
  }

  .proof-card::after,
  .action-card::after {
    content: '';
    position: absolute;
    left: var(--dot-x);
    top: var(--dot-y);
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.9) 0%, rgba(14, 165, 233, 0.35) 45%, rgba(14, 165, 233, 0) 75%);
    transform: translate(-50%, -50%) scale(0.2);
    opacity: 0;
    filter: blur(0.4px);
    transition: opacity 160ms ease, transform 180ms ease;
    pointer-events: none;
    z-index: 0;
  }

  .proof-card.is-hovering::after,
  .action-card.is-hovering::after {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @keyframes hero-float-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @keyframes hero-float-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, 8px, 0); }
  }

  @keyframes hero-float-c {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -6px, 0); }
  }

  @keyframes hero-product-breath {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(0, -8px, 0) scale(1.015); }
  }

  @keyframes hero-glow-drift {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(10px, -8px, 0) scale(1.08); }
  }

  .hero-motion-scene {
    --mx: 0px;
    --my: 0px;
  }

  .hero-parallax-layer {
    will-change: transform;
    transform: translate3d(var(--mx), var(--my), 0);
    transition: transform 220ms ease-out;
  }

  .hero-layer-panel {
    --mx: calc(var(--scene-x, 0px) * 0.08);
    --my: calc(var(--scene-y, 0px) * 0.08);
    animation: hero-float-c 10s ease-in-out infinite;
  }

  .hero-main-product {
    --mx: calc(var(--scene-x, 0px) * 0.18);
    --my: calc(var(--scene-y, 0px) * 0.16);
    animation: hero-float-a 11s ease-in-out infinite;
  }

  .hero-product-float {
    animation: hero-product-breath 12s ease-in-out infinite;
  }

  .hero-float-card {
    animation: hero-float-b 9s ease-in-out infinite;
  }

  .hero-card-top-left {
    --mx: calc(var(--scene-x, 0px) * -0.18);
    --my: calc(var(--scene-y, 0px) * -0.16);
    animation-delay: -1.5s;
  }

  .hero-card-right {
    --mx: calc(var(--scene-x, 0px) * 0.22);
    --my: calc(var(--scene-y, 0px) * -0.08);
    animation-delay: -4s;
  }

  .hero-card-bottom-left {
    --mx: calc(var(--scene-x, 0px) * -0.12);
    --my: calc(var(--scene-y, 0px) * 0.22);
    animation-delay: -2.5s;
  }

  .hero-card-bottom-right {
    --mx: calc(var(--scene-x, 0px) * 0.16);
    --my: calc(var(--scene-y, 0px) * 0.18);
    animation-delay: -5s;
  }

  .hero-microchip {
    --mx: calc(var(--scene-x, 0px) * 0.24);
    --my: calc(var(--scene-y, 0px) * -0.12);
    animation: hero-float-c 8s ease-in-out infinite;
    animation-delay: -3.2s;
  }

  .hero-scene-glow {
    animation: hero-glow-drift 14s ease-in-out infinite;
  }

  .hero-scene-glow-secondary {
    animation-delay: -6s;
  }

  .products-menu.is-open > .products-menu-panel,
  .products-menu.is-open > .pointer-events-none {
    opacity: 1;
    pointer-events: auto;
  }

  .products-menu.is-open #products-menu-button svg {
    transform: translateY(1px) rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-parallax-layer,
    .hero-product-float,
    .hero-scene-glow {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }

</style>

<script>
  function updateTheme(theme: string) {
    const root = document.documentElement;

    if (theme === 'dark') {
      root.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    } else if (theme === 'light') {
      root.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      // System preference
      localStorage.removeItem('theme');
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    }

    updateButtonStates(theme);
  }

  function updateButtonStates(activeTheme: string) {
    const buttons = document.querySelectorAll('.theme-btn');
    buttons.forEach(btn => btn.classList.remove('active'));

    const activeBtn = document.getElementById(`theme-${activeTheme}`);
    if (activeBtn) activeBtn.classList.add('active');
  }

  function getStoredTheme(): string {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || stored === 'light') return stored;
    return 'system';
  }

  // Initialize on load
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('site-nav');
    const navLinks = document.querySelectorAll('[data-section-link]');
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuLinks = document.querySelectorAll('.mobile-nav-link');
    const productsMenu = document.querySelector<HTMLElement>('.products-menu');
    const productsMenuButton = document.getElementById('products-menu-button');
    const proofCards = document.querySelectorAll<HTMLElement>('.proof-card');
    const actionCards = document.querySelectorAll<HTMLElement>('.action-card');
    const heroScenes = document.querySelectorAll<HTMLElement>('.hero-motion-scene');
    const observedSections = ['products', 'workflow', 'contact']
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    function setMobileMenu(open: boolean) {
      if (!mobileMenu || !mobileMenuButton) return;
      mobileMenu.classList.toggle('hidden', !open);
      mobileMenuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function setProductsMenu(open: boolean) {
      if (!productsMenu || !productsMenuButton) return;
      productsMenu.classList.toggle('is-open', open);
      productsMenuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function updateNavState() {
      if (!nav) return;
      nav.classList.toggle('scrolled', window.scrollY > 24);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const targetId = entry.target.getAttribute('id');
        const link = document.querySelector(`[data-section-link="${targetId}"]`);
        if (!link) return;

        if (entry.isIntersecting) {
          navLinks.forEach((item) => item.classList.remove('active'));
          link.classList.add('active');
        }
      });
    }, {
      rootMargin: '-35% 0px -45% 0px',
      threshold: 0.1,
    });

    observedSections.forEach((section) => observer.observe(section));

    const storedTheme = getStoredTheme();
    updateButtonStates(storedTheme);
    updateNavState();

    // Set up button click handlers
    document.getElementById('theme-light')?.addEventListener('click', () => updateTheme('light'));
    document.getElementById('theme-system')?.addEventListener('click', () => updateTheme('system'));
    document.getElementById('theme-dark')?.addEventListener('click', () => updateTheme('dark'));
    window.addEventListener('scroll', updateNavState, { passive: true });
    mobileMenuButton?.addEventListener('click', () => {
      const isOpen = mobileMenuButton.getAttribute('aria-expanded') === 'true';
      setMobileMenu(!isOpen);
    });
    productsMenuButton?.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      const isOpen = productsMenuButton.getAttribute('aria-expanded') === 'true';
      setProductsMenu(!isOpen);
    });
    mobileMenuLinks.forEach((link) => {
      link.addEventListener('click', () => setMobileMenu(false));
    });
    productsMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setProductsMenu(false));
    });
    proofCards.forEach((card) => {
      const updateDotPosition = (event: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        card.style.setProperty('--dot-x', `${x}px`);
        card.style.setProperty('--dot-y', `${y}px`);
      };

      card.addEventListener('mouseenter', (event) => {
        card.classList.add('is-hovering');
        updateDotPosition(event);
      });
      card.addEventListener('mousemove', updateDotPosition);
      card.addEventListener('mouseleave', () => {
        card.classList.remove('is-hovering');
      });
    });
    actionCards.forEach((card) => {
      const updateDotPosition = (event: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        card.style.setProperty('--dot-x', `${x}px`);
        card.style.setProperty('--dot-y', `${y}px`);
      };

      card.addEventListener('mouseenter', (event) => {
        card.classList.add('is-hovering');
        updateDotPosition(event);
      });
      card.addEventListener('mousemove', updateDotPosition);
      card.addEventListener('mouseleave', () => {
        card.classList.remove('is-hovering');
      });
    });
    heroScenes.forEach((scene) => {
      const resetScene = () => {
        scene.style.setProperty('--scene-x', '0px');
        scene.style.setProperty('--scene-y', '0px');
      };

      resetScene();

      scene.addEventListener('mousemove', (event) => {
        const rect = scene.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width - 0.5) * 20;
        const y = ((event.clientY - rect.top) / rect.height - 0.5) * 20;
        scene.style.setProperty('--scene-x', `${x}px`);
        scene.style.setProperty('--scene-y', `${y}px`);
      });

      scene.addEventListener('mouseleave', resetScene);
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        setMobileMenu(false);
      }
    });
    document.addEventListener('click', (event) => {
      if (!productsMenu) return;
      if (!productsMenu.contains(event.target as Node)) {
        setProductsMenu(false);
      }
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMobileMenu(false);
        setProductsMenu(false);
      }
    });

    // Listen for system preference changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        if (e.matches) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
    });
  });
</script>

