---
import Layout from '../layouts/Layout.astro';
import HomepageConceptV3 from '../components/home/HomepageConceptV3.astro';
import heroProduct from '../assets/transformx-rotary-file-system.png';
import { siteConfig } from '../config/site';

const description =
  'EndoTech NZ presents engineered endodontic systems for controlled shaping, predictable sealing, and clinical confidence across demanding anatomy.';
---

<Layout
  title={`${siteConfig.name} | Engineered Endodontic Systems`}
  description={description}
  image={heroProduct.src}
>
  <HomepageConceptV3 />
</Layout>
