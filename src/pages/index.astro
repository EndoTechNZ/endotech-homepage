        </div>
        <div class="rounded-3xl border border-white/15 bg-white/10 p-8 backdrop-blur">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-100">Compare</p>
          <h3 class="mt-4 text-2xl font-bold">Talk through product fit</h3>
          <p class="mt-3 text-sm leading-relaxed text-cyan-50/90">Use this route if you need help matching ET, PT, or obturation products to your current instrumentation habits.</p>
          <a href={`${base}about/contact/`} class="mt-6 inline-flex items-center justify-center gap-3 rounded-full bg-cyan-500/30 px-6 py-3 text-sm font-bold text-white border border-white/20 hover:bg-cyan-500/40 hover:border-white/30">
            Ask about system fit
          </a>
        </div>
        <div class="rounded-3xl border border-white/15 bg-white/10 p-8 backdrop-blur">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-100">Order</p>
          <h3 class="mt-4 text-2xl font-bold">Request pricing or availability</h3>
          <p class="mt-3 text-sm leading-relaxed text-cyan-50/90">Use this route for pricing, stocking discussions, group orders, or APAC distribution and availability enquiries.</p>
          <a href={`${base}about/contact/`} class="mt-6 inline-flex items-center justify-center gap-3 rounded-full bg-slate-900 px-6 py-3 text-sm font-bold text-white hover:bg-slate-950">
            Request information
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-slate-100 dark:bg-slate-900 text-slate-900 dark:text-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-12 mb-12">
        <div class="md:col-span-2">
          <div class="mb-6 flex items-center gap-3">
            <img src={logoIcon.src} alt={siteConfig.name} class="h-12 w-auto" />
            <div class="leading-none">
              <div class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">EndoTechNZ</div>
              <div class="mt-1 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">New Zealand</div>
            </div>
          </div>
          <p class="text-slate-600 dark:text-slate-400 max-w-sm leading-relaxed">Advanced endodontic instruments for dental professionals across {siteConfig.regionLabel} and the Asia-Pacific region.</p>
        </div>

        <div>
          <h4 class="font-bold mb-4">Products</h4>
          <ul class="list-none space-y-3 text-slate-600 dark:text-slate-400">
            <li><a href={`${base}products/et-transformx/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">ET TransformX</a></li>
            <li><a href={`${base}products/pt-transformx/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">PT TransformX</a></li>
            <li><a href={`${base}products/bcs/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">BCS BioCeramics</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-bold mb-4">Resources</h4>
          <ul class="list-none space-y-3 text-slate-600 dark:text-slate-400">
            <li><a href={`${base}products/overview/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Clinical Docs</a></li>
            <li><a href={`${base}technique/workflow/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Technique Guides</a></li>
            <li><a href={`${base}resources/downloads/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Downloads</a></li>
            <li><a href={`mailto:${siteConfig.email}`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Contact</a></li>
