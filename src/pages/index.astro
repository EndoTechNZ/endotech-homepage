---
import Layout from '../layouts/Layout.astro';
import InsightCard from '../components/InsightCard.astro';
import logoIcon from '../assets/endotech-logo-2.png';
import heroProduct from '../assets/transformx-rotary-file-system.png';
import etProduct from '../assets/et-transformx.png';
import acrobatProduct from '../assets/acrobat-glide-path-files.png';
import { siteConfig } from '../config/site';

// Base URL for all internal links
const base = import.meta.env.BASE_URL;
const bcsSealerImage = `${base}downloads/metallic-packshots/BCS-Sealer-metallic-silver.png`;
const productMenu = [
  { label: 'ET TransformX Files', href: `${base}products/et-transformx/` },
  { label: 'PT TransformX Files', href: `${base}products/pt-transformx/` },
  { label: 'Acrobat Glide Path Files', href: `${base}products/acrobat-glide-path/` },
  { label: 'BCS BioCeramic Sealer', href: `${base}products/bcs-bioceramic-sealer/` },
  { label: 'BCS BioCeramic Putty', href: `${base}products/bcs-bioceramic-putty/` },
  { label: 'BCS BioCeramics Family', href: `${base}products/bcs/` },
];
const partNumberSheets = [
  { label: 'ET TransformX Part Numbers', href: `${base}downloads/ET-Part-Numbers.pdf` },
  { label: 'PT TransformX Part Numbers', href: `${base}downloads/PT-Part-Numbers.pdf` },
];
const insightCards = [
  {
    title: 'Transform Technology',
    body: "Variable-phase geometry shifts the file's behavior through the canal: more coronal stability during early shaping, more apical flexibility where transportation risk increases.",
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Avatar Tip',
    body: 'Refined apical geometry is intended to improve guidance in the final millimeters and lower the chance of apical zipping, ledging, and transportation.',
    iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Work Smarter, Not Different',
    body: 'The system is positioned for clinicians who want performance gains without relearning their full shaping protocol or changing routine motor settings.',
    iconPath: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  },
  {
    title: 'Shape Defines Seal',
    body: 'More controlled taper development and better canal centring help create a preparation shape that supports more consistent irrigation and obturation.',
    iconPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
];
---

<Layout
  title={siteConfig.homepageTitle}
  description={siteConfig.defaultDescription}
  image={heroProduct.src}
>
  <!-- Navigation -->
  <nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 border-b border-slate-100/80 bg-white/78 backdrop-blur-md transition-all duration-300 dark:border-slate-800/80 dark:bg-slate-900/78">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between transition-all duration-300">
      <a href={base} class="flex items-center gap-3">
        <img src={logoIcon.src} alt={siteConfig.name} class="h-10 w-auto" />
        <div class="leading-none">
          <div class="text-lg font-bold tracking-tight text-slate-900 dark:text-white">EndoTechNZ</div>
          <div class="mt-0.5 text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">New Zealand</div>
        </div>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href={base} class="inline-flex origin-center text-base font-semibold text-slate-900 transition-transform transition-colors duration-200 hover:scale-110 hover:text-cyan-700 dark:text-white dark:hover:text-cyan-300">Home</a>
        <div class="group products-menu relative">
          <button id="products-menu-button" type="button" class="inline-flex origin-center items-center gap-2 text-sm font-medium text-slate-600 transition-transform transition-colors duration-200 hover:scale-110 hover:text-slate-900 focus:outline-none focus:text-slate-900 dark:text-slate-400 dark:hover:text-white dark:focus:text-white" aria-haspopup="true" aria-expanded="false" aria-controls="products-menu-panel">
            Products
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-[1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 9l6 6 6-6"></path>
            </svg>
          </button>
          <div class="pointer-events-none absolute left-1/2 top-full z-40 h-4 w-72 -translate-x-1/2 opacity-0 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100"></div>
          <div id="products-menu-panel" class="products-menu-panel pointer-events-none absolute left-1/2 top-full z-50 w-72 -translate-x-1/2 pt-3 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
            <div class="rounded-[1.6rem] border border-slate-200/80 bg-white/96 p-3 shadow-[0_24px_60px_-28px_rgba(15,23,42,0.28)] backdrop-blur-xl dark:border-slate-700/80 dark:bg-slate-900/96">
            <div class="mb-2 px-3 pt-2 text-[0.65rem] font-semibold uppercase tracking-[0.24em] text-cyan-700 dark:text-cyan-300">Product Lineup</div>
            <div class="grid gap-1">
              {productMenu.map((item) => (
                <a href={item.href} class="rounded-2xl px-3 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800/80 dark:hover:text-white">
                  {item.label}
                </a>
              ))}
            </div>
            </div>
          </div>
        </div>
        <a href={`${base}technology/avatar-tip/`} class="inline-flex origin-center text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-transform transition-colors duration-200 hover:scale-110">Technology</a>
        <a href="#compare" class="inline-flex origin-center text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-transform transition-colors duration-200 hover:scale-110">Compare</a>
        <a href="#workflow" data-section-link="workflow" class="nav-link inline-flex origin-center text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-transform transition-colors duration-200 hover:scale-110">Workflow</a>
        <a href={`${base}products/overview/`} class="inline-flex origin-center text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-medium transition-transform transition-colors duration-200 hover:scale-110">Clinical Docs</a>
        <a href="#contact" data-section-link="contact" class="inline-flex origin-center items-center gap-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-slate-800 dark:hover:bg-slate-100 transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-slate-900/20">
          Request Information
        </a>
      </div>
      <button
        id="mobile-menu-button"
        class="md:hidden inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/90 px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm dark:border-slate-700 dark:bg-slate-900/90 dark:text-slate-200"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden border-t border-slate-200/80 bg-white/95 px-6 pb-6 pt-4 shadow-2xl shadow-slate-900/5 dark:border-slate-800/80 dark:bg-slate-900/95 md:hidden">
      <div class="grid gap-3">
        <a href={base} class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Home</a>
        <a href="#products" class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Browse product systems</a>
        <div class="rounded-[1.6rem] border border-slate-200 bg-white/90 p-3 dark:border-slate-700 dark:bg-slate-900/80">
          <div class="px-1 pb-2 text-[0.65rem] font-semibold uppercase tracking-[0.24em] text-cyan-700 dark:text-cyan-300">Products</div>
          <div class="grid gap-2">
            {productMenu.map((item) => (
              <a href={item.href} class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">
                {item.label}
              </a>
            ))}
          </div>
        </div>
        <a href={`${base}technology/avatar-tip/`} class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Technology</a>
        <a href="#compare" class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Compare ET, PT, and sealer</a>
        <a href="#workflow" class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Review the workflow</a>
        <a href={`${base}resources/downloads/`} class="mobile-nav-link rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-cyan-300 hover:text-slate-900 dark:border-slate-700 dark:text-slate-300 dark:hover:border-cyan-700 dark:hover:text-white">Download the clinical pack</a>
        <a href={`mailto:${siteConfig.email}`} class="mobile-nav-link inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white dark:bg-white dark:text-slate-900">Contact {siteConfig.shortName}</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center pt-8 md:pt-12 overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-cyan-50/30 dark:from-slate-900 dark:via-slate-900 dark:to-cyan-950/30"></div>
    <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23fff&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Decorative elements -->
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-gradient-to-br from-cyan-400/10 to-blue-500/10 dark:from-cyan-400/20 dark:to-blue-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-80 h-80 bg-gradient-to-tr from-slate-200/50 to-transparent dark:from-slate-700/30 rounded-full blur-3xl"></div>

    <!-- Fine precision lines -->
    <div class="absolute top-32 left-20 w-px h-32 bg-gradient-to-b from-transparent via-cyan-500/20 to-transparent hidden lg:block"></div>
    <div class="absolute top-48 left-32 w-16 h-px bg-gradient-to-r from-cyan-500/20 to-transparent hidden lg:block"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-14 lg:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start lg:items-end">
        <div class="space-y-8">
            <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold text-slate-900 dark:text-white leading-[1.1] tracking-tight">
            Reduce the
            <span class="block text-cyan-600 dark:text-cyan-400">UNEXPECTED</span>
            <span class="block text-slate-600 dark:text-slate-400 font-medium text-3xl lg:text-4xl xl:text-5xl mt-3">in Endodontics</span>
          </h1>

          <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-2xl">
            Evaluate a rotary file system built to improve <span class="text-slate-900 dark:text-white font-semibold">working-length control</span>, maintain <span class="text-slate-900 dark:text-white font-semibold">canal centring</span>, and reduce the likelihood of <span class="text-slate-900 dark:text-white font-semibold">ledging, transportation, and file separation</span> in curved anatomy.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a href="#products" class="group inline-flex items-center gap-2 bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-8 py-4 rounded-full font-semibold hover:bg-slate-800 dark:hover:bg-slate-100 transition-all hover:shadow-xl hover:shadow-slate-900/20 hover:-translate-y-0.5">
              View Product Systems
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a href={`${base}resources/downloads/`} class="inline-flex items-center gap-2 bg-white dark:bg-slate-800 text-slate-900 dark:text-white px-8 py-4 rounded-full font-semibold border-2 border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
              Download Clinical Pack
            </a>
            <a href={`mailto:${siteConfig.email}`} class="inline-flex items-center gap-2 px-2 py-4 font-semibold text-slate-900 transition-colors hover:text-cyan-600 dark:text-white dark:hover:text-cyan-400">
              Talk to {siteConfig.shortName}
            </a>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-cyan-100 bg-white/90 px-4 py-4 shadow-sm shadow-cyan-100/40 backdrop-blur dark:border-cyan-900/60 dark:bg-slate-900/80 dark:shadow-black/20">
              <p class="text-sm font-semibold text-slate-900 dark:text-white">Built around familiar PT and ET-style workflows</p>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Designed to slot into existing sequence logic and established motor settings.</p>
            </div>
            <div class="rounded-2xl border border-cyan-100 bg-white/90 px-4 py-4 shadow-sm shadow-cyan-100/40 backdrop-blur dark:border-cyan-900/60 dark:bg-slate-900/80 dark:shadow-black/20">
              <p class="text-sm font-semibold text-slate-900 dark:text-white">Clinical evaluation comes first</p>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Open workflow sheets, part numbers, and system comparisons before contacting sales.</p>
            </div>
          </div>

          <div class="grid gap-4 pt-6 border-t border-slate-100 dark:border-slate-800 sm:grid-cols-3">
            <div class="rounded-3xl border border-slate-200/80 bg-white/92 p-5 shadow-lg shadow-slate-200/45 backdrop-blur dark:border-slate-800 dark:bg-slate-900/85 dark:shadow-black/20">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-50 text-cyan-600 shadow-sm shadow-cyan-100 dark:bg-cyan-950/60 dark:text-cyan-400 dark:shadow-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 6h12M6 12h12M6 18h7"></path>
                </svg>
              </div>
              <div class="mt-5 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-cyan-600/80 dark:text-cyan-400/80">Workflow Options</div>
              <div class="mt-3 text-2xl font-bold leading-tight text-slate-900 dark:text-white">Three File Systems + One Glidepath</div>
              <div class="mt-3 text-sm leading-relaxed text-slate-500 dark:text-slate-400">Choose the shaping workflow that matches how you already work, with glidepath support coming too.</div>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/92 p-5 shadow-lg shadow-slate-200/45 backdrop-blur dark:border-slate-800 dark:bg-slate-900/85 dark:shadow-black/20">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-50 text-cyan-600 shadow-sm shadow-cyan-100 dark:bg-cyan-950/60 dark:text-cyan-400 dark:shadow-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5v14M5 12h14"></path>
                </svg>
              </div>
              <div class="mt-5 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-cyan-600/80 dark:text-cyan-400/80">Clinical Access</div>
              <div class="mt-3 text-2xl font-bold leading-tight text-slate-900 dark:text-white">Clinical Downloads</div>
              <div class="mt-3 text-sm leading-relaxed text-slate-500 dark:text-slate-400">Open technique sheets, part numbers, and chairside handouts.</div>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/92 p-5 shadow-lg shadow-slate-200/45 backdrop-blur dark:border-slate-800 dark:bg-slate-900/85 dark:shadow-black/20">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-50 text-cyan-600 shadow-sm shadow-cyan-100 dark:bg-cyan-950/60 dark:text-cyan-400 dark:shadow-none">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12h18M12 3v18"></path>
                </svg>
              </div>
              <div class="mt-5 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-cyan-600/80 dark:text-cyan-400/80">Regional Help</div>
              <div class="mt-3 text-2xl font-bold leading-tight text-slate-900 dark:text-white">US, AU, NZ, JP Support</div>
              <div class="mt-3 text-sm leading-relaxed text-slate-500 dark:text-slate-400">US, AU, NZ, JP supply, product-fit help, and ordering support.</div>
            </div>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="absolute inset-x-0 top-4 h-80 rounded-full bg-gradient-to-r from-cyan-300/20 via-sky-300/10 to-slate-200/5 blur-3xl dark:from-cyan-400/20 dark:via-blue-500/15 dark:to-slate-700/5"></div>
          <div class="absolute inset-x-10 bottom-8 h-24 rounded-full bg-slate-900/10 blur-2xl dark:bg-black/30"></div>
          <div class="hero-motion-scene relative isolate h-[60rem] overflow-hidden rounded-[2.75rem] border border-slate-200/70 bg-gradient-to-br from-white via-slate-50/95 to-cyan-50/65 shadow-[0_36px_100px_-38px_rgba(15,23,42,0.35)] dark:border-slate-700/50 dark:bg-gradient-to-br dark:from-slate-800 dark:via-slate-900 dark:to-cyan-950/25 dark:shadow-[0_40px_110px_-38px_rgba(0,0,0,0.65)]">
            <div class="absolute inset-0 opacity-70" style="background-image: radial-gradient(circle at top left, rgba(6,182,212,0.12), transparent 28%), radial-gradient(circle at bottom right, rgba(56,189,248,0.12), transparent 30%), linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px); background-size: auto, auto, 30px 30px, 30px 30px;"></div>
            <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-white/80 via-white/25 to-transparent dark:from-white/10 dark:via-white/5 dark:to-transparent"></div>
            <div class="hero-scene-glow absolute -left-16 top-12 h-44 w-44 rounded-full bg-cyan-300/25 blur-3xl dark:bg-cyan-400/20"></div>
            <div class="hero-scene-glow hero-scene-glow-secondary absolute right-[-3.5rem] top-40 h-56 w-56 rounded-full bg-sky-300/15 blur-3xl dark:bg-blue-500/20"></div>

            <div class="hero-parallax-layer hero-layer-panel absolute left-14 right-14 top-12 rounded-[1.9rem] border border-white/70 bg-white/55 p-6 shadow-[0_20px_50px_-35px_rgba(15,23,42,0.35)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-900/45">
              <div class="text-center">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">Clinical System View</p>
                <p class="mt-2 text-xl font-bold text-slate-900 dark:text-white">Glide, Shape, Seal</p>
              </div>
            </div>

            <a href={`${base}products/overview/`} class="hero-parallax-layer hero-main-product group absolute left-28 right-28 top-40 block rounded-[2.1rem] border border-white/70 bg-white/72 p-6 shadow-[0_28px_80px_-40px_rgba(15,23,42,0.45)] backdrop-blur-xl transition-transform duration-500 hover:-translate-y-1 dark:border-white/10 dark:bg-slate-900/60">
              <div class="relative overflow-hidden rounded-[1.7rem] border border-slate-200/70 bg-gradient-to-br from-white via-slate-50 to-cyan-50/70 dark:border-slate-700/70 dark:from-slate-900 dark:via-slate-800 dark:to-cyan-950/30">
                <div class="absolute inset-0 opacity-40" style="background-image: radial-gradient(circle at 22% 18%, rgba(6,182,212,0.14), transparent 24%), linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px); background-size: auto, 30px 30px, 30px 30px;"></div>
                <img src={heroProduct.src} alt="TransformX rotary file system showing the PT sequence" class="hero-product-float relative z-10 h-[34rem] w-full object-contain object-top px-10 pt-12 pb-10 transition-transform duration-500 group-hover:scale-[1.03]" />
              </div>
            </a>

