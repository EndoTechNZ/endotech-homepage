---
import ProductLayout from '../../layouts/ProductLayout.astro';
import WorkflowStrip from '../../components/navigation/WorkflowStrip.astro';
import avatarComparison from '../../assets/avatar-tip-comparison.png';

const base = import.meta.env.BASE_URL;

const controls = [
  'Rounded guidance profile',
  'Smooth transition geometry',
  'Bi-conical tip behaviour',
  'Controlled apical advancement',
];

const benefits = [
  'Better canal centering in the apical third',
  'Reduced tendency toward transportation and ledging',
  'Lower risk of abrupt lateral wall engagement',
  'More controlled approach to working length',
  'Improved preservation of the original canal path',
  'Greater confidence in difficult apical anatomy',
];
---

<ProductLayout
  title="Avatar Tip Technology | EndoTech NZ"
  description="Avatar Tip Technology is a guidance-focused apical tip design for safer progression, canal centering, and controlled shaping in the apical 2 mm."
  accent="slate"
>
  <main class="avatar-page">
    <section class="avatar-hero" aria-labelledby="avatar-title">
      <div>
        <p class="avatar-eyebrow">Avatar Tip Technology</p>
        <h1 id="avatar-title">Guidance where apical tolerance is lowest.</h1>
        <p>
          Avatar Tip is the TransformX apical geometry designed to support centered advancement, controlled engagement, and safer traversal through demanding anatomy.
        </p>
        <div class="avatar-actions">
          <a href="#comparison">Compare geometry</a>
          <a href="#apical-control">View apical behaviour</a>
          <a href={`${base}technology/transform-technology/`}>Transform Technology</a>
        </div>
      </div>

      <figure class="avatar-visual">
        <img src={avatarComparison.src} alt="Avatar Tip compared with a sharper competitor tip profile" />
        <figcaption>
          <strong>Tip geometry matters</strong>
          <span>Smoother transition geometry is presented as a control feature, not an aggressiveness claim.</span>
        </figcaption>
      </figure>
    </section>

    <WorkflowStrip activeStep="access" />

    <section class="split-section" aria-labelledby="problem-title">
      <div class="section-label">Clinical Problem</div>
      <div>
        <h2 id="problem-title">The greatest shaping risk is concentrated in the apical third.</h2>
        <p>
          In the final millimeters, canal curvature, reduced dentin thickness, and limited tolerance for error make tip behaviour clinically important. A more aggressive leading profile can engage the outer wall before the file is fully centered.
        </p>
      </div>
    </section>

    <section class="split-section response-section" aria-labelledby="response-title">
      <div class="section-label">TransformX Solution</div>
      <div>
        <h2 id="response-title">A guidance-focused tip design for controlled advancement.</h2>
        <p>
          Avatar Tip is designed to enter curved anatomy progressively, reduce abrupt wall engagement, and help preserve the original canal path through the apical constriction.
        </p>
        <div class="control-list">
          {controls.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section id="comparison" class="media-section" aria-labelledby="comparison-title">
      <div class="media-heading">
        <p class="avatar-eyebrow">Video Comparison</p>
        <h2 id="comparison-title">Rounded guidance profile versus a sharper transition profile.</h2>
      </div>

      <div class="video-grid">
        <figure>
          <video controls muted playsinline preload="metadata">
            <source src={`${base}videos/avatar-tip/avatar-tip-rounded.mp4`} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
          <figcaption>Avatar Tip: rounded leading geometry designed for smoother guidance.</figcaption>
        </figure>
        <figure>
          <video controls muted playsinline preload="metadata">
            <source src={`${base}videos/avatar-tip/competitor-tip-pointed.mp4`} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
          <figcaption>Competitor tip: sharper transition profile with a more pointed leading edge.</figcaption>
        </figure>
      </div>
    </section>

    <section id="apical-control" class="apical-section" aria-labelledby="apical-title">
      <div class="apical-copy">
        <p class="avatar-eyebrow">Apical Behaviour</p>
        <h2 id="apical-title">Controlled traversal through the final 2 mm.</h2>
        <p>
          The safety story is not only how the tip looks under magnification. It is how the file behaves as it advances through a complex apical pathway.
        </p>
      </div>

      <figure class="apical-video">
        <video controls muted playsinline preload="metadata">
          <source src={`${base}videos/avatar-tip/avatar-tip-apical-control.mp4`} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
        <figcaption>Bi-conical block demonstration showing centered advancement through the apical segment.</figcaption>
      </figure>
    </section>

    <section class="benefits-section" aria-labelledby="benefits-title">
      <div>
        <p class="avatar-eyebrow">Clinical Benefits</p>
        <h2 id="benefits-title">Apical control expressed in clinical terms.</h2>
      </div>
      <ul>
        {benefits.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="evidence-section" aria-labelledby="evidence-title">
      <p class="avatar-eyebrow">Evidence Direction</p>
      <h2 id="evidence-title">Tip design research supports the principle of controlled guidance.</h2>
      <p>
        Crown-down tip design literature supports the idea that smoother, biconical guidance can help maintain original canal curvature and reduce ledging compared with sharper geometries. Avatar Tip applies that principle inside the TransformX shaping system.
      </p>
      <div class="avatar-actions">
        <a href={`${base}technology/transform-technology/`}>Explore Transform Technology</a>
        <a href={`${base}products/pt-transformx/`}>View PT TransformX</a>
      </div>
    </section>
  </main>
</ProductLayout>

<style>
  .avatar-page {
    background: #f7f9fb;
    color: #0b1424;
  }

  .avatar-hero,
  .split-section,
  .media-section,
  .apical-section,
  .benefits-section,
  .evidence-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(56px, 6vw, 96px) 48px;
  }

  .avatar-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(380px, 0.78fr);
    gap: clamp(44px, 6vw, 84px);
    align-items: center;
    min-height: min(780px, calc(100vh - 82px));
  }

  .avatar-eyebrow,
  .section-label {
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .avatar-hero h1,
  .split-section h2,
  .media-heading h2,
  .apical-copy h2,
  .benefits-section h2,
  .evidence-section h2 {
    margin: 0;
    color: #090f1d;
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.12;
  }

  .avatar-hero h1 {
    margin-top: 28px;
    max-width: 11ch;
    font-size: clamp(3.1rem, 4.4vw, 5.4rem);
    line-height: 1.02;
  }

  .avatar-hero p,
  .split-section p,
  .apical-copy p,
  .evidence-section > p {
    max-width: 780px;
    margin: 24px 0 0;
    color: #536478;
    font-size: clamp(1rem, 0.95vw, 1.14rem);
    line-height: 1.78;
  }

  .avatar-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 38px;
  }

  .avatar-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    border: 1px solid #c8d2dc;
    border-radius: 4px;
    padding: 0 20px;
    color: #0b1424;
    font-weight: 850;
    text-decoration: none;
    transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .avatar-actions a:first-child {
    border-color: #0b1424;
    background: #0b1424;
    color: #ffffff;
  }

  .avatar-actions a:hover,
  .avatar-actions a:focus-visible {
    transform: translateY(-1px);
    border-color: #8aa5b8;
    background: #ffffff;
    color: #0b1424;
  }

  .avatar-visual,
  .video-grid figure,
  .apical-video {
    margin: 0;
    border-top: 1px solid #cfd9e2;
    border-bottom: 1px solid #cfd9e2;
    padding: 30px 0;
  }

  .avatar-visual img {
    display: block;
    width: 100%;
    height: auto;
  }

  .avatar-visual figcaption,
  .video-grid figcaption,
  .apical-video figcaption {
    display: grid;
    gap: 8px;
    margin-top: 22px;
    color: #536478;
    line-height: 1.65;
  }

  .avatar-visual strong {
    color: #0b1424;
    font-family: 'Sora', system-ui, sans-serif;
  }

  .split-section {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr);
    gap: clamp(32px, 5vw, 72px);
    border-top: 1px solid #dbe3ea;
    background: #ffffff;
  }

  .response-section,
  .apical-section {
    background: #f7f9fb;
  }

  .split-section h2,
  .media-heading h2,
  .apical-copy h2,
  .benefits-section h2,
  .evidence-section h2 {
    max-width: 780px;
    font-size: clamp(1.9rem, 2.45vw, 3.05rem);
  }

  .control-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin-top: 42px;
    border-top: 1px solid #dbe3ea;
  }

  .control-list span {
    border-bottom: 1px solid #dbe3ea;
    padding: 22px 24px 22px 0;
    color: #0b1424;
    font-weight: 850;
  }

  .control-list span:nth-child(even) {
    border-left: 1px solid #dbe3ea;
    padding-left: 24px;
  }

  .media-section {
    border-top: 1px solid #dbe3ea;
    background: #ffffff;
  }

  .media-heading h2 {
    margin-top: 22px;
    max-width: 950px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 42px;
    margin-top: 48px;
  }

  video {
    display: block;
    width: 100%;
    background: #0b1424;
  }

  .video-grid video {
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .apical-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(420px, 1fr);
    gap: clamp(44px, 6vw, 84px);
    align-items: start;
    border-top: 1px solid #dbe3ea;
  }

  .apical-copy h2 {
    margin-top: 22px;
  }

  .benefits-section {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(420px, 0.72fr);
    gap: clamp(44px, 6vw, 84px);
    border-top: 1px solid #dbe3ea;
    background: #ffffff;
  }

  .benefits-section h2 {
    margin-top: 22px;
  }

  .benefits-section ul {
    display: grid;
    gap: 0;
    align-content: start;
    margin: 0;
    padding: 0;
    border-top: 1px solid #cfd9e2;
    list-style: none;
  }

  .benefits-section li {
    border-bottom: 1px solid #dbe3ea;
    padding: 22px 0;
    color: #536478;
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .benefits-section li::before {
    content: '';
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.8rem;
    border-radius: 999px;
    background: #876a2b;
    vertical-align: 0.1em;
  }

  .evidence-section {
    border-top: 1px solid #dbe3ea;
    background: #f7f9fb;
  }

  .evidence-section h2 {
    max-width: 900px;
    margin-top: 22px;
  }

  @media (max-width: 980px) {
    .avatar-hero,
    .split-section,
    .apical-section,
    .benefits-section,
    .video-grid {
      grid-template-columns: 1fr;
    }

    .avatar-hero,
    .split-section,
    .media-section,
    .apical-section,
    .benefits-section,
    .evidence-section {
      padding-left: 28px;
      padding-right: 28px;
    }
  }

  @media (max-width: 640px) {
    .avatar-hero,
    .split-section,
    .media-section,
    .apical-section,
    .benefits-section,
    .evidence-section {
      padding-left: 18px;
      padding-right: 18px;
    }

    .avatar-hero h1 {
      font-size: clamp(3.1rem, 13vw, 5rem);
    }

    .control-list {
      grid-template-columns: 1fr;
    }

    .control-list span:nth-child(even) {
      border-left: 0;
      padding-left: 0;
    }
  }
</style>
