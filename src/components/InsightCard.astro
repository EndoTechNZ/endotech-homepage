---
interface Props {
  title: string;
  body: string;
  iconPath: string;
}

const { title, body, iconPath } = Astro.props;
---

<article class="insight-card relative bg-gradient-to-br from-slate-50 to-white dark:from-slate-800 dark:to-slate-900 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-cyan-200 dark:hover:border-cyan-700 hover:shadow-xl hover:shadow-cyan-500/5 dark:hover:shadow-cyan-500/10 transition-all duration-300">
  <div class="insight-icon w-12 h-12 bg-cyan-500/10 dark:bg-cyan-500/20 rounded-xl flex items-center justify-center mb-6 transition-colors">
    <svg class="insight-icon-glyph w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPath}></path>
    </svg>
  </div>
  <h3 class="mb-3 text-lg font-bold text-slate-900 dark:text-white">{title}</h3>
  <p class="text-base leading-relaxed text-slate-600 dark:text-slate-400">{body}</p>
</article>

<style>
  .insight-icon {
    transition: transform 220ms ease, box-shadow 220ms ease, background-color 220ms ease;
    transform-origin: center;
  }

  .insight-icon-glyph {
    transition: transform 240ms ease;
    transform-origin: center;
  }

  .insight-card:hover .insight-icon {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 14px 30px -18px rgba(14, 165, 233, 0.55);
    background-color: rgba(6, 182, 212, 0.2);
  }

  :global(.dark) .insight-card:hover .insight-icon {
    background-color: rgba(6, 182, 212, 0.3);
  }

  .insight-card:hover .insight-icon-glyph {
    transform: scale(1.06);
  }
</style>
