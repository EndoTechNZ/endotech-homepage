---
import type { CTAItem } from '../../data/bcs';
import { withBasePath } from '../../utils/paths';

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  description?: string;
  accent?: 'teal' | 'violet' | 'slate';
  ctas?: CTAItem[];
  imageSrc?: string;
  imageAlt?: string;
  imageStack?: { src: string; alt: string; href?: string; tone?: 'teal' | 'violet' | 'slate' }[];
  visualLabel?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  description,
  accent = 'teal',
  ctas = [],
  imageSrc,
  imageAlt = title,
  imageStack = [],
  visualLabel,
} = Astro.props;

const primaryCtas = ctas.filter((cta) => cta.row !== 'secondary');
const secondaryCtas = ctas.filter((cta) => cta.row === 'secondary');

const accentMap = {
  teal: {
    badge: 'text-teal-700 bg-teal-50 border-teal-200',
    dot: 'bg-teal-500',
    highlight: 'from-teal-100 via-cyan-50 to-white',
    panel: 'from-teal-500/15 via-cyan-500/8 to-white',
    shadow: 'shadow-[0_30px_90px_-45px_rgba(13,148,136,0.45)]',
    button: 'bg-slate-900 text-white hover:bg-slate-800',
    secondary: 'border-teal-200 text-teal-900 hover:border-teal-300 hover:bg-teal-50',
  },
  violet: {
    badge: 'text-violet-700 bg-violet-50 border-violet-200',
    dot: 'bg-violet-500',
    highlight: 'from-violet-100 via-fuchsia-50 to-white',
    panel: 'from-violet-500/15 via-fuchsia-500/8 to-white',
    shadow: 'shadow-[0_30px_90px_-45px_rgba(124,58,237,0.45)]',
    button: 'bg-slate-900 text-white hover:bg-slate-800',
    secondary: 'border-violet-200 text-violet-900 hover:border-violet-300 hover:bg-violet-50',
  },
  slate: {
    badge: 'text-slate-700 bg-slate-50 border-slate-200',
    dot: 'bg-slate-500',
    highlight: 'from-slate-100 via-slate-50 to-white',
    panel: 'from-slate-500/12 via-slate-300/10 to-white',
    shadow: 'shadow-[0_30px_90px_-45px_rgba(15,23,42,0.35)]',
    button: 'bg-slate-900 text-white hover:bg-slate-800',
    secondary: 'border-slate-200 text-slate-900 hover:border-slate-300 hover:bg-slate-50',
  },
}[accent];
---

<section class="relative overflow-hidden border-b border-slate-200/80 bg-white">
  <div class={`absolute inset-0 bg-gradient-to-br ${accentMap.highlight}`}></div>
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(15,23,42,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(15,23,42,0.08) 1px, transparent 1px); background-size: 32px 32px;"></div>
  <div class="relative mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-24">
    <div class="grid gap-10 sm:gap-12 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-center lg:gap-14">
      <div>
        <div class={`inline-flex items-center gap-3 rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] ${accentMap.badge}`}>
          <span class={`h-2.5 w-2.5 rounded-full ${accentMap.dot}`}></span>
          {eyebrow}
        </div>
        <h1 class="mt-6 max-w-4xl text-4xl font-bold tracking-tight text-slate-900 sm:mt-8 sm:text-5xl lg:text-6xl">{title}</h1>
        <p class="mt-4 max-w-3xl text-xl font-semibold leading-tight text-slate-700 sm:mt-6 sm:text-2xl">{subtitle}</p>
        {description && <p class="mt-5 max-w-3xl text-base leading-7 text-slate-600 sm:mt-6 sm:text-lg sm:leading-8">{description}</p>}
        {ctas.length > 0 && (
          <div class="mt-8 space-y-4 sm:mt-10 sm:space-y-5">
            {primaryCtas.length > 0 && (
              <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-6 sm:gap-y-4">
                {primaryCtas.map((cta) => (
                  <a
                    href={withBasePath(cta.href)}
                    class:list={[
                      'inline-flex w-full items-center justify-center rounded-full text-sm font-semibold transition-all duration-250 ease-out hover:-translate-y-0.5 sm:w-auto',
                      cta.variant === 'ghost'
                        ? 'border border-slate-200/90 bg-white/65 px-6 py-3.5 text-slate-700 shadow-[0_10px_24px_-20px_rgba(15,23,42,0.25)] hover:border-slate-300 hover:bg-white hover:text-slate-900 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.28)]'
                        : cta.variant === 'secondary'
                          ? `border px-6 py-3.5 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.32)] ${accentMap.secondary}`
                          : `px-6 py-3.5 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.42)] ${accentMap.button}`,
                    ]}
                  >
                    {cta.label}
                  </a>
                ))}
              </div>
            )}

            {secondaryCtas.length > 0 && (
              <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-start sm:gap-4 lg:justify-center">
                {secondaryCtas.map((cta) => (
                  <a
                    href={withBasePath(cta.href)}
                    class:list={[
                      'inline-flex w-full items-center justify-center rounded-full text-sm font-semibold transition-all duration-250 ease-out hover:-translate-y-0.5 sm:min-w-[15rem] sm:w-auto',
                      cta.variant === 'ghost'
                        ? 'border border-slate-200/90 bg-white/65 px-6 py-3.5 text-slate-700 shadow-[0_10px_24px_-20px_rgba(15,23,42,0.25)] hover:border-slate-300 hover:bg-white hover:text-slate-900 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.28)]'
                        : cta.variant === 'secondary'
                          ? `border px-6 py-3.5 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.32)] ${accentMap.secondary}`
                          : `px-6 py-3.5 hover:shadow-[0_18px_34px_-24px_rgba(15,23,42,0.42)] ${accentMap.button}`,
                    ]}
                  >
                    {cta.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      <div class="relative">
        <div class={`absolute inset-x-8 top-10 h-56 rounded-full bg-gradient-to-r ${accentMap.panel} blur-3xl`}></div>
        <div class={`relative overflow-hidden rounded-[1.5rem] border border-slate-200/80 bg-white/90 p-4 sm:rounded-[2rem] sm:p-6 ${accentMap.shadow}`}>
          <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at top left, rgba(15,23,42,0.14), transparent 36%), linear-gradient(rgba(15,23,42,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(15,23,42,0.08) 1px, transparent 1px); background-size: auto, 24px 24px, 24px 24px;"></div>
          <div class="relative aspect-[4/3] rounded-[1.2rem] border border-slate-200/70 bg-gradient-to-br from-white via-slate-50 to-slate-100/80 sm:rounded-[1.5rem]">
            {imageStack.length > 0 ? (
              <div class="relative flex h-full items-center justify-center px-5 py-6 sm:px-8 sm:py-10">
                <div class="absolute inset-x-12 bottom-12 h-10 rounded-full bg-slate-900/8 blur-2xl"></div>
                <div class="relative flex w-full max-w-[30rem] items-end justify-center gap-3 sm:gap-4">
                  {imageStack.map((image, index) => (
                    <div class:list={['relative flex flex-1 items-end', index === 0 ? 'max-w-[13rem]' : 'max-w-[14.5rem]']}>
                      <div class={`absolute inset-x-4 bottom-2 h-5 rounded-full blur-xl ${
                        image.tone === 'violet'
                          ? 'bg-violet-300/18'
                          : image.tone === 'slate'
                            ? 'bg-slate-300/16'
                            : 'bg-teal-300/18'
                      }`}></div>
                      {image.href ? (
                        <a
                          href={withBasePath(image.href)}
                          class="hero-pack-link relative z-10 block w-full overflow-hidden rounded-[1.2rem] border border-slate-200/85 bg-white/96 p-2 shadow-[0_22px_28px_rgba(15,23,42,0.10)] transition-all duration-250 ease-out hover:-translate-y-1 hover:border-slate-300 hover:shadow-[0_24px_32px_rgba(15,23,42,0.14)]"
                        >
                          <img
                            src={image.src}
                            alt={image.alt}
                            class:list={[
                              'w-full self-end object-contain',
                              index === 0 ? 'max-h-[19.5rem]' : 'max-h-[19.5rem]',
                            ]}
                          />
                        </a>
                      ) : (
                        <div class="relative z-10 w-full overflow-hidden rounded-[1.2rem] border border-slate-200/85 bg-white/96 p-2 shadow-[0_22px_28px_rgba(15,23,42,0.10)]">
                          <img
                            src={image.src}
                            alt={image.alt}
                            class:list={[
                              'w-full self-end object-contain',
                              index === 0 ? 'max-h-[19.5rem]' : 'max-h-[19.5rem]',
                            ]}
                          />
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ) : imageSrc ? (
              <img src={imageSrc} alt={imageAlt} class="h-full w-full object-contain p-4 sm:p-6" />
            ) : (
              <div class="flex h-full flex-col justify-between p-5 sm:p-8">
                <div class={`inline-flex w-fit rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] ${accentMap.badge}`}>
                  {visualLabel ?? title}
                </div>
                <div class="space-y-4">
                  <div class={`h-3 w-24 rounded-full ${accentMap.dot} opacity-70`}></div>
                  <div class="grid gap-3">
                    <div class="rounded-2xl border border-slate-200 bg-white/90 p-4">
                      <p class="text-sm font-semibold text-slate-900">Premixed bioceramic workflow</p>
                      <p class="mt-2 text-sm leading-6 text-slate-600">Designed for sealing and repair steps where handling consistency and clinical control matter.</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-white/90 p-4">
                      <p class="text-sm font-semibold text-slate-900">Procedure-aligned delivery</p>
                      <p class="mt-2 text-sm leading-6 text-slate-600">Built around concise, clinically readable messaging instead of broad promotional claims.</p>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-pack-link {
    isolation: isolate;
    --dot-x: 50%;
    --dot-y: 50%;
  }

  .hero-pack-link::after {
    content: '';
    position: absolute;
    left: var(--dot-x);
    top: var(--dot-y);
    width: 10px;
    height: 10px;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(188, 244, 244, 0.98) 0%, rgba(188, 244, 244, 0.55) 42%, rgba(188, 244, 244, 0) 78%);
    transform: translate(-50%, -50%) scale(0.2);
    opacity: 0;
    filter: blur(0.25px);
    transition: opacity 140ms ease, transform 160ms ease;
    pointer-events: none;
    z-index: 1;
  }

  .hero-pack-link.is-hovering::after {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
 </style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const packLinks = document.querySelectorAll<HTMLElement>('.hero-pack-link');

    packLinks.forEach((link) => {
      const updateDotPosition = (event: MouseEvent) => {
        const rect = link.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        link.style.setProperty('--dot-x', `${x}px`);
        link.style.setProperty('--dot-y', `${y}px`);
      };

      link.addEventListener('mouseenter', (event) => {
        link.classList.add('is-hovering');
        updateDotPosition(event);
      });
      link.addEventListener('mousemove', updateDotPosition);
      link.addEventListener('mouseleave', () => {
        link.classList.remove('is-hovering');
      });
    });
  });
</script>
