---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  items: string[];
  accent?: 'teal' | 'violet' | 'slate';
}

const { eyebrow, title, intro, items, accent = 'teal' } = Astro.props;
const accentClass = {
  teal: 'text-teal-700 bg-teal-50 border-teal-100',
  violet: 'text-violet-700 bg-violet-50 border-violet-100',
  slate: 'text-slate-700 bg-slate-100 border-slate-200',
}[accent];
---

<section class="border-b border-slate-200/80 bg-slate-50/70">
  <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{eyebrow}</p>}
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{title}</h2>
    {intro && <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600 sm:mt-5 sm:text-lg sm:leading-8">{intro}</p>}
    <div class="mt-8 grid gap-4 sm:mt-10 md:grid-cols-2 xl:grid-cols-3">
      {items.map((item, index) => (
        <article class="rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:rounded-[1.5rem]">
          <div class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] ${accentClass}`}>
            Application {index + 1}
          </div>
          <h3 class="mt-4 text-lg font-bold text-slate-900">{item}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
