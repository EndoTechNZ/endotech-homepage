---
import type { FeatureItem } from '../../data/iroot';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  items: FeatureItem[];
  accent?: 'teal' | 'violet' | 'slate';
}

const { eyebrow, title, intro, items, accent = 'teal' } = Astro.props;

const accentMap = {
  teal: {
    icon: 'bg-teal-50 text-teal-700 border-teal-100',
    card: 'hover:border-teal-200 hover:shadow-teal-500/8',
    iconHover: 'rgba(13, 148, 136, 0.18)',
    iconGlow: 'rgba(13, 148, 136, 0.32)',
  },
  violet: {
    icon: 'bg-violet-50 text-violet-700 border-violet-100',
    card: 'hover:border-violet-200 hover:shadow-violet-500/8',
    iconHover: 'rgba(124, 58, 237, 0.18)',
    iconGlow: 'rgba(124, 58, 237, 0.32)',
  },
  slate: {
    icon: 'bg-slate-100 text-slate-700 border-slate-200',
    card: 'hover:border-slate-300 hover:shadow-slate-500/8',
    iconHover: 'rgba(51, 65, 85, 0.14)',
    iconGlow: 'rgba(51, 65, 85, 0.28)',
  },
}[accent];

function iconPath(icon: FeatureItem['icon']) {
  switch (icon) {
    case 'premixed':
      return 'M5 12h14M12 5v14';
    case 'hydrophilic':
      return 'M12 4c3.5 4 5 6.7 5 9a5 5 0 01-10 0c0-2.3 1.5-5 5-9z';
    case 'bioactive':
      return 'M12 4l2.5 5 5.5.8-4 3.9.9 5.5-4.9-2.6-4.9 2.6.9-5.5-4-3.9 5.5-.8L12 4z';
    case 'radiopaque':
      return 'M4 12h16M12 4v16M6.5 6.5l11 11M17.5 6.5l-11 11';
    case 'alkaline':
      return 'M8 12h8M12 8v8';
    case 'stability':
      return 'M5 16l4-4 3 3 7-7';
    case 'handling':
      return 'M6 12l4 4 8-8';
    case 'washout':
      return 'M5 8h14M7 12h10M9 16h6';
    case 'workflow':
      return 'M4 12h16M14 6l6 6-6 6';
    case 'repair':
      return 'M12 3v18M3 12h18';
  }
}
---

<section class="border-b border-slate-200/80 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{eyebrow}</p>}
    <h2 class="mt-3 text-4xl font-bold tracking-tight text-slate-900">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{intro}</p>}
    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {items.map((item) => (
        <article
          class:list={[
            'feature-card rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl',
            accentMap.card,
          ]}
        >
          <div
            class:list={[
              'feature-icon inline-flex h-12 w-12 items-center justify-center rounded-2xl border transition-colors',
              accentMap.icon,
            ]}
            style={`--feature-icon-hover:${accentMap.iconHover}; --feature-icon-glow:${accentMap.iconGlow};`}
          >
            <svg class="feature-icon-glyph h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconPath(item.icon)}></path>
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-icon {
    transition: transform 220ms ease, box-shadow 220ms ease, background-color 220ms ease;
    transform-origin: center;
  }

  .feature-icon-glyph {
    transition: transform 240ms ease;
    transform-origin: center;
  }

  .feature-card:hover .feature-icon {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 14px 30px -18px var(--feature-icon-glow);
    background-color: var(--feature-icon-hover);
  }

  .feature-card:hover .feature-icon-glyph {
    transform: scale(1.06);
  }
</style>
