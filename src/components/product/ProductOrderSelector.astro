---
type OrderItem = {
  size: string;
  length: string;
  sku: string;
  price: string;
  status: string;
  productUrl: string | null;
  cartUrl: string | null;
  isMb2?: boolean;
};

type Props = {
  eyebrow?: string;
  title: string;
  description: string;
  items: OrderItem[];
  coverageLabel: string;
  packFormat: string;
};

const {
  eyebrow = 'NZ Ordering',
  title,
  description,
  items,
  coverageLabel,
  packFormat,
} = Astro.props;

const configurations = Array.from(
  new Map(
    items.map((item) => [
      item.size,
      {
        value: item.size,
        label: item.isMb2 ? `${item.size} MB2` : item.size,
        isMb2: Boolean(item.isMb2),
      },
    ]),
  ).values(),
);

const defaultItem = items.find((item) => item.status === 'Available to order online') ?? items[0];
const defaultConfiguration = defaultItem.size;
const defaultLengths = items.filter((item) => item.size === defaultConfiguration);
const selectorId = `order-selector-${defaultItem.sku.toLowerCase()}`;
---

<section class="border-b border-slate-200/80 bg-white" data-order-selector={selectorId}>
  <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
    <div class="overflow-hidden rounded-[1.6rem] border border-slate-200 bg-slate-50/70 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]">
      <div class="border-b border-slate-200/80 px-6 py-8 sm:px-8 sm:py-10">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{eyebrow}</p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{title}</h2>
            <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">{description}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            <article class="rounded-[1.15rem] border border-slate-200 bg-white px-4 py-4">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-500">Sequence Coverage</p>
              <p class="mt-2 text-base font-semibold leading-7 text-slate-900">{coverageLabel}</p>
            </article>
            <article class="rounded-[1.15rem] border border-slate-200 bg-white px-4 py-4">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-500">Pack Format</p>
              <p class="mt-2 text-base font-semibold leading-7 text-slate-900">{packFormat}</p>
            </article>
          </div>
        </div>
      </div>

      <div class="grid gap-6 px-6 py-8 sm:px-8 sm:py-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)] lg:items-start">
        <div>
          <div class="rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Step 1</p>
            <h3 class="mt-2 text-xl font-bold tracking-tight text-slate-900">Choose file configuration</h3>
            <div class="mt-5 flex flex-wrap gap-3" data-order-configurations>
              {configurations.map((configuration) => (
                <button
                  type="button"
                  class={`rounded-full border px-4 py-2 text-sm font-semibold transition ${
                    configuration.value === defaultConfiguration
                      ? 'border-slate-900 bg-slate-900 text-white'
                      : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:text-slate-950'
                  }`}
                  data-configuration-button
                  data-configuration={configuration.value}
                >
                  {configuration.label}
                </button>
              ))}
            </div>
          </div>

          <div class="mt-4 rounded-[1.35rem] border border-slate-200 bg-white p-5 sm:p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Step 2</p>
            <h3 class="mt-2 text-xl font-bold tracking-tight text-slate-900">Choose file length</h3>
            <div class="mt-5 flex flex-wrap gap-3" data-order-lengths>
              {defaultLengths.map((item) => (
                <button
                  type="button"
                  class={`rounded-full border px-4 py-2 text-sm font-semibold transition ${
                    item.length === defaultItem.length
                      ? 'border-teal-700 bg-teal-50 text-teal-800'
                      : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:text-slate-950'
                  }`}
                  data-length-button
                  data-length={item.length}
                >
                  {item.length}
                </button>
              ))}
            </div>
            <p class="mt-5 text-sm leading-6 text-slate-600">
              The MB2 option is limited to 17 mm. Standard Acrobat sequence files are available in 21 mm, 25 mm, and 29 mm.
            </p>
          </div>

          <div class="mt-4 rounded-[1.35rem] border border-dashed border-slate-300 bg-white p-5 sm:p-6" data-order-fallback>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">All Order Options</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              If interactive selection is unavailable, use the direct links below to open the exact file listing.
            </p>
            <div class="mt-5 grid gap-3">
              {items.map((item) => (
                <article class="rounded-[1rem] border border-slate-200 bg-slate-50/80 px-4 py-4">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <p class="text-sm font-semibold text-slate-900">{item.isMb2 ? `${item.size} MB2` : item.size} · {item.length}</p>
                      <p class="mt-1 text-sm text-slate-600">SKU: {item.sku}</p>
                    </div>
                    <p class="text-sm font-semibold text-slate-900">{item.price}</p>
                  </div>
                  <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                    {(item.cartUrl || item.productUrl) && (
                      <a
                        href={item.cartUrl ?? item.productUrl ?? '/about/contact/'}
                        class="inline-flex items-center justify-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800"
                      >
                        {item.cartUrl ? 'Add 6-pack to cart' : 'View Shopify product'}
                      </a>
                    )}
                    {item.productUrl && (
                      <a
                        href={item.productUrl}
                        class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950"
                      >
                        Open Shopify listing
                      </a>
                    )}
                    {!item.cartUrl && !item.productUrl && (
                      <a
                        href="/about/contact/"
                        class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950"
                      >
                        Contact EndoTech
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>

        <aside class="rounded-[1.45rem] border border-slate-200 bg-white p-5 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)] sm:p-6" data-order-summary>
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Selected File</p>
              <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900" data-summary-heading>{defaultItem.size}</h3>
              <p class="mt-2 text-base font-semibold text-slate-600" data-summary-length>{defaultItem.length}</p>
            </div>
            <span
              class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ${
                defaultItem.status === 'Available to order online'
                  ? 'bg-emerald-50 text-emerald-700'
                  : defaultItem.status === 'Contact for availability'
                    ? 'bg-amber-50 text-amber-700'
                    : 'bg-slate-100 text-slate-600'
              }`}
              data-summary-status-badge
            >
              {defaultItem.status}
            </span>
          </div>

          <dl class="mt-6 grid gap-3">
            <div class="rounded-[1rem] border border-slate-200 bg-slate-50/80 px-4 py-3">
              <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">SKU</dt>
              <dd class="mt-2 text-sm font-semibold leading-6 text-slate-900" data-summary-sku>{defaultItem.sku}</dd>
            </div>
            <div class="rounded-[1rem] border border-slate-200 bg-slate-50/80 px-4 py-3">
              <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Current NZ Price</dt>
              <dd class="mt-2 text-sm font-semibold leading-6 text-slate-900" data-summary-price>{defaultItem.price}</dd>
            </div>
            <div class="rounded-[1rem] border border-slate-200 bg-slate-50/80 px-4 py-3">
              <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Availability</dt>
              <dd class="mt-2 text-sm font-semibold leading-6 text-slate-900" data-summary-status>{defaultItem.status}</dd>
            </div>
          </dl>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {(defaultItem.cartUrl || defaultItem.productUrl) && (
              <a
                href={defaultItem.cartUrl ?? defaultItem.productUrl ?? '/about/contact/'}
                class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
                data-summary-primary
              >
                {defaultItem.cartUrl ? 'Add 6-pack to cart' : 'View Shopify product'}
              </a>
            )}
            {!defaultItem.cartUrl && !defaultItem.productUrl && (
              <a
                href="/about/contact/"
                class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
                data-summary-primary
              >
                Contact EndoTech
              </a>
            )}
            <a
              href={defaultItem.productUrl ?? '/about/contact/'}
              class={`inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950 ${
                defaultItem.productUrl ? '' : 'hidden'
              }`}
              data-summary-secondary
            >
              Open Shopify listing
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ items, configurations, defaultConfiguration, selectorId }}>
  const orderItems = items;
  const configurationMeta = configurations;

  const selectorRoot = document.querySelector(`[data-order-selector="${selectorId}"]`);
  const configurationContainer = selectorRoot?.querySelector('[data-order-configurations]');
  const lengthContainer = selectorRoot?.querySelector('[data-order-lengths]');
  const summaryRoot = selectorRoot?.querySelector('[data-order-summary]');
  const fallbackRoot = selectorRoot?.querySelector('[data-order-fallback]');

  if (configurationContainer && lengthContainer && summaryRoot && selectorRoot) {
    if (fallbackRoot instanceof HTMLElement) {
      fallbackRoot.classList.add('hidden');
    }

    let activeConfiguration = defaultConfiguration;
    let activeLength =
      orderItems.find((item) => item.size === activeConfiguration && item.status === 'Available to order online')?.length ??
      orderItems.find((item) => item.size === activeConfiguration)?.length ??
      '';

    const heading = summaryRoot.querySelector('[data-summary-heading]');
    const length = summaryRoot.querySelector('[data-summary-length]');
    const sku = summaryRoot.querySelector('[data-summary-sku]');
    const price = summaryRoot.querySelector('[data-summary-price]');
    const status = summaryRoot.querySelector('[data-summary-status]');
    const statusBadge = summaryRoot.querySelector('[data-summary-status-badge]');
    const primary = summaryRoot.querySelector('[data-summary-primary]');
    const secondary = summaryRoot.querySelector('[data-summary-secondary]');

    const getStatusClasses = (value) => {
      if (value === 'Available to order online') return 'inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-emerald-50 text-emerald-700';
      if (value === 'Contact for availability') return 'inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-amber-50 text-amber-700';
      return 'inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-slate-100 text-slate-600';
    };

    const renderLengths = () => {
      const filtered = orderItems.filter((item) => item.size === activeConfiguration);
      activeLength =
        filtered.find((item) => item.length === activeLength)?.length ??
        filtered.find((item) => item.status === 'Available to order online')?.length ??
        filtered[0]?.length ??
        '';

      lengthContainer.innerHTML = filtered
        .map((item) => {
          const activeClasses =
            item.length === activeLength
              ? 'border-teal-700 bg-teal-50 text-teal-800'
              : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:text-slate-950';

          return `<button type="button" class="rounded-full border px-4 py-2 text-sm font-semibold transition ${activeClasses}" data-length-button data-length="${item.length}">${item.length}</button>`;
        })
        .join('');
    };

    const renderSummary = () => {
      const item =
        orderItems.find((entry) => entry.size === activeConfiguration && entry.length === activeLength) ??
        orderItems.find((entry) => entry.size === activeConfiguration);

      if (!item) return;

      const configLabel = configurationMeta.find((entry) => entry.value === item.size)?.label ?? item.size;

      if (heading) heading.textContent = configLabel;
      if (length) length.textContent = item.length;
      if (sku) sku.textContent = item.sku;
      if (price) price.textContent = item.price;
      if (status) status.textContent = item.status;
      if (statusBadge) {
        statusBadge.textContent = item.status;
        statusBadge.className = getStatusClasses(item.status);
      }
      if (primary) {
        primary.textContent = item.cartUrl ? 'Add 6-pack to cart' : item.productUrl ? 'View Shopify product' : 'Contact EndoTech';
        primary.setAttribute('href', item.cartUrl ?? item.productUrl ?? '/about/contact/');
      }
      if (secondary) {
        if (item.productUrl) {
          secondary.classList.remove('hidden');
          secondary.setAttribute('href', item.productUrl);
        } else {
          secondary.classList.add('hidden');
          secondary.setAttribute('href', '/about/contact/');
        }
      }
    };

    configurationContainer.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const button = target.closest('[data-configuration-button]');
      if (!(button instanceof HTMLElement)) return;

      const nextConfiguration = button.dataset.configuration;
      if (!nextConfiguration || nextConfiguration === activeConfiguration) return;

      activeConfiguration = nextConfiguration;

      configurationContainer.querySelectorAll('[data-configuration-button]').forEach((entry) => {
        if (!(entry instanceof HTMLElement)) return;
        const isActive = entry.dataset.configuration === activeConfiguration;
        entry.className = `rounded-full border px-4 py-2 text-sm font-semibold transition ${
          isActive
            ? 'border-slate-900 bg-slate-900 text-white'
            : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:text-slate-950'
        }`;
      });

      renderLengths();
      renderSummary();
    });

    lengthContainer.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const button = target.closest('[data-length-button]');
      if (!(button instanceof HTMLElement)) return;

      const nextLength = button.dataset.length;
      if (!nextLength) return;

      activeLength = nextLength;

      lengthContainer.querySelectorAll('[data-length-button]').forEach((entry) => {
        if (!(entry instanceof HTMLElement)) return;
        const isActive = entry.dataset.length === activeLength;
        entry.className = `rounded-full border px-4 py-2 text-sm font-semibold transition ${
          isActive
            ? 'border-teal-700 bg-teal-50 text-teal-800'
            : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:text-slate-950'
        }`;
      });

      renderSummary();
    });
  }
</script>
