---
interface Props {
  title?: string;
  items: string[];
}

const { title = 'Packaging', items } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div class="rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-8 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{title}</p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {items.map((item) => (
          <div class="rounded-[1.25rem] border border-slate-200 bg-white px-5 py-4 text-base font-semibold text-slate-900">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
