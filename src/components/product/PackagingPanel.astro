---
interface Props {
  title?: string;
  items: string[];
}

const { title = 'Packaging', items } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-14 sm:py-16 lg:py-20">
    <div class="rounded-[1.5rem] border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-5 shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)] sm:rounded-[2rem] sm:p-8">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{title}</p>
      <div class="mt-5 grid gap-3 sm:mt-6 sm:gap-4 md:grid-cols-2">
        {items.map((item) => (
          <div class="rounded-[1.1rem] border border-slate-200 bg-white px-4 py-3.5 text-sm font-semibold text-slate-900 sm:rounded-[1.25rem] sm:px-5 sm:py-4 sm:text-base">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
