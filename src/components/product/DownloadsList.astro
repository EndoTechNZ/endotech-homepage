---
import type { DownloadItem } from '../../utils/downloads';
import { withBasePath } from '../../utils/paths';

interface Props {
  title: string;
  intro?: string;
  items: DownloadItem[];
}

const { title, intro, items } = Astro.props;
const hasDownloads = items.some((item) => item.href !== '#');
---

<section id="downloads" class="border-b border-slate-200/80 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <h2 class="text-4xl font-bold tracking-tight text-slate-900">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{intro}</p>}
    <div class="mt-10 grid gap-4">
      {items.map((item) => (
        <article class="flex flex-col gap-4 rounded-[1.5rem] border border-slate-200 bg-slate-50/60 p-5 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{item.type}</p>
            <h3 class="mt-2 text-lg font-bold text-slate-900">{item.label}</h3>
          </div>
          {item.href === '#' ? (
            <span class="inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-500">Awaiting files</span>
          ) : (
            <a href={withBasePath(item.href)} class="inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800">
              Open download
            </a>
          )}
        </article>
      ))}
    </div>
    {!hasDownloads && (
      <p class="mt-6 text-sm leading-7 text-slate-500">
        Add brochure, IFU, SDS, or evidence files to <code>public/downloads/iroot/</code> and they will appear here automatically at build time.
      </p>
    )}
  </div>
</section>
