---
interface Props {
  title: string;
  intro?: string;
  steps: string[];
}

const { title, intro, steps } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-slate-950 text-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <h2 class="text-4xl font-bold tracking-tight">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{intro}</p>}
    <div class="mt-10 grid gap-4 lg:grid-cols-7">
      {steps.map((step, index) => (
        <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Step {index + 1}</p>
          <p class="mt-4 text-lg font-bold">{step}</p>
        </div>
      ))}
    </div>
  </div>
</section>
