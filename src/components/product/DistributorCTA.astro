---
import { withBasePath } from '../../utils/paths';

interface Props {
  title: string;
  body: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title,
  body,
  primaryLabel = 'Request distributor information',
  primaryHref = '/about/contact/',
  secondaryLabel = 'View downloads',
  secondaryHref = '/products/bcs/evidence/',
} = Astro.props;
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div class="rounded-[2rem] bg-gradient-to-br from-slate-900 to-slate-800 px-8 py-10 text-white">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-300">Distributor Support</p>
      <h2 class="mt-4 text-4xl font-bold tracking-tight">{title}</h2>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{body}</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={withBasePath(primaryHref)} class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3.5 text-sm font-semibold text-slate-900 hover:bg-slate-100">
          {primaryLabel}
        </a>
        <a href={withBasePath(secondaryHref)} class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3.5 text-sm font-semibold text-white hover:bg-white/8">
          {secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
