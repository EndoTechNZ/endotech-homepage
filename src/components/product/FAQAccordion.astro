---
import type { FAQItem } from '../../data/bcs';

interface Props {
  title: string;
  items: FAQItem[];
}

const { title, items } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-slate-50/70">
  <div class="mx-auto max-w-4xl px-6 py-20">
    <h2 class="text-4xl font-bold tracking-tight text-slate-900">{title}</h2>
    <div class="mt-10 space-y-4">
      {items.map((item) => (
        <details class="faq-item group rounded-[1.5rem] border border-slate-200 bg-white p-6">
          <summary class="cursor-pointer list-none text-lg font-bold text-slate-900">
            {item.question}
          </summary>
          <p class="mt-4 text-sm leading-7 text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-item {
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      background-color 180ms ease;
  }

  .faq-item[open] {
    border-color: rgba(125, 211, 252, 0.88);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 252, 255, 0.98));
    box-shadow:
      0 0 0 1px rgba(191, 219, 254, 0.78),
      0 0 0 5px rgba(186, 230, 253, 0.22),
      0 18px 42px -30px rgba(56, 189, 248, 0.42);
  }
</style>
