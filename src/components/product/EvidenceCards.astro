---
interface EvidenceCardItem {
  title: string;
  description: string;
}

interface Props {
  title: string;
  intro?: string;
  items: EvidenceCardItem[];
}

const { title, intro, items } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-slate-50/70">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <h2 class="text-4xl font-bold tracking-tight text-slate-900">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{intro}</p>}
    <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6">
          <h3 class="text-xl font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
