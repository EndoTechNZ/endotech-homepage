---
import type { ComparisonRow } from '../../data/bcs';

interface Props {
  title: string;
  intro?: string;
  rows: ComparisonRow[];
  productLabel: string;
  conventionalLabel: string;
}

const { title, intro, rows, productLabel, conventionalLabel } = Astro.props;
---

<section class="border-b border-slate-200/80 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <h2 class="text-4xl font-bold tracking-tight text-slate-900">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{intro}</p>}
    <div class="mt-10 overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">Feature</th>
            <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">{productLabel}</th>
            <th class="px-6 py-4 text-left text-sm font-semibold text-slate-900">{conventionalLabel}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          {rows.map((row) => (
            <tr>
              <td class="px-6 py-5 text-sm font-semibold text-slate-900">{row.label}</td>
              <td class="px-6 py-5 text-sm leading-7 text-slate-600">{row.product}</td>
              <td class="px-6 py-5 text-sm leading-7 text-slate-600">{row.conventional}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
