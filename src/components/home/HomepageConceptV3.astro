---
import logoIcon from '../../assets/endotech-logo-2.png';
import WorkflowStrip from '../navigation/WorkflowStrip.astro';
import transformxSystem from '../../assets/transformx-rotary-file-system.png';
import etProduct from '../../assets/et-transformx.png';
import ptProduct from '../../assets/pt-transformx.png';
import acrobatProduct from '../../assets/acrobat-glide-path-files.png';
import bcsSealer from '../../assets/bcs-sealer.png';
import vortiflowFlow from '../../assets/vortiflow/vortiflow-fluid-dynamics-clean.png';
import { siteConfig } from '../../config/site';
import { getWorkflowStripItems } from '../../data/workflowStrip';

const base = import.meta.env.BASE_URL;
const avatarTipVideo = `${base}videos/avatar-tip/avatar-tip-rounded.mp4`;

const navItems = [
  { label: 'Home', href: base },
  { label: 'Products', href: `${base}products/overview/` },
  { label: 'Clinical Workflow', href: `${base}technique/workflow/` },
  { label: 'Technology', href: `${base}technology/transform-technology/` },
  { label: 'Order', href: `${base}order/` },
  { label: 'Education', href: `${base}resources/clinical-tips/` },
  { label: 'Evidence & Downloads', href: `${base}products/bcs/evidence/` },
  { label: 'About', href: `${base}about/company/` },
];

const productMenu = [
  { label: 'Product Overview', href: `${base}products/overview/` },
  { label: 'ET TransformX Files', href: `${base}products/et-transformx/` },
  { label: 'PT TransformX Files', href: `${base}products/pt-transformx/` },
  { label: 'Acrobat Glide Path Files', href: `${base}products/acrobat-glide-path/` },
  { label: 'VortiFlow Irrigation Needle', href: `${base}products/vortiflow-irrigation-needle/` },
  { label: 'BCS BioCeramics Family', href: `${base}products/bcs/` },
];

const clinicalPairs = [
  {
    problem: 'Curved canals increase restoring forces and concentrate procedural risk near working length.',
    response: 'Avatar Tip and TransformX file behaviour support apical guidance, canal centring, and controlled advancement where tolerance for error is lowest.',
  },
  {
    problem: 'Preparation shape affects irrigation exchange, obturation control, and the quality of the final seal.',
    response: 'EndoTech links glide path, shaping, cleaning support, and bioceramic sealing as one clinical sequence, not separate product decisions.',
  },
  {
    problem: 'Clinicians need more control without disrupting familiar technique or sequence logic.',
    response: 'TransformX is positioned for predictable shaping behaviour within familiar workflows, helping clinicians adapt to demanding anatomy without unnecessary complexity.',
  },
];

const workflow = getWorkflowStripItems(base);

const products = [
  {
    eyebrow: 'Contact for details',
    title: 'ET TransformX Files',
    description: 'For clinicians already shaping with ET, EdgeX7, or other .04/.06-style sequences.',
    tags: ['EdgeTaper', 'EdgeX7', '.04/.06'],
    image: etProduct.src,
    href: `${base}products/et-transformx/`,
  },
  {
    eyebrow: 'Contact for details',
    title: 'PT TransformX Files',
    description: 'For clinicians using ProTaper-style systems who want familiar progression with more control.',
    tags: ['ProTaper Gold', 'ProTaper Next'],
    image: ptProduct.src,
    href: `${base}products/pt-transformx/`,
  },
  {
    eyebrow: 'Educational overview',
    title: 'VortiFlow Irrigation Needle',
    description: 'Engineered lateral-flow irrigation positioned between shaping and final sealing.',
    tags: ['Irrigation', 'Lateral Flow', 'Helical Channel'],
    image: vortiflowFlow.src,
    href: `${base}products/vortiflow-irrigation-needle/`,
  },
  {
    eyebrow: 'Contact for details',
    title: 'BCS BioCeramic Materials',
    description: 'Premixed bioceramic materials for practices building a matched shaping-to-sealing workflow.',
    tags: ['Sealing + Repair', 'Bioceramic'],
    image: bcsSealer.src,
    href: `${base}products/bcs/`,
  },
];

const productChooserNote =
  'Request pricing, pack configuration, and New Zealand availability directly from EndoTech.';

const evidence = [
  'Transform Technology overview',
  'Avatar Tip and apical control',
  'Technique sheets and part numbers',
  'Clinical education resources',
];
---

<header class="v3-header">
  <a class="brand" href={base} aria-label={`${siteConfig.name} home`}>
    <img src={logoIcon.src} alt="" />
    <span>
      <strong>{siteConfig.name}</strong>
      <small>Engineered endodontics</small>
    </span>
  </a>

  <nav aria-label="Primary navigation">
    {navItems.map((item) => (
      item.label === 'Products' ? (
        <div class="products-menu">
          <button
            id="homepage-products-menu-button"
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="homepage-products-menu-panel"
          >
            Products
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </button>
          <div class="products-menu-bridge"></div>
          <div id="homepage-products-menu-panel" class="products-menu-panel">
            <div class="products-menu-shell">
              <span>Product lineup</span>
              {productMenu.map((product) => (
                <a href={product.href}>{product.label}</a>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <a href={item.href}>{item.label}</a>
      )
    ))}
  </nav>

  <div class="header-actions">
    <a class="header-action" href={`${base}about/contact/`}>Contact</a>
    <button class="header-menu-toggle" id="homepage-mobile-menu-button" type="button" aria-expanded="false" aria-controls="homepage-mobile-menu">
      Menu
    </button>
  </div>
</header>

<div id="homepage-mobile-menu" class="homepage-mobile-menu">
  <div class="homepage-mobile-menu-shell">
    <a href={base}>Home</a>
    <a href={`${base}products/overview/`}>Product Overview</a>
    <a href={`${base}technique/workflow/`}>Clinical Workflow</a>
    <a href={`${base}technology/transform-technology/`}>Technology</a>
    <a href={`${base}order/`}>Order</a>
    <a href={`${base}products/acrobat-glide-path/`}>Acrobat Glide Path</a>
    <a href={`${base}products/et-transformx/`}>ET TransformX</a>
    <a href={`${base}products/pt-transformx/`}>PT TransformX</a>
    <a href={`${base}products/vortiflow-irrigation-needle/`}>VortiFlow</a>
    <a href={`${base}products/bcs/`}>BCS Family</a>
    <a href={`${base}resources/clinical-tips/`}>Education</a>
    <a href={`${base}products/bcs/evidence/`}>Evidence & Downloads</a>
    <a href={`${base}about/company/`}>About</a>
    <a href={`${base}about/contact/`}>Contact</a>
  </div>
</div>

<main class="homepage-v3">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">EndoTech NZ</p>
      <h1 id="hero-title">
        <span class="hero-title-line hero-title-line--primary">Reduce the unexpected</span>
        <span class="hero-title-line hero-title-line--context">in Endodontics</span>
        <span class="hero-title-line hero-title-line--support">Products Engineered for Success</span>
      </h1>
      <p>
        Engineered endodontic systems for controlled shaping, predictable sealing, and clinical confidence from glide path to final restoration.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#workflow">Review the workflow</a>
        <a class="button secondary" href="#technology">Explore technology</a>
        <a class="button secondary" href="#products">View products</a>
      </div>
    </div>

    <figure class="hero-figure">
      <img src={transformxSystem.src} alt="TransformX rotary file system" />
      <figcaption>
        <strong>TransformX system</strong>
        <span>Shaping technology positioned inside a complete clinical workflow.</span>
      </figcaption>
    </figure>
  </section>

  <WorkflowStrip />

  <section class="statement" aria-labelledby="statement-title">
    <p class="eyebrow">Clinical Positioning</p>
    <h2 id="statement-title">A system-first approach to safer shaping, cleaner preparation, and more predictable sealing.</h2>
  </section>

  <section class="problem-response" aria-label="Clinical problem and EndoTech response">
    {clinicalPairs.map((pair, index) => (
      <article data-response-row>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <div class="problem-copy">
          <h3>Clinical problem</h3>
          <p>{pair.problem}</p>
        </div>
        <div class="response-arrow" aria-hidden="true"></div>
        <div class="response-copy">
          <h3>EndoTech response</h3>
          <p>{pair.response}</p>
        </div>
      </article>
    ))}
  </section>

  <section id="workflow" class="workflow-section" aria-labelledby="workflow-title">
    <div class="section-heading">
      <p class="eyebrow">Workflow Architecture</p>
      <h2 id="workflow-title">A sequence designed for control, not a loose collection of instruments.</h2>
      <p>
        Each stage has a defined clinical role. The homepage introduces the sequence first, then guides clinicians into the products, technique documents, and evidence that support it.
      </p>
    </div>

    <ol class="workflow-map">
      {workflow.map((item) => (
        <li>
          <strong>{item.step}</strong>
          <p>{item.note}</p>
        </li>
      ))}
    </ol>
  </section>

  <section id="technology" class="technology-section" aria-labelledby="technology-title">
    <div class="section-heading">
      <p class="eyebrow">Technology</p>
      <h2 id="technology-title">Technology is presented through the clinical risks it helps control.</h2>
      <p>
        Transform Technology and Avatar Tip are not presented as isolated features. They are connected directly to shaping behaviour, apical control, and predictable preparation geometry.
      </p>
    </div>

    <div class="technology-grid">
      <figure>
        <video
          data-avatar-tip-video
          autoplay
          loop
          muted
          playsinline
          preload="auto"
          aria-label="Avatar Tip rounded leading geometry video"
        >
          <source src={avatarTipVideo} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
        <figcaption>Avatar Tip / apical guidance</figcaption>
      </figure>
      <figure class="fluid-dynamics-figure">
        <img src={vortiflowFlow.src} alt="VortiFlow irrigation flow dynamics" />
        <figcaption>VortiFlow / micro fluid dynamics</figcaption>
      </figure>
    </div>
  </section>

  <section id="products" class="products-section" aria-labelledby="products-title">
    <div class="section-heading">
      <p class="eyebrow">Products</p>
      <h2 id="products-title">Choose your system.</h2>
    </div>

    <div class="product-chooser" role="list">
      {products.map((product) => (
        <a href={product.href} role="listitem">
          <figure>
            <img src={product.image} alt="" />
          </figure>
          <div class="product-chooser-copy">
            <div class="product-chooser-heading">
              <h3>{product.title}</h3>
              <span>{product.eyebrow}</span>
            </div>
            <p>{product.description}</p>
            <div class="product-chooser-tags" aria-hidden="true">
              {product.tags.map((tag) => (
                <small>{tag}</small>
              ))}
            </div>
            <strong>View details</strong>
          </div>
        </a>
      ))}
    </div>

    <p class="product-chooser-note">{productChooserNote}</p>
  </section>

  <section id="evidence" class="evidence-section" aria-labelledby="evidence-title">
    <div>
      <p class="eyebrow">Evidence & Education</p>
      <h2 id="evidence-title">Evidence, education, and downloads support clinical evaluation before product selection.</h2>
    </div>

    <ul>
      {evidence.map((item) => (
        <li>
          <span>{item}</span>
          <a href={`${base}resources/downloads/`}>
            <span>Open</span>
            <span aria-hidden="true" class="evidence-link-arrow">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="closing" aria-labelledby="closing-title">
    <div>
      <p class="eyebrow">Next Step</p>
      <h2 id="closing-title">Review the system, then choose the product path that matches the case.</h2>
      <p>
        Start with the clinical workflow, review the technology, then move into product detail or contact EndoTech NZ for clinical and distribution enquiries.
      </p>
    </div>
    <div class="closing-actions">
      <a class="button primary" href={`${base}products/overview/`}>View product system</a>
      <a class="button secondary" href={`${base}about/contact/`}>Contact EndoTech NZ</a>
    </div>
  </section>
</main>

<footer class="v3-footer">
  <strong>{siteConfig.name}</strong>
  <span>{siteConfig.organizationDescription}</span>
  <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
</footer>

<script>
  const productsMenu = document.querySelector('.v3-header .products-menu');
  const productsMenuButton = document.getElementById('homepage-products-menu-button');
  const mobileMenu = document.getElementById('homepage-mobile-menu');
  const mobileMenuButton = document.getElementById('homepage-mobile-menu-button');

  const setProductsMenu = (open) => {
    if (!productsMenu || !productsMenuButton) return;
    productsMenu.classList.toggle('is-open', open);
    productsMenuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
  };

  const setMobileMenu = (open) => {
    if (!mobileMenu || !mobileMenuButton) return;
    mobileMenu.classList.toggle('is-open', open);
    mobileMenuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
  };

  productsMenuButton?.addEventListener('click', (event) => {
    event.preventDefault();
    const isOpen = productsMenuButton.getAttribute('aria-expanded') === 'true';
    setProductsMenu(!isOpen);
  });

  productsMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setProductsMenu(false));
  });

  mobileMenuButton?.addEventListener('click', () => {
    const isOpen = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    setMobileMenu(!isOpen);
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMobileMenu(false));
  });

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node) || !productsMenu) return;
    if (!productsMenu.contains(event.target)) setProductsMenu(false);
    if (mobileMenu && mobileMenuButton && !mobileMenu.contains(event.target) && !mobileMenuButton.contains(event.target)) {
      setMobileMenu(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setProductsMenu(false);
      setMobileMenu(false);
    }
  });

  document.querySelectorAll('[data-response-row]').forEach((row) => {
    let leaveTimer;

    row.addEventListener('pointerenter', () => {
      window.clearTimeout(leaveTimer);
      row.classList.remove('is-arrow-leaving');
      row.classList.add('is-arrow-active');
    });

    row.addEventListener('pointerleave', () => {
      row.classList.remove('is-arrow-active');
      row.classList.add('is-arrow-leaving');

      leaveTimer = window.setTimeout(() => {
        row.classList.remove('is-arrow-leaving');
      }, 360);
    });
  });

  document.querySelectorAll('[data-avatar-tip-video]').forEach((element) => {
    if (!(element instanceof HTMLVideoElement)) return;

    const setSlowLoop = () => {
      element.defaultPlaybackRate = 0.5;
      element.playbackRate = 0.5;
    };

    setSlowLoop();
    element.addEventListener('loadedmetadata', setSlowLoop);
    element.addEventListener(
      'canplay',
      () => {
        element.play().catch(() => {});
      },
      { once: true }
    );
  });
</script>

<style>
  :global(html) {
    scroll-padding-top: 96px;
  }

  :global(body.landing-page) {
    background: #f7f9fb;
    color: #101827;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .v3-header,
  .hero,
  .statement,
  .problem-response,
  .workflow-section,
  .technology-section,
  .products-section,
  .evidence-section,
  .closing,
  .v3-footer {
    padding-left: 56px;
    padding-right: 56px;
  }

  .v3-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: minmax(210px, auto) 1fr auto;
    gap: 28px;
    align-items: center;
    min-height: 82px;
    border-bottom: 1px solid #dbe3ea;
    background: rgba(247, 249, 251, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .brand img {
    width: 42px;
  }

  .brand span {
    display: grid;
    gap: 3px;
    line-height: 1;
  }

  .brand strong,
  .v3-footer strong {
    color: #0b1424;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
  }

  .brand small {
    color: #64748b;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .v3-header nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    color: #334155;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .v3-header nav a,
  .products-menu button {
    color: inherit;
    text-decoration: none;
  }

  .products-menu {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .products-menu button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 0;
    padding: 0;
    background: transparent;
    font: inherit;
    cursor: pointer;
  }

  .products-menu svg {
    width: 14px;
    height: 14px;
    transition: transform 180ms ease;
  }

  .products-menu path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .products-menu-bridge {
    position: absolute;
    top: 100%;
    left: 50%;
    width: 280px;
    height: 16px;
    transform: translateX(-50%);
  }

  .products-menu-panel {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    z-index: 80;
    width: 300px;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 8px);
    transition:
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .products-menu-shell {
    display: grid;
    gap: 2px;
    border: 1px solid #d8e1e8;
    border-radius: 6px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 24px 55px -34px rgba(15, 23, 42, 0.34);
    backdrop-filter: blur(16px);
  }

  .products-menu-shell span {
    padding: 6px 8px 8px;
    color: #876a2b;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .products-menu-shell a {
    border-radius: 4px;
    padding: 10px 8px;
    color: #344357;
    font-size: 0.86rem;
    font-weight: 700;
    transition:
      background 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .products-menu-shell a:hover,
  .products-menu-shell a:focus-visible {
    background: #f3f7fa;
    color: #0b1424;
    transform: translateX(2px);
  }

  .products-menu:hover .products-menu-panel,
  .products-menu:focus-within .products-menu-panel,
  .products-menu.is-open .products-menu-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .products-menu:hover svg,
  .products-menu:focus-within svg,
  .products-menu.is-open svg {
    transform: translateY(1px);
  }

  .header-action,
  .header-menu-toggle,
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .header-action {
    padding: 0 18px;
    border: 1px solid #c8d2dc;
    color: #0b1424;
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .header-menu-toggle {
    display: none;
    border: 1px solid #c8d2dc;
    padding: 0 16px;
    background: #ffffff;
    color: #0b1424;
    cursor: pointer;
  }

  .homepage-mobile-menu {
    display: none;
    border-bottom: 1px solid #dbe3ea;
    background: rgba(247, 249, 251, 0.98);
  }

  .homepage-mobile-menu-shell {
    display: grid;
    gap: 8px;
    padding: 14px 18px 18px;
  }

  .homepage-mobile-menu-shell a {
    border: 1px solid #dbe3ea;
    border-radius: 6px;
    padding: 12px 14px;
    color: #0b1424;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.92);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 0.86fr);
    gap: 76px;
    align-items: center;
    min-height: 720px;
    padding-top: 72px;
    padding-bottom: 84px;
    background:
      linear-gradient(90deg, #f7f9fb 0%, #f7f9fb 54%, #e3ebf1 54%, #e3ebf1 100%);
  }

  .eyebrow {
    margin: 0 0 18px;
    color: #876a2b;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    display: grid;
    gap: 8px;
    max-width: 760px;
    margin-bottom: 26px;
    color: #0b1424;
    font-size: 4.8rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.94;
    text-wrap: balance;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-line--primary {
    max-width: 12ch;
  }

  .hero-title-line--context {
    color: #24384f;
    font-size: 0.54em;
    font-weight: 650;
    line-height: 1.08;
  }

  .hero-title-line--support {
    width: fit-content;
    margin-top: 12px;
    border-top: 1px solid #b8c4cf;
    padding-top: 16px;
    color: #41556c;
    font-size: 0.32em;
    font-weight: 700;
    line-height: 1.16;
  }

  h2 {
    color: #0b1424;
    font-size: 3.35rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.08;
  }

  h3 {
    color: #0b1424;
    font-size: 1.22rem;
    line-height: 1.26;
  }

  .hero-copy p,
  .section-heading p,
  .closing p {
    max-width: 700px;
    color: #4b5c70;
    font-size: 1.14rem;
    line-height: 1.76;
  }

  .hero-actions,
  .closing-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .button {
    padding: 0 24px;
  }

  .button.primary {
    background: #0b1424;
    color: #ffffff;
  }

  .button.secondary {
    border: 1px solid #b8c4cf;
    color: #0b1424;
