<div class="avatar-cursor-dot" aria-hidden="true"></div>

<script is:inline>
  (() => {
    if (typeof window === 'undefined') return;
    if (!window.matchMedia('(pointer: fine)').matches) return;

    const dot = document.querySelector('.avatar-cursor-dot');
    if (!dot) return;

    let active = false;
    let currentTarget = null;

    const showDot = () => {
      active = true;
      dot.classList.add('is-visible');
    };

    const hideDot = () => {
      active = false;
      dot.classList.remove('is-visible');
    };

    const moveDot = (event) => {
      if (!active) return;
      dot.style.left = `${event.clientX}px`;
      dot.style.top = `${event.clientY}px`;
    };

    const handlePointerEnter = (event) => {
      const summary = event.target.closest('.avatar-toggle__summary');
      if (!summary) return;
      currentTarget = summary;
      showDot();
      moveDot(event);
    };

    const handlePointerMove = (event) => {
      if (!currentTarget) return;
      if (!event.target.closest('.avatar-toggle__summary')) return;
      moveDot(event);
    };

    const handlePointerLeave = (event) => {
      if (!currentTarget) return;
      const related = event.relatedTarget;
      if (related instanceof Element && currentTarget.contains(related)) return;
      currentTarget = null;
      hideDot();
    };

    document.addEventListener('pointerover', handlePointerEnter);
    document.addEventListener('pointermove', handlePointerMove);
    document.addEventListener('pointerout', handlePointerLeave);
    document.addEventListener('astro:after-swap', hideDot);
  })();
</script>
